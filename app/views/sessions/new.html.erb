<div class="login-container">
  <div class="login-card page-content">
    <h1>ログイン</h1>
    <p class="login-subtitle">Team Site へようこそ</p>

    <% if flash[:alert].present? %>
      <div class="alert alert-danger">
        <%= flash[:alert] %>
      </div>
    <% end %>

    <%= form_with url: login_path, method: :post, class: "login-form" do |f| %>
      <div class="form-group">
        <%= f.label :username, "ユーザー名" %>
        <%= f.text_field :username, required: true, placeholder: "ユーザー名を入力してください" %>
      </div>

      <div class="form-group">
        <%= f.label :password, "パスワード" %>
        <%= f.password_field :password, required: true, placeholder: "パスワードを入力してください" %>
      </div>

      <%= f.submit "ログイン", class: "btn btn-primary btn-block" %>
    <% end %>

    <div class="login-info">
      <h3>テスト用アカウント</h3>
      <div class="account-info">
        <h4>管理者</h4>
        <p><strong>ユーザー名:</strong> admin</p>
        <p><strong>パスワード:</strong> admin123</p>
      </div>
      <div class="account-info">
        <h4>一般メンバー</h4>
        <p><strong>ユーザー名:</strong> member</p>
        <p><strong>パスワード:</strong> member123</p>
      </div>
    </div>

    <p class="login-footer">
      <a href="/">ホームに戻る</a>
    </p>
  </div>
</div>

<style>
  .login-container {
    min-height: calc(100vh - 140px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  /* page-content の装飾を活かしつつ、ログイン画面用の幅に固定 */
  .login-card {
    width: 100%;
    max-width: 420px;
  }

  .login-card h1 {
    text-align: center;
    margin-bottom: 10px;
    font-family: var(--font-heading); /* 統一感のために見出しフォントを適用 */
  }

  .login-subtitle {
    text-align: center;
    color: var(--clr-text-dim); /* pages.css のテーマ変数を使用 */
    margin-bottom: 30px;
    font-size: 14px;
  }

  /* フォーム要素の余白調整 */
  .login-form .form-group {
    margin-bottom: 20px;
  }

  /* ★ここを追加：入力フォームの文字色を黒にする */
  .login-form .form-group input {
    color: #000000;
  }

  .btn-block {
    width: 100%;
    margin-top: 20px;
  }

  /* エラーメッセージ（flash-alert 等と同じような雰囲気に調整） */
  .alert {
    padding: 12px;
    border-radius: var(--radius-sm);
    margin-bottom: 20px;
    font-size: 14px;
    border: 1px solid;
  }

  .alert-danger {
    background: linear-gradient(135deg, #3a0d0d, #250808);
    color: #fca5a5;
    border-color: #7a1a1a;
  }

  /* テストアカウント情報のエリア */
  .login-info {
    margin-top: 30px;
    padding-top: 30px;
    border-top: 1px dashed var(--clr-border); /* 破線もテーマ色に */
  }

  .login-info h3 {
    font-size: 14px;
    margin-bottom: 15px;
    text-align: center;
    font-family: var(--font-heading);
  }

  .account-info {
    /* キャンバス地の上に置くため、半透明の暗色で馴染ませる */
    background: rgba(0, 0, 0, 0.06); 
    padding: 12px;
    border-radius: var(--radius-sm);
    margin-bottom: 12px;
    font-size: 13px;
    border: 1px solid rgba(0, 0, 0, 0.1);
  }

  .account-info h4 {
    margin: 0 0 8px 0;
    color: #3a2108;
  }

  .account-info p {
    margin: 4px 0;
  }

  .login-footer {
    text-align: center;
    margin-top: 20px;
  }

  .login-footer a {
    color: var(--clr-gold);
    text-decoration: none;
    font-size: 14px;
    transition: color 0.2s;
  }

  .login-footer a:hover {
    color: var(--clr-gold-light);
    text-decoration: underline;
  }

  @media (max-width: 480px) {
    .login-card h1 {
      font-size: 24px;
    }
  }
</style>
