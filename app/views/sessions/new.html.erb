<div class="login-container">
  <div class="login-card">
    <h1>ログイン</h1>
    <p class="login-subtitle">Team Site へようこそ</p>

    <% if flash[:alert].present? %>
      <div class="alert alert-danger">
        <%= flash[:alert] %>
      </div>
    <% end %>

    <%= form_with url: login_path, method: :post, class: "login-form" do |f| %>
      <div class="form-group">
        <%= f.label :username, "ユーザー名" %>
        <%= f.text_field :username, required: true, placeholder: "ユーザー名を入力してください" %>
      </div>

      <div class="form-group">
        <%= f.label :password, "パスワード" %>
        <%= f.password_field :password, required: true, placeholder: "パスワードを入力してください" %>
      </div>

      <%= f.submit "ログイン", class: "btn btn-primary btn-block" %>
    <% end %>

    <div class="login-info">
      <h3>テスト用アカウント</h3>
      <div class="account-info">
        <h4>管理者</h4>
        <p><strong>ユーザー名:</strong> admin</p>
        <p><strong>パスワード:</strong> admin123</p>
      </div>
      <div class="account-info">
        <h4>一般メンバー</h4>
        <p><strong>ユーザー名:</strong> member</p>
        <p><strong>パスワード:</strong> member123</p>
      </div>
    </div>

    <p class="login-footer">
      <a href="/">ホームに戻る</a>
    </p>
  </div>
</div>

<style>
  .login-container {
    min-height: calc(100vh - 140px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  }

  .login-card {
    background: white;
    padding: 40px;
    border-radius: 8px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
    width: 100%;
    max-width: 400px;
  }

  .login-card h1 {
    text-align: center;
    color: #2c3e50;
    margin-bottom: 10px;
  }

  .login-subtitle {
    text-align: center;
    color: #7f8c8d;
    margin-bottom: 30px;
    font-size: 14px;
  }

  .alert {
    padding: 12px;
    border-radius: 4px;
    margin-bottom: 20px;
    font-size: 14px;
  }

  .alert-danger {
    background-color: #f8d7da;
    color: #721c24;
    border: 1px solid #f5c6cb;
  }

  .login-form .form-group {
    margin-bottom: 20px;
  }

  .login-form .form-group label {
    display: block;
    margin-bottom: 8px;
    font-weight: 600;
    color: #2c3e50;
  }

  .login-form .form-group input {
    width: 100%;
    padding: 12px;
    border: 1px solid #ddd;
    border-radius: 4px;
    font-size: 16px;
    box-sizing: border-box;
  }

  .login-form .form-group input:focus {
    outline: none;
    border-color: #667eea;
    box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
  }

  .btn-block {
    width: 100%;
    margin-top: 20px;
  }

  .login-info {
    margin-top: 30px;
    padding-top: 30px;
    border-top: 1px solid #ddd;
  }

  .login-info h3 {
    color: #2c3e50;
    font-size: 14px;
    margin-bottom: 15px;
    text-align: center;
  }

  .account-info {
    background: #f5f5f5;
    padding: 12px;
    border-radius: 4px;
    margin-bottom: 12px;
    font-size: 13px;
  }

  .account-info h4 {
    margin: 0 0 8px 0;
    color: #2c3e50;
  }

  .account-info p {
    margin: 4px 0;
    color: #555;
  }

  .login-footer {
    text-align: center;
    margin-top: 20px;
  }

  .login-footer a {
    color: #667eea;
    text-decoration: none;
    font-size: 14px;
  }

  .login-footer a:hover {
    text-decoration: underline;
  }

  @media (max-width: 480px) {
    .login-card {
      padding: 30px 20px;
    }

    .login-card h1 {
      font-size: 24px;
    }
  }
</style>
