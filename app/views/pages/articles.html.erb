<div class="container">
  <header class="page-header">
    <h1>記事</h1>
    <p>チームの活動記録と思い出</p>
  </header>

  <div class="page-content">
    <div class="articles-actions">
      <button class="btn btn-primary" id="newArticleBtn">新しい記事を投稿</button>
      <div class="filter-section">
        <input type="text" placeholder="記事を検索..." id="searchArticles" class="search-input">
      </div>
    </div>

    <div class="articles-list" id="articlesList">
      <div class="empty-state">
        <p>記事がまだ投稿されていません</p>
      </div>
    </div>
  </div>

  <!-- 記事投稿フォーム（モーダル） -->
  <div class="modal" id="articleModal">
    <div class="modal-content modal-lg">
      <span class="close" id="closeArticleModal">&times;</span>
      <h2>記事を投稿</h2>
      <form id="articleForm">
        <div class="form-group">
          <label for="articleTitle">タイトル</label>
          <input type="text" id="articleTitle" required placeholder="記事のタイトルを入力してください">
        </div>
        <div class="form-group">
          <label for="articleContent">本文</label>
          <textarea id="articleContent" rows="8" required placeholder="記事の内容を入力してください"></textarea>
        </div>
        <div class="form-group">
          <label for="articleTags">タグ（カンマで区切る）</label>
          <input type="text" id="articleTags" placeholder="例：イベント, 冒険, 面白かった">
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn-primary">投稿</button>
          <button type="button" class="btn btn-secondary" id="cancelArticle">キャンセル</button>
        </div>
      </form>
    </div>
  </div>

  <!-- 記事編集フォーム（モーダル） -->
  <div class="modal" id="editArticleModal">
    <div class="modal-content modal-lg">
      <span class="close" id="closeEditModal">&times;</span>
      <h2>記事を編集</h2>
      <form id="editArticleForm">
        <div class="form-group">
          <label for="editArticleTitle">タイトル</label>
          <input type="text" id="editArticleTitle" required>
        </div>
        <div class="form-group">
          <label for="editArticleContent">本文</label>
          <textarea id="editArticleContent" rows="8" required></textarea>
        </div>
        <div class="form-group">
          <label for="editArticleTags">タグ</label>
          <input type="text" id="editArticleTags" placeholder="例：イベント, 冒険, 面白かった">
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn-primary">更新</button>
          <button type="button" class="btn btn-secondary" id="cancelEdit">キャンセル</button>
        </div>
      </form>
    </div>
  </div>
</div>

<style>
  .articles-list {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-top: 30px;
  }

  .article-card {
    padding: 20px;
    border: 1px solid #ddd;
    border-radius: 8px;
    background: white;
  }

  .article-card h3 {
    margin-top: 0;
  }

  .article-meta {
    color: #666;
    font-size: 0.9em;
    margin-top: 10px;
  }

  .article-actions {
    display: flex;
    gap: 10px;
    margin-top: 15px;
  }

  .empty-state {
    text-align: center;
    padding: 40px 20px;
    color: #999;
  }

  .articles-actions {
    display: flex;
    gap: 15px;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
  }

  @media (max-width: 768px) {
    .articles-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .search-input {
      width: 100%;
    }
  }
</style>

<script>
  const newArticleBtn = document.getElementById('newArticleBtn');
  const articleModal = document.getElementById('articleModal');
  const closeArticleModal = document.getElementById('closeArticleModal');
  const cancelArticle = document.getElementById('cancelArticle');

  newArticleBtn.addEventListener('click', () => {
    articleModal.style.display = 'block';
  });

  closeArticleModal.addEventListener('click', () => {
    articleModal.style.display = 'none';
  });

  cancelArticle.addEventListener('click', () => {
    articleModal.style.display = 'none';
  });

  window.addEventListener('click', (e) => {
    if (e.target === articleModal || e.target === document.getElementById('editArticleModal')) {
      e.target.style.display = 'none';
    }
  });
</script>
