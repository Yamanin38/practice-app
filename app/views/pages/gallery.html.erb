<div class="container">
  <header class="page-header">
    <h1>ギャラリー</h1>
    <p>チームの思い出の写真</p>
  </header>

  <div class="page-content">
    <div class="gallery-actions">
      <button class="btn btn-primary" id="uploadBtn">写真を投稿</button>
      <div class="filter-section">
        <input type="text" placeholder="検索..." id="searchInput" class="search-input">
      </div>
    </div>

    <div class="gallery-grid" id="galleryGrid">
      <div class="gallery-item placeholder">
        <div class="placeholder-content">
          <p>写真がまだ投稿されていません</p>
        </div>
      </div>
    </div>
  </div>

  <!-- 写真投稿フォーム（モーダル） -->
  <div class="modal" id="uploadModal">
    <div class="modal-content">
      <span class="close" id="closeModal">&times;</span>
      <h2>写真を投稿</h2>
      <form id="uploadForm">
        <div class="form-group">
          <label for="imageFile">画像ファイル</label>
          <input type="file" id="imageFile" accept="image/*" required>
        </div>
        <div class="form-group">
          <label for="imageCaption">キャプション</label>
          <textarea id="imageCaption" rows="3" placeholder="写真の説明を入力してください"></textarea>
        </div>
        <button type="submit" class="btn btn-primary">投稿</button>
      </form>
    </div>
  </div>
</div>

<style>
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 20px;
    margin-top: 30px;
  }

  .gallery-item {
    position: relative;
    overflow: hidden;
    border-radius: 8px;
    background: #f0f0f0;
    aspect-ratio: 1;
  }

  .placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    grid-column: 1 / -1;
  }

  .gallery-actions {
    display: flex;
    gap: 15px;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
  }

  @media (max-width: 768px) {
    .gallery-grid {
      grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    }
  }
</style>

<script>
  const uploadBtn = document.getElementById('uploadBtn');
  const uploadModal = document.getElementById('uploadModal');
  const closeModal = document.getElementById('closeModal');

  uploadBtn.addEventListener('click', () => {
    uploadModal.style.display = 'block';
  });

  closeModal.addEventListener('click', () => {
    uploadModal.style.display = 'none';
  });

  window.addEventListener('click', (e) => {
    if (e.target === uploadModal) {
      uploadModal.style.display = 'none';
    }
  });
</script>
