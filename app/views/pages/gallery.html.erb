}

.image-modal-body {
  margin: 0;
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
  width: 100%;
}

.modal-full-image {
  max-width: 85vw;
  max-height: 75vh;
  width: auto;
  height: auto;
  display: block;
  object-fit: contain;
}

.modal-upload-date {
  position: absolute;
  bottom: -28px;
  left: 12px;
  color: rgba(255, 255, 255, 0.7);
  font-size: 12px;
}

.modal-image-size {
  position: absolute;
  bottom: -28px;
  right: 12px;
  color: rgba(255, 255, 255, 0.7);
  font-size: 12px;
}

.image-modal-footer {
  display: flex;
  gap: 12px;
  justify-content: center;
  align-items: center;
  width: 100%;
  padding: 36px 20px 14px 20px;
  background: rgba(0, 0, 0, 0.4);
  position: relative;
}

.btn-danger {
  background: linear-gradient(135deg, #e74c3c, #c0392b);
  color: white;
  border: none;
  padding: 8px 20px;
  border-radius: 20px;
  cursor: pointer;
  font-size: 13px;
  font-weight: 600;
  transition: opacity 0.2s ease;
}

.btn-danger:hover {
  opacity: 0.85;
}

.image-modal-footer .btn-secondary {
  background: rgba(255, 255, 255, 0.15);
  color: white;
  border: 1px solid rgba(255, 255, 255, 0.3);
  padding: 8px 20px;
  border-radius: 20px;
  font-size: 13px;
  font-weight: 600;
  transition: background 0.2s ease;
}

.image-modal-footer .btn-secondary:hover {
  background: rgba(255, 255, 255, 0.25);
}

.upload-info {
  color: rgba(255, 255, 255, 0.6);
  font-size: 12px;
}

.upload-modal-content {
  background: white;
  border-radius: 12px;
  padding: 0;
  width: 90%;
  max-width: 480px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: auto;
}

.upload-modal-header {
  width: 100%;
  padding: 20px 20px 0 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.upload-modal-header h2 {
  margin: 0 0 16px 0;
