  }

  .btn-danger {
    background-color: #dc3545;
    color: white;
    border: none;
    padding: 8px 16px;
    border-radius: 4px;
    cursor: pointer;
    font-size: 12px;
  }

  .btn-danger:hover {
    background-color: #c82333;
  }

  .image-view-modal-content {
  background: rgba(15, 15, 15, 0.95);
  border-radius: 12px;
  padding: 0;
  width: auto;
  max-width: 90vw;
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.8);
  overflow: hidden;
  position: relative;
  margin: auto;
}

.image-modal-header {
  position: absolute;
