<div class="container">
  <header class="page-header">
    <h1>ギャラリー</h1>
    <p>チームの思い出の写真</p>
  </header>

  <div class="page-content">
    <div class="gallery-actions">
      <% if @user %>
        <button class="btn btn-primary" id="uploadBtn">写真を投稿</button>
      <% else %>
        <p class="login-prompt"><a href="<%= login_path %>">ログイン</a>して写真を投稿</p>
      <% end %>

      <div class="filter-section">
  <%= form_with url: gallery_path, method: :get, local: true, class: "date-filter-form", data: { turbo: true } do |f| %>
    <button type="button" class="btn-cal-toggle" id="calToggleBtn">
  📅 <span id="calToggleText"><%= params[:date].present? ? params[:date] : "日付で絞り込む" %></span>
</button>
    <div class="calendar-filter" id="calendarFilter" style="display:none;">
      <div class="calendar-header">
        <button type="button" class="cal-nav" id="calPrev">&#8249;</button>
        <span class="cal-title" id="calTitle">
          <select id="calYearSelect" class="cal-year-select"></select>
          <span id="calMonthText"></span>
        </span>
        <button type="button" class="cal-nav" id="calNext">&#8250;</button>
      </div>
      <div class="calendar-weekdays">
        <span>日</span><span>月</span><span>火</span><span>水</span><span>木</span><span>金</span><span>土</span>
      </div>
      <div class="calendar-days" id="calendarDays"></div>
      <input type="hidden" name="date" id="calSelectedDate" value="<%= params[:date] %>">
      <div class="calendar-actions">
    <button type="button" class="btn-cal-clear" id="calClear">クリア</button>
  </div>
    </div>
  <% end %>
</div>
    </div>

    <% if @images.any? %>
      <div class="gallery-grid" id="galleryGrid">
        <% @images.each do |image| %>
  <div class="gallery-item" onclick="openImageModal(<%= image.id %>, '<%= @user&.admin? %>')">
    <% if image.file.present? %>
      <%= image_tag image.file.representation(resize_to_fill: [400, 400]),
    alt: "Gallery image",
    class: "gallery-image",
    data: {
      image_id: image.id,
      full_url: url_for(image.file),
      file_size: image.file.blob.byte_size,
      used_in_articles: image.article_images.map { |ai| ai.article.title }.to_json
    } %>
    <% end %>
    <div class="gallery-overlay">
      <p class="upload-date"><%= image.created_at.strftime("%Y年%m月%d日") %></p>
    </div>
  </div>
<% end %>
      </div>

      <div class="pagination-container">
        <%= paginate @images %>
      </div>

    <% else %>
      <div class="gallery-grid" id="galleryGrid">
        <div class="gallery-item placeholder">
          <div class="placeholder-content">
            <p>写真がまだ投稿されていません</p>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <!-- 写真投稿フォーム（モーダル） -->
  <% if @current_user_view %>
    <div class="modal" id="uploadModal">
      <div class="modal-content">
        <span class="close" id="closeModal">&times;</span>
        <h2>写真を投稿</h2>

        <%= form_with url: images_path, method: :post, local: true, multipart: true, class: "upload-form" do |f| %>
        <div class="upload-preview-area" id="uploadPreviewArea">
          <div class="upload-placeholder" id="uploadPlaceholder">
            <p class="upload-icon">🖼️</p>
            <p class="upload-hint">ファイルを選択、またはここにドラッグ＆ドロップ（最大4枚）</p>
          </div>
          <div class="upload-preview-grid" id="uploadPreviewGrid" style="display:none;"></div>
        </div>

        <div class="upload-file-group">
          <label for="file_input_field" class="file-label">画像を選択（最大4枚）</label>
          <%= f.file_field :files, multiple: true, accept: "image/*", required: true, id: "file_input_field", name: "files[]" %>
        </div>

        <%= f.submit "投稿する", class: "btn btn-primary upload-submit-btn", id: "submitBtn", disabled: true %>
      <% end %>
      </div>
    </div>
  <% end %>

  <!-- 画像拡大モーダル -->
<div class="modal" id="imageViewModal">
  <div class="modal-content image-view-modal-content">
    <div class="image-modal-header">
      <span class="close" id="closeImageModal">&times;</span>
    </div>
    <div class="image-modal-body">
      <img id="modalImage" src="" alt="拡大画像" class="modal-full-image">
      <span class="modal-upload-date" id="modalUploadDate"></span>
      <span class="modal-image-size" id="modalImageSize"></span>
    </div>
    <div class="image-modal-footer">
      <% if @current_user_view&.admin? %>
        <form id="modalDeleteForm" method="POST" style="margin:0;">
          <input type="hidden" name="_method" value="delete">
          <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
          <button type="submit" class="btn btn-danger">🗑 削除</button>
        </form>
      <% end %>
      <button class="btn btn-secondary" id="closeImageModalBtn">閉じる</button>
    </div>
  </div>
</div>

<!-- 削除確認モーダル -->
<div class="modal" id="deleteConfirmModal">
  <div class="modal-content modal-sm" style="margin: 120px auto;">
    <div class="modal-header">
      <h2>🗑️ 削除の確認</h2>
      <button class="modal-close" id="closeDeleteConfirmModal">&times;</button>
    </div>
    <div class="modal-body">
      <p style="color: var(--clr-text); margin-bottom: 24px;">本当にこの写真を削除しますか？<br>元に戻すことはできません。</p>
      <div style="display: flex; gap: 12px; justify-content: flex-end;">
  <button class="btn btn-danger4" id="confirmImageDeleteBtn">削除する</button>
  <button class="btn btn-secondary" id="cancelImageDeleteBtn">キャンセル</button>
</div>
    </div>
  </div>
</div>

<!-- 削除不可モーダル -->
<div class="modal" id="cannotDeleteModal">
  <div class="modal-content modal-sm" style="margin: 120px auto;">
    <div class="modal-header">
      <h2>⚠️ 削除できません</h2>
      <button class="modal-close" id="closeCannotDeleteModal">&times;</button>
    </div>
    <div class="modal-body">
      <p style="color: var(--clr-text); margin-bottom: 16px;">この写真は以下の活動記録に使用されているため削除できません。</p>
      <ul id="cannotDeleteArticleList" style="color: var(--clr-gold-light); padding-left: 20px; margin-bottom: 20px;"></ul>
      <div style="text-align: right;">
        <button class="btn btn-secondary" id="closeCannotDeleteBtn">閉じる</button>
      </div>
    </div>
  </div>
</div>
</div>

<style>
  .pagination-container {
    display: flex;
    justify-content: center;
    margin-top: 30px;
  }

  .pagination-container nav {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    align-items: center;
    justify-content: center;
  }

  .pagination-container nav .page,
  .pagination-container nav .first,
  .pagination-container nav .prev,
  .pagination-container nav .next,
  .pagination-container nav .last,
  .pagination-container nav .gap {
    display: block;
    margin: 0;
    padding: 0;
  }

  .pagination-container nav a,
  .pagination-container nav span {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 36px;
    height: 36px;
    padding: 0 10px;
    border: 1px solid #5a3510;
    border-radius: 4px;
    color: #e8a820;
    text-decoration: none;
    font-size: 14px;
    font-weight: 700;
    background: linear-gradient(180deg, #3a2108 0%, #241400 100%);
    transition: all 0.2s ease;
    line-height: 1;
    box-shadow:
      0 1px 0 rgba(255,200,80,.12) inset,
      0 2px 6px rgba(0,0,0,.5),
      0 1px 0 rgba(0,0,0,.7);
  }

  .pagination-container nav a:hover {
    background: linear-gradient(180deg, #c8820a 0%, #9a5f00 100%);
    color: #fff8e0;
    border-color: #6a3e00;
    box-shadow:
      0 1px 0 rgba(255,200,80,.25) inset,
      0 3px 10px rgba(0,0,0,.6);
  }

  .pagination-container nav .current a,
  .pagination-container nav .current span,
  .pagination-container nav .current em {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 36px;
    height: 36px;
    padding: 0 10px;
    background: linear-gradient(180deg, #c8820a 0%, #7a4800 100%);
    color: #fff8e0;
    border-color: #6a3e00;
    font-style: normal;
    line-height: 1;
    box-shadow:
      0 1px 0 rgba(255,200,80,.25) inset,
      0 2px 8px rgba(0,0,0,.6);
  }

  .pagination-container nav span.page.current {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 36px;
    height: 36px;
    padding: 0 10px;
    background: linear-gradient(180deg, #c8820a 0%, #7a4800 100%);
    color: #fff8e0;
    border-color: #6a3e00;
    line-height: 1;
    box-shadow:
      0 1px 0 rgba(255,200,80,.25) inset,
      0 2px 8px rgba(0,0,0,.6);
  }

  .pagination-container nav .disabled a,
  .pagination-container nav .disabled span {
    color: #4a3020;
    border-color: #2e1a00;
    pointer-events: none;
    background: linear-gradient(180deg, #1e1000 0%, #150d00 100%);
    box-shadow: none;
    opacity: 0.5;
  }

  .calendar-filter {
    background: linear-gradient(180deg, #2e1a00 0%, #1e1000 100%);
    border: 1px solid #5a3510;
    border-radius: 8px;
    padding: 14px;
    width: 280px;
    box-shadow:
      0 8px 24px rgba(0,0,0,.7),
      inset 0 1px 0 rgba(255,200,80,.12);
  }

  .calendar-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
  }

  .cal-title {
    font-weight: 700;
    font-size: 15px;
    color: #e8a820;
    text-shadow: 0 1px 3px rgba(0,0,0,.5);
  }

  .cal-nav {
    background: linear-gradient(180deg, #3a2108 0%, #241400 100%);
    border: 1px solid #5a3510;
    border-radius: 4px;
    font-size: 18px;
    cursor: pointer;
    color: #e8a820;
    padding: 2px 10px;
    line-height: 1;
    box-shadow:
      0 1px 0 rgba(255,200,80,.12) inset,
      0 2px 4px rgba(0,0,0,.5);
    transition: filter .15s;
  }

  .cal-nav:hover {
    filter: brightness(1.3);
  }

  .calendar-weekdays {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    text-align: center;
    font-size: 12px;
    font-weight: 700;
    color: #7a5030;
    margin-bottom: 4px;
  }

  .calendar-weekdays span:first-child {
    color: #c05040;
  }

  .calendar-weekdays span:last-child {
    color: #8090c0;
  }

  .calendar-days {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 2px;
  }

  .cal-day {
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    border-radius: 50%;
    cursor: default;
    color: #4a3020;
  }

  .cal-day.has-image {
    color: #e8d5b0;
    cursor: pointer;
    font-weight: 700;
  }

  .cal-day.has-image:hover {
    background: rgba(200,130,10,.25);
    color: #e8a820;
  }

  .cal-day.selected {
    background: linear-gradient(135deg, #c8820a, #7a4800);
    color: #fff8e0 !important;
    box-shadow: 0 2px 6px rgba(0,0,0,.5);
  }

  .cal-day.today {
    border: 1px solid #c8820a;
  }

  .calendar-actions {
    display: flex;
    gap: 8px;
    margin-top: 10px;
    justify-content: flex-end;
  }

  .btn-cal-clear {
    background: linear-gradient(180deg, #3a2108 0%, #241400 100%);
    border: 1px solid #5a3510;
    border-radius: 4px;
    padding: 6px 14px;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    color: #a08060;
    box-shadow:
      0 1px 0 rgba(255,200,80,.08) inset,
      0 2px 4px rgba(0,0,0,.4);
    transition: filter .15s;
  }

  .btn-cal-clear:hover {
    filter: brightness(1.3);
    color: #e8d5b0;
  }

  .btn-cal-apply {
    background: linear-gradient(180deg, #c8820a 0%, #7a4800 100%);
    border: 1px solid #6a3e00;
    border-radius: 4px;
    padding: 6px 14px;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    color: #fff8e0;
    text-shadow: 0 1px 2px rgba(0,0,0,.5);
    box-shadow:
      0 1px 0 rgba(255,200,80,.25) inset,
      0 2px 6px rgba(0,0,0,.5);
    transition: filter .15s;
  }

  .btn-cal-apply:hover {
    filter: brightness(1.15);
  }
  .gallery-grid {
    position: relative; /* z-indexを有効にするため */
    z-index: 1; /* カレンダーエリアより低い値にする */
    /* 既存のスタイル */
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    gap: 10px;
    margin-top: 30px;
  }

  .gallery-item {
    position: relative;
    overflow: hidden;
    border-radius: 8px;
    background: #241400;
    aspect-ratio: 1;
    /* ▼ 木枠のフレームスタイルを追加 ▼ */
    box-sizing: border-box; /* 枠線をアイテムのサイズ内に収める */
    border-radius: 4px; /* 元の8px  から少し角を立たせて木枠らしさを出す */
    border: 3px solid #5c3a21; /* ベースとなる木の茶色 */
    
    /* 上と左を明るく、下と右を暗くして立体感（ハイライトとシャドウ）を表現 */
    border-top-color: #7a4f2f;
    border-left-color: #7a4f2f;
    border-bottom-color: #3d2616;
    border-right-color: #3d2616;
    
    /* 木枠自体の外側に影を落として壁に飾っているような質感を出す */
    box-shadow: 0 6px 12px rgba(0, 0, 0, 0.6);
  }

  .gallery-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .gallery-overlay {
    position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.8));
  padding: 10px;           /* パディングを少し狭めて文字の表示領域を広げます */
  color: white;
  opacity: 0;
  transition: opacity 0.3s ease;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  align-items: center;     /* 左寄せから中央寄せに変更します */
  gap: 10px;
  }

  .gallery-item:hover .gallery-overlay {
    opacity: 1;
  }

  .upload-date {
    margin: 0;
  font-size: 11px;       /* 14pxから11〜12pxに小さくして枠内に収めやすくします */
  white-space: nowrap;   /* 文字列が絶対に途中で改行されないようにします */
  width: 100%;           /* 横幅いっぱいに広げます */
  text-align: center;    /* 文字を中央寄せにします */
  }

  .placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    grid-column: 1 / -1;
  }

  .placeholder-content p {
    color: #fff;
  }

  .gallery-actions {
    position: relative; /* z-indexを有効にするため */
    z-index: 10; /* 画像エリアより高い値にする */
    /* 既存のスタイル */
    display: flex;
    gap: 15px;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
  }

