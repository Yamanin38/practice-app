    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.8));
    padding: 15px;
    color: white;
    opacity: 0;
    transition: opacity 0.3s ease;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: flex-start;
    gap: 10px;
  }

  .gallery-item:hover .gallery-overlay {
    opacity: 1;
  }

  .upload-date {
    margin: 0;
    font-size: 14px;
  }

  .placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    grid-column: 1 / -1;
  }

  .gallery-actions {
    display: flex;
    gap: 15px;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
  }

  .filter-section {
  position: relative;
}

.btn-cal-toggle {
  background: white;
  border: 1px solid #ddd;
  border-radius: 6px;
