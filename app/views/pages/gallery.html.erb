}

#imageViewModal {
  display: none;
  position: fixed;
  z-index: 2000;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.85);
  backdrop-filter: blur(4px);
  justify-content: center;
  align-items: center;
}

#imageViewModal.active {
  display: flex;
}

  @media (max-width: 768px) {
    .gallery-grid {
      grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    }

    .gallery-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .filter-section {
      width: 100%;
    }
