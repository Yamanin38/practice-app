}

.btn-cal-toggle.active {
  background: #f0f4ff;
  border-color: #3498db;
  color: #3498db;
}

.calendar-filter {
  position: absolute;
  top: calc(100% + 8px);
  right: 0;
  background: white;
  border: 1px solid #ddd;
  border-radius: 8px;
  padding: 12px;
  width: 280px;
  box-shadow: 0 4px 16px rgba(0,0,0,0.12);
  z-index: 100;
}

  .date-filter {
    width: 100%;
    padding: 10px;
    border: 1px solid #ddd;
    border-radius: 4px;
    font-size: 14px;
  }

  .login-prompt {
    font-size: 14px;
    color: #666;
  }

  .login-prompt a {
    color: #667eea;
    text-decoration: none;
  }

  .login-prompt a:hover {
