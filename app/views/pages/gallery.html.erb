<script>
  document.addEventListener('DOMContentLoaded', () => {

    const uploadForm = document.querySelector('.upload-form');
  const submitBtn = document.getElementById('submitBtn');
  
  if (uploadForm) {
    uploadForm.addEventListener('submit', async (e) => {
      e.preventDefault(); // 通常の画面遷移（フォーム送信）をストップ！

      // 1. ボタンを「処理中」にして操作をロック
      submitBtn.disabled = true;
      submitBtn.value = '投稿中...';

       // ×ボタンを無効化（spanなのでpointer-eventsで制御）
      if (closeModal) {
        closeModal.style.pointerEvents = 'none';
        closeModal.style.opacity = '0.4';
      }
      
      // （お好みで）モーダル全体を半透明にするなどして、他の操作を防ぐ
      uploadForm.style.opacity = '0.7';
      uploadForm.style.pointerEvents = 'none';

      // 2. フォームデータを取得して非同期送信
      const formData = new FormData(uploadForm);
      
      try {
        const createRes = await fetch(uploadForm.action, {
          method: 'POST',
          body: formData,
          headers: {
            'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content,
            'Accept': 'application/json'
          }
        });

        if (!createRes.ok) throw new Error('アップロードリクエストに失敗しました');

        const data = await createRes.json();
        const trackingIds = data.tracking_ids;

        // 3. ポーリング開始（定期的に確認）
        pollUploadStatus(trackingIds);

      } catch (error) {
        console.error('Error:', error);
        alert('エラーが発生しました。もう一度お試しください。');
        resetUploadForm(); // 失敗したらフォームを元に戻す
      }
    });
  }

    // ▼▼ ここから追加：フォームをリセットする関数 ▼▼
  function resetUploadForm() {
  // 👇【最優先】まずボタンとフォームのロックを完全に解除する（エラーで途切れないように一番上に配置）
  const submitBtn = document.getElementById('submitBtn');
  if (submitBtn) {
    submitBtn.value = '投稿する';
    submitBtn.disabled = false; // 明示的にボタンの無効化を解除！
  }

  // ×ボタンを再度有効化
  const closeModalBtn = document.getElementById('closeModal');
  if (closeModalBtn) {
    closeModalBtn.style.pointerEvents = 'auto';
    closeModalBtn.style.opacity = '1';
  }

  const uploadForm = document.querySelector('.upload-form');
  if (uploadForm) {
    uploadForm.style.opacity = '1';            // 半透明を解除
    uploadForm.style.pointerEvents = 'auto';   // クリック不可を解除
  }

  // ------------------------------------------
  // ここから下のデータクリア処理は、既存の挙動に合わせて実行
  selectedFiles = [];
  
  const fileInputField = document.getElementById('file_input_field');
  if (fileInputField) fileInputField.value = '';
  
  const uploadPreviewArea = document.getElementById('uploadPreviewArea');
  if (uploadPreviewArea) uploadPreviewArea.classList.remove('dragover', 'has-image');
  
  // 既存のプレビュー関数は、念のためエラーが起きても安全なように try-catch で囲む
  try {
    if (typeof renderPreview === 'function') {
      renderPreview(); // ※ここで画像が0枚になり、既存のロジックで適切にボタンが制御されます
    }
  } catch (error) {
    console.error('プレビューの初期化中にエラーが発生しました:', error);
  }
}
  // ▲▲ ここまで追加 ▲▲
    const uploadBtn = document.getElementById('uploadBtn');
    const uploadModal = document.getElementById('uploadModal');
    const closeModal = document.getElementById('closeModal');
    const dateFilter = document.querySelector('.date-filter');

    // 削除ボタン押下時に紐づきチェック
    const modalDeleteForm = document.getElementById('modalDeleteForm');
    if (modalDeleteForm) {
      modalDeleteForm.addEventListener('submit', (e) => {
        // 常にいったんブラウザのネイティブ送信を止め、確認モーダルを経由させる
        e.preventDefault();

        const modal = document.getElementById('imageViewModal');
        const imageId = modal.dataset.currentImageId;
        const imgElement = document.querySelector(`[data-image-id="${imageId}"]`);
        const usedInArticles = imgElement ? JSON.parse(imgElement.dataset.usedInArticles || '[]') : [];

        if (usedInArticles.length > 0) {
          // 拡大モーダルを閉じる
          modal.classList.remove('active');
          // 削除不可モーダルを表示
          const list = document.getElementById('cannotDeleteArticleList');
          const maxShow = 5;
          const shown = usedInArticles.slice(0, maxShow);
          const remaining = usedInArticles.length - maxShow;
          let html = shown.map(title => `<li>${title}</li>`).join('');
          if (remaining > 0) {
            html += `<li style="color: var(--clr-text-muted);">他 ${remaining} 件</li>`;
          }
          list.innerHTML = html;

          document.getElementById('cannotDeleteModal').style.display = 'block';
        } else {
          // 削除可能な場合は確認モーダルを表示する
          document.getElementById('deleteConfirmModal').style.display = 'block';
        }
      });
    }

    // 削除確認モーダルの「削除する」ボタン → 本当にフォームを送信する
    const confirmImageDeleteBtn = document.getElementById('confirmImageDeleteBtn');
    if (confirmImageDeleteBtn) {
      confirmImageDeleteBtn.addEventListener('click', () => {
        document.getElementById('deleteConfirmModal').style.display = 'none';
        modalDeleteForm.submit();
      });
    }

    // 削除確認モーダルの「キャンセル」「✕」 → 閉じるだけ
    const cancelImageDeleteBtn = document.getElementById('cancelImageDeleteBtn');
    const closeDeleteConfirmModal = document.getElementById('closeDeleteConfirmModal');
    [cancelImageDeleteBtn, closeDeleteConfirmModal].forEach(btn => {
      if (btn) {
        btn.addEventListener('click', () => {
          confirmImageDeleteBtn.disabled = true;          // ← 追加
          confirmImageDeleteBtn.textContent = '削除中...'; // ← 追加
          document.getElementById('deleteConfirmModal').style.display = 'none';
        });
      }
    });

    // ▼▼ ここから追加: カレンダーの年プルダウンを生成する処理 ▼▼
    // ── 修正後 ──
    const yearSelect = document.getElementById('calYearSelect');
    const todayYear = new Date().getFullYear();

    // 【修正】年の選択範囲を広げました（例：2010年 〜 現在の年 + 10年（2036年）まで）
    // 範囲をさらに広げたい場合は「2010」や「+ 10」の数値を調整してください
    for (let y = 2026; y <= todayYear + 10; y++) {
      const option = document.createElement('option');
      option.value = y;
      option.text = y + '年';
      yearSelect.appendChild(option);
    }

    // プルダウンで年を変更したときの処理
    yearSelect.addEventListener('change', function() {
      // 【修正】変数名を実際のコードに合わせて `calYear` に変更しました
      calYear = parseInt(this.value); 
      renderCalendar(); // カレンダーを再描画
    });
    // ▲▲ ここまで追加 ▲▲

    // 削除不可モーダルの閉じるボタン
const closeCannotDeleteModal = document.getElementById('closeCannotDeleteModal');
const closeCannotDeleteBtn = document.getElementById('closeCannotDeleteBtn');
if (closeCannotDeleteModal) {
  closeCannotDeleteModal.addEventListener('click', () => {
    document.getElementById('cannotDeleteModal').style.display = 'none';
  });
}
if (closeCannotDeleteBtn) {
  closeCannotDeleteBtn.addEventListener('click', () => {
    document.getElementById('cannotDeleteModal').style.display = 'none';
  });
}

    // 💡 修正後：写真投稿モーダルの開閉処理
    if (uploadBtn && uploadModal) {
      uploadBtn.addEventListener('click', () => {
        resetUploadForm();
        uploadModal.classList.add('active');
        document.body.style.overflow = 'hidden';
      });
    }

    if (closeModal && uploadModal) {
      closeModal.addEventListener('click', () => {
        uploadModal.classList.remove('active');
        document.body.style.overflow = '';
        resetUploadForm();
      });
    }

    if (dateFilter) {
      dateFilter.addEventListener('change', (e) => {
        const form = e.target.closest('form');
        if (form) form.submit();
      });
    }
  });

  // 画像モーダル
function openImageModal(imageId, isAdmin) {
  const modal = document.getElementById('imageViewModal');
  const modalImage = document.getElementById('modalImage');
  const deleteForm = document.getElementById('modalDeleteForm');
  const modalUploadDate = document.getElementById('modalUploadDate');
  const modalImageSize = document.getElementById('modalImageSize');

  const imgElement = document.querySelector(`[data-image-id="${imageId}"]`);
  const galleryItem = imgElement.closest('.gallery-item');
  const dateText = galleryItem.querySelector('.upload-date')?.textContent || '';
  const fileSize = imgElement.dataset.fileSize;

  modalImage.src = imgElement.dataset.fullUrl;
  if (modalUploadDate) modalUploadDate.textContent = dateText;
  if (modalImageSize && fileSize) {
    const kb = (fileSize / 1024).toFixed(1);
    const display = kb >= 1000
      ? `${(kb / 1024).toFixed(1)} MB`
      : `${kb} KB`;
    modalImageSize.textContent = display;
  }
  if (deleteForm) deleteForm.action = `/images/${imageId}`;

  // 現在表示中の画像IDを記憶しておく
  modal.dataset.currentImageId = imageId;
  modal.classList.add('active');
}

document.getElementById('closeImageModal').addEventListener('click', () => {
  document.getElementById('imageViewModal').classList.remove('active');
});

document.getElementById('closeImageModalBtn').addEventListener('click', () => {
  document.getElementById('imageViewModal').classList.remove('active');
});

window.addEventListener('click', (e) => {
  const modal = document.getElementById('imageViewModal');
  if (e.target === modal) {
    modal.classList.remove('active');
  }
});

const fileInputField = document.getElementById('file_input_field');
const uploadPreviewArea = document.getElementById('uploadPreviewArea');
const submitBtn = document.getElementById('submitBtn');
const uploadModal = document.getElementById('uploadModal');
const closeModalBtn = document.getElementById('closeModal'); // ← 元のHTMLのID（closeModal）に合わせる
const MAX_FILES = 4;

let selectedFiles = [];

function renderPreview() {
  const placeholder = document.getElementById('uploadPlaceholder');
  const grid = document.getElementById('uploadPreviewGrid');

  if (selectedFiles.length === 0) {
    placeholder.style.display = 'block';
    grid.style.display = 'none';
    grid.innerHTML = '';
    submitBtn.disabled = true;
    uploadPreviewArea.classList.remove('has-image');
    return;
  }

  placeholder.style.display = 'none';
  grid.style.display = 'grid';
  grid.innerHTML = '';
  uploadPreviewArea.classList.add('has-image');

  selectedFiles.forEach((file, index) => {
    const reader = new FileReader();
    reader.onload = (e) => {
      const thumb = document.createElement('div');
      thumb.className = 'upload-preview-thumb';
      thumb.innerHTML = `<img src="${e.target.result}" alt="プレビュー${index + 1}">
        <button type="button" class="remove-thumb" data-index="${index}">&times;</button>`;
      grid.appendChild(thumb);

      thumb.querySelector('.remove-thumb').addEventListener('click', () => {
        selectedFiles.splice(index, 1);
        syncFileInput();
        renderPreview();
      });
    };
    reader.readAsDataURL(file);
  });

  submitBtn.disabled = false;
}

function syncFileInput() {
  const dt = new DataTransfer();
  selectedFiles.forEach(file => dt.items.add(file));
  fileInputField.files = dt.files;
}

function addFiles(fileList) {
  const incoming = Array.from(fileList).filter(f => f.type.startsWith('image/'));

  if (incoming.length === 0) {
    alert('画像ファイルを選択してください。');
    return;
  }

  if (selectedFiles.length + incoming.length > MAX_FILES) {
    alert(`画像は最大${MAX_FILES}枚までしか選択できません。`);
    return;
  }

  selectedFiles = selectedFiles.concat(incoming);
  syncFileInput();
  renderPreview();
}

function resetUploadForm() {
  selectedFiles = [];
  fileInputField.value = '';
  uploadPreviewArea.classList.remove('dragover', 'has-image');
  renderPreview();
}

if (fileInputField && uploadPreviewArea) {
  fileInputField.addEventListener('change', (e) => {
    addFiles(e.target.files);
  });

  uploadPreviewArea.addEventListener('dragover', (e) => {
    e.preventDefault();
    uploadPreviewArea.classList.add('dragover');
  });

  uploadPreviewArea.addEventListener('dragleave', (e) => {
    e.preventDefault();
    uploadPreviewArea.classList.remove('dragover');
  });

  uploadPreviewArea.addEventListener('drop', (e) => {
    e.preventDefault();
    uploadPreviewArea.classList.remove('dragover');
    addFiles(e.dataTransfer.files);
  });

  // モーダルが閉じられたときにリセット
  if (uploadModal) {
    uploadModal.addEventListener('hidden.bs.modal', () => {
      resetUploadForm();
    });
  }

  if (closeModalBtn) {
    closeModalBtn.addEventListener('click', () => {
      resetUploadForm();
    });
  }
}

// -------------------------------------------------------------
  // ★新しく追加：モーダルが閉じられたときにリセット関数を呼び出す
  // -------------------------------------------------------------
  
  // パターンA：Bootstrapを使用している場合（推奨：背景クリックで閉じても作動します）
  if (uploadModal) {
    // Bootstrapのモーダルが完全に隠れたときに発生するイベント
    uploadModal.addEventListener('hidden.bs.modal', () => {
      resetUploadForm();
    });
  }

  // パターンB：自作の閉じるボタン（×ボタンなど）で制御している場合
  if (closeModalBtn) {
    closeModalBtn.addEventListener('click', () => {
      resetUploadForm();
    });
  }

// カレンダー
const uploadDates = <%= @upload_dates.map(&:to_s).to_json.html_safe %>;
const uploadDateSet = new Set(uploadDates);

let calYear, calMonth;

const today = new Date();
const selectedDateInput = document.getElementById('calSelectedDate');

// 初期月：選択中の日付があればその月、なければ今月
if (selectedDateInput.value) {
  const d = new Date(selectedDateInput.value);
  calYear = d.getFullYear();
  calMonth = d.getMonth();
} else {
  calYear = today.getFullYear();
  calMonth = today.getMonth();
}

function renderCalendar() {
  // ── 修正後 ──
  const daysEl = document.getElementById('calendarDays');

  // 年プルダウンの選択状態を現在の表示年に合わせる
  document.getElementById('calYearSelect').value = calYear;
  // 月のテキストだけを更新する
  document.getElementById('calMonthText').textContent = `${calMonth + 1}月`;
  daysEl.innerHTML = '';

  const firstDay = new Date(calYear, calMonth, 1).getDay();
  const daysInMonth = new Date(calYear, calMonth + 1, 0).getDate();
  const selectedVal = selectedDateInput.value;

  // ボタンのテキストを更新
  document.getElementById('calToggleText').textContent = selectedVal
  ? selectedVal
  : '日付で絞り込む';

  // 空白埋め
  for (let i = 0; i < firstDay; i++) {
    const blank = document.createElement('div');
    blank.className = 'cal-day';
    daysEl.appendChild(blank);
  }

  for (let d = 1; d <= daysInMonth; d++) {
    const dateStr = `${calYear}-${String(calMonth + 1).padStart(2, '0')}-${String(d).padStart(2, '0')}`;
    const div = document.createElement('div');
    div.className = 'cal-day';
    div.textContent = d;

    if (uploadDateSet.has(dateStr)) {
      div.classList.add('has-image');
      div.addEventListener('click', (e) => {
      e.stopPropagation();
      selectedDateInput.value = dateStr;
      renderCalendar();
      fetchImages(dateStr);
      calendarFilter.style.display = 'none';
      calToggleBtn.classList.remove('active');
    });
    }

    if (dateStr === selectedVal) div.classList.add('selected');

    const todayStr = `${today.getFullYear()}-${String(today.getMonth() + 1).padStart(2, '0')}-${String(today.getDate()).padStart(2, '0')}`;
    if (dateStr === todayStr) div.classList.add('today');

    daysEl.appendChild(div);
  }
  // ───【ここを追加】───
      // 常に6行（7列 × 6行 = 42マス）分の高さを維持するため、月末の足りない分を空白で埋める
      const currentCells = firstDay + daysInMonth;
      for (let i = currentCells; i < 42; i++) {
        const blank = document.createElement('div');
        blank.className = 'cal-day';
        daysEl.appendChild(blank);
      }
      // ─────────────────────
}

// 前月・次月
document.getElementById('calPrev').addEventListener('click', () => {
  calMonth--;
  if (calMonth < 0) { calMonth = 11; calYear--; }
  renderCalendar();
});

document.getElementById('calNext').addEventListener('click', () => {
  calMonth++;
  if (calMonth > 11) { calMonth = 0; calYear++; }
  renderCalendar();
});

// クリア
document.getElementById('calClear').addEventListener('click', () => {
  selectedDateInput.value = '';
  renderCalendar();
  fetchImages('');
  calendarFilter.style.display = 'none';
  calToggleBtn.classList.remove('active');
});

// トグルボタン
calToggleBtn.addEventListener('click', (e) => {
  e.stopPropagation();
  const isOpen = calendarFilter.style.display !== 'none';
  calendarFilter.style.display = isOpen ? 'none' : 'block';
  calToggleBtn.classList.toggle('active', !isOpen);
});

// カレンダー外クリックで閉じる
document.addEventListener('click', (e) => {
  if (!calendarFilter.contains(e.target) && e.target !== calToggleBtn) {
    calendarFilter.style.display = 'none';
    calToggleBtn.classList.remove('active');
  }
});

// 初期描画
renderCalendar();

// Ajax でギャラリーを更新
function fetchImages(date) {
  const url = date ? `/gallery?date=${date}` : '/gallery';
  const fetchUrl = new URL(url, window.location.origin);
  fetchUrl.searchParams.append('_t', Date.now()); // キャッシュ対策

  fetch(fetchUrl.toString(), { 
    headers: { 'X-Requested-With': 'XMLHttpRequest' },
    cache: 'no-store'
  })
    .then(res => res.text())
    .then(html => {
      const parser = new DOMParser();
      const doc = parser.parseFromString(html, 'text/html');

      // グリッドを差し替え
      const newGrid = doc.getElementById('galleryGrid');
      const oldGrid = document.getElementById('galleryGrid');
      if (newGrid && oldGrid) {
        oldGrid.replaceWith(newGrid);
      }

      // ページネーションを差し替え
      const newPager = doc.querySelector('.pagination-container');
      const oldPager = document.querySelector('.pagination-container');
      if (oldPager) {
        if (newPager) {
          oldPager.replaceWith(newPager);
        } else {
          oldPager.remove();
        }
      } else if (newPager) {
        const currentGrid = document.getElementById('galleryGrid');
        if (currentGrid) {
          currentGrid.insertAdjacentElement('afterend', newPager);
        }
      }

      // URLを書き換え（ブラウザ履歴に残す）
      history.pushState({}, '', url);

      // トグルボタンのテキスト更新
      const calToggleText = document.getElementById('calToggleText');
      if (calToggleText) {
        calToggleText.textContent = date || '日付で絞り込む';
      }
    })
    .catch(err => console.error('fetchImages error:', err));
}

// ポーリングを実行する関数
async function pollUploadStatus(trackingIds) {
  const maxAttempts = 30;
  let attempts = 0;

  const intervalId = setInterval(async () => {
    attempts++;

    try {
      const statusRes = await fetch('/images/status', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content,
          'Accept': 'application/json'
        },
        body: JSON.stringify({ tracking_ids: trackingIds })
      });

      const statusData = await statusRes.json();

      if (statusData.status === 'completed') {
        // 全て完了したらループを止める
        clearInterval(intervalId);
        
        // ギャラリーを裏側で更新
        fetchImages(document.getElementById('calSelectedDate').value);
        
        // モーダルを閉じる
        document.getElementById('uploadModal').classList.remove('active');
        document.body.style.overflow = '';
        
        // フォームの状態を完全リセット（さっき修正した関数が呼ばれます）
        resetUploadForm(); 
        
        // alert("画像のアップロードが完了しました！"); ← ★削除（何も言わずに閉じる）
      }

      if (attempts >= maxAttempts) {
        clearInterval(intervalId);
        // タイムアウト時もユーザー体験を損ねないよう、コンソールにだけ残してそっと閉じる
        console.warn('ポーリングがタイムアウトしました。バックグラウンドで処理を継続します。');
        document.getElementById('uploadModal').classList.remove('active');
        document.body.style.overflow = '';
        resetUploadForm();
      }

    } catch (error) {
      console.error('Polling error:', error);
      clearInterval(intervalId);
      document.getElementById('uploadModal').classList.remove('active');
      document.body.style.overflow = '';
      resetUploadForm();
    }

  }, 2000); // 2秒ごとに確認
}
