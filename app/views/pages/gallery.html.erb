}

.upload-modal-header .close {
  position: absolute;
  top: 14px;
  right: 18px;
  font-size: 26px;
  color: #aaa;
}

.upload-modal-header .close:hover {
  color: #333;
}

.upload-form {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 24px 24px 24px;
