}

.upload-preview-area {
  width: 100%;
  aspect-ratio: 1;
  max-height: 300px;
  background: #f5f5f5;
  border-radius: 8px;
  border: 2px dashed #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
