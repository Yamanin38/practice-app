.upload-form {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 24px 24px 24px;
  gap: 16px;
}

.upload-preview-area {
  width: 100%;
  height: auto;
  aspect-ratio: auto;
  min-height: 120px;
  max-height: none;
}

.upload-placeholder {
  max-height: 300px;
}

.upload-icon {
  font-size: 48px;
  margin-bottom: 8px;
}

.upload-hint {
  font-size: 14px;
}

.upload-preview-image {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.upload-file-group {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}

.file-label {
  display: inline-block;
  padding: 10px 24px;
  background: #f0f4ff;
  color: #3498db;
  border: 2px solid #3498db;
  border-radius: 20px;
  cursor: pointer;
  font-weight: 600;
  font-size: 14px;
  transition: all 0.2s ease;
}

.file-label:hover {
  background: #3498db;
  color: white;
}

#file_input_field {
  position: absolute;
  width: 1px;
  height: 1px;
  opacity: 0;
  overflow: hidden;
}

.upload-submit-btn {
  width: 100%;
  padding: 12px;
  border-radius: 8px;
  font-size: 16px;
}

#imageViewModal {
  display: none;
  position: fixed;
  z-index: 2000;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.85);
  backdrop-filter: blur(4px);
  justify-content: center;
  align-items: center;
}

#imageViewModal.active {
  display: flex;
}

.container,
  .page-content {
    overflow: visible !important; /* Bootstrapなどの外部CSSの上書きを想定 */
  }

  @media (max-width: 768px) {
    .gallery-grid {
    grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
  }

    .gallery-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .filter-section {
      width: 100%;
    }
  }

  .upload-preview-area {
  width: 100%;
  min-height: 0;
  aspect-ratio: auto;
}

.upload-preview-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 8px;
  width: 100%;
  padding: 4px;
}

.upload-preview-thumb {
  position: relative;
  width: 100%;
  aspect-ratio: 1;
  border-radius: 6px;
  overflow: hidden;
  border: 1px solid var(--clr-border);
}

.upload-preview-thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.upload-preview-thumb .remove-thumb {
  position: absolute;
  top: 4px;
  right: 4px;
  width: 22px;
  height: 22px;
  background: rgba(0,0,0,0.6);
  color: #fff;
  border: none;
  border-radius: 50%;
  cursor: pointer;
  font-size: 14px;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

  /* カレンダーの年選択プルダウンのスタイル */
.cal-year-select {
  background-color: transparent;
  color: inherit;
  border: 1px solid var(--clr-border, #7a4818);
  border-radius: 4px;
  padding: 2px 24px 2px 8px; /* 右側は矢印用に少し広めに */
  font-family: inherit;
  font-size: 16px;
  font-weight: bold;
  cursor: pointer;
  appearance: none; /* デフォルトの矢印を消す */
  background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23e8a820' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
  background-repeat: no-repeat;
  background-position: right 4px center;
  background-size: 14px;
}

.cal-year-select:focus {
  outline: none;
  border-color: var(--clr-primary, #e8a820);
}

.cal-year-select option {
  background-color: var(--clr-surface, #3a2108);
  color: var(--clr-text, #e8d5b0);
}

/* 月テキストの余白調整 */
#calMonthText {
  margin-left: 4px;
}

/* 💡 1. 画面のど真ん中に表示するための設定 */
#uploadModal {
  display: none;
  align-items: center;
  justify-content: center;
  padding: 20px;
}
#uploadModal.active {
  display: flex; /* JSで active が付くと真ん中に表示される */
}
#uploadModal .modal-content {
  margin: 0; /* pages.cssの余白設定を上書きして完全な中央に */
  position: relative;
  display: flex;
  flex-direction: column;
  max-height: 90vh;
  max-width: 450px; /* 写真投稿用は少しスリムに */
}

/* 💡 2. 活動記録モーダルと全く同じ余白・配置にする設定 */
#uploadModal .modal-content > h2 {
  padding: 28px 36px 0;
  margin: 0 0 16px 0;
  color: var(--clr-gold-light);
}
#uploadModal .modal-content > form {
  padding: 20px 36px 32px;
  overflow-y: auto;
  flex: 1;
}
#uploadModal .modal-content > .close {
  position: absolute;
  top: 14px;
  right: 18px;
  z-index: 10;
  line-height: 1;
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

/* 💡 3. プレビューエリアとボタンをダークテーマ（pages.cssの変数）に合わせる */
