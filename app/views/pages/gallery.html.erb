<div class="container">
  <header class="page-header">
    <h1>ギャラリー</h1>
    <p>チームの思い出の写真</p>
  </header>

  <div class="page-content">
    <div class="gallery-actions">
      <% if current_user %>
        <button class="btn btn-primary" id="uploadBtn">写真を投稿</button>
      <% else %>
        <p class="login-prompt"><a href="<%= login_path %>">ログイン</a>して写真を投稿</p>
      <% end %>

      <div class="filter-section">
        <% if @upload_dates.any? %>
          <%= form_with url: gallery_path, method: :get, local: true, class: "date-filter-form" do |f| %>
            <%= f.select :date, [["すべての日付", ""]] + @upload_dates.map { |d| [d.strftime("%Y年%m月%d日"), d] },
                { selected: params[:date] }, { class: "date-filter" } %>
          <% end %>
        <% end %>
      </div>
    </div>

    <% if @images.any? %>
      <div class="gallery-grid" id="galleryGrid">
        <% @images.each do |image| %>
  <div class="gallery-item" onclick="openImageModal(<%= image.id %>, '<%= current_user&.admin? %>')">
    <% if image.file.present? %>
      <%= image_tag image.file.variant(resize_to_fill: [400, 400]),
          alt: "Gallery image",
          class: "gallery-image",
          data: { 
            image_id: image.id,
            full_url: url_for(image.file)
          } %>
    <% end %>
    <div class="gallery-overlay">
      <p class="upload-date"><%= image.created_at.strftime("%Y年%m月%d日") %></p>
    </div>
  </div>
<% end %>
      </div>
    <% else %>
      <div class="gallery-grid">
        <div class="gallery-item placeholder">
          <div class="placeholder-content">
            <p>写真がまだ投稿されていません</p>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <!-- 写真投稿フォーム（モーダル） -->
  <% if current_user %>
    <div class="modal" id="uploadModal">
      <div class="modal-content">
        <span class="close" id="closeModal">&times;</span>
        <h2>写真を投稿</h2>
        <%= form_with url: images_path, method: :post, local: true, multipart: true, class: "upload-form" do |f| %>
          <div class="form-group">
            <%= f.label :file, "画像ファイル" %>
            <%= f.file_field :file, accept: "image/*", required: true %>
          </div>
          <%= f.submit "投稿", class: "btn btn-primary" %>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- 画像拡大モーダル -->
<div class="modal" id="imageViewModal">
  <div class="modal-content image-view-modal-content">
    <div class="image-modal-header">
      <span class="close" id="closeImageModal">&times;</span>
    </div>
    <div class="image-modal-body">
      <img id="modalImage" src="" alt="拡大画像" class="modal-full-image">
    </div>
    <div class="image-modal-footer">
      <span class="upload-info" id="modalUploadDate"></span>
      <% if current_user&.admin? %>
        <form id="modalDeleteForm" method="POST" style="margin:0;">
          <input type="hidden" name="_method" value="delete">
          <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
          <button type="submit" class="btn btn-danger">🗑 削除</button>
        </form>
      <% end %>
      <button class="btn btn-secondary" id="closeImageModalBtn">閉じる</button>
    </div>
  </div>
</div>
</div>

<style>
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 20px;
    margin-top: 30px;
  }

  .gallery-item {
    position: relative;
    overflow: hidden;
    border-radius: 8px;
    background: #f0f0f0;
    aspect-ratio: 1;
  }

  .gallery-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .gallery-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.8));
    padding: 15px;
    color: white;
    opacity: 0;
    transition: opacity 0.3s ease;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: flex-start;
    gap: 10px;
  }

  .gallery-item:hover .gallery-overlay {
    opacity: 1;
  }

  .upload-date {
    margin: 0;
    font-size: 14px;
  }

  .placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    grid-column: 1 / -1;
  }

  .gallery-actions {
    display: flex;
    gap: 15px;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
  }

  .filter-section {
    flex: 1;
    min-width: 200px;
  }

  .date-filter {
    width: 100%;
    padding: 10px;
    border: 1px solid #ddd;
    border-radius: 4px;
    font-size: 14px;
  }

  .login-prompt {
    font-size: 14px;
    color: #666;
  }

  .login-prompt a {
    color: #667eea;
    text-decoration: none;
  }

  .login-prompt a:hover {
    text-decoration: underline;
  }

  .btn-danger {
    background-color: #dc3545;
    color: white;
    border: none;
    padding: 8px 16px;
    border-radius: 4px;
    cursor: pointer;
    font-size: 12px;
  }

  .btn-danger:hover {
    background-color: #c82333;
  }

  .image-view-modal-content {
  background: rgba(15, 15, 15, 0.95);
  border-radius: 12px;
  padding: 0;
  width: auto;
  max-width: 90vw;
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.8);
  overflow: hidden;
  position: relative;
  margin: auto;
}

.image-modal-header {
  position: absolute;
  top: 12px;
  right: 12px;
  z-index: 10;
}

.image-modal-header .close {
  color: white;
  font-size: 28px;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  transition: background 0.2s ease;
}

.image-modal-header .close:hover {
  background: rgba(255, 255, 255, 0.2);
}

.image-modal-body {
  margin: 0;
  display: flex;
  justify-content: center;
  align-items: center;
}

.modal-full-image {
  max-width: 85vw;
  max-height: 75vh;
  width: auto;
  height: auto;
  display: block;
  object-fit: contain;
}

.image-modal-footer {
  display: flex;
  gap: 12px;
  justify-content: center;
  align-items: center;
  width: 100%;
  padding: 14px 20px;
  background: rgba(0, 0, 0, 0.4);
}

.btn-danger {
  background: linear-gradient(135deg, #e74c3c, #c0392b);
  color: white;
  border: none;
  padding: 8px 20px;
  border-radius: 20px;
  cursor: pointer;
  font-size: 13px;
  font-weight: 600;
  transition: opacity 0.2s ease;
}

.btn-danger:hover {
  opacity: 0.85;
}

.image-modal-footer .btn-secondary {
  background: rgba(255, 255, 255, 0.15);
  color: white;
  border: 1px solid rgba(255, 255, 255, 0.3);
  padding: 8px 20px;
  border-radius: 20px;
  font-size: 13px;
  font-weight: 600;
  transition: background 0.2s ease;
}

.image-modal-footer .btn-secondary:hover {
  background: rgba(255, 255, 255, 0.25);
}

.upload-info {
  color: rgba(255, 255, 255, 0.6);
  font-size: 12px;
}

#imageViewModal {
  display: none;
  position: fixed;
  z-index: 2000;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.85);
  backdrop-filter: blur(4px);
  justify-content: center;
  align-items: center;
}

#imageViewModal.active {
  display: flex;
}

  @media (max-width: 768px) {
    .gallery-grid {
      grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    }

    .gallery-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .filter-section {
      width: 100%;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const uploadBtn = document.getElementById('uploadBtn');
    const uploadModal = document.getElementById('uploadModal');
    const closeModal = document.getElementById('closeModal');
    const dateFilter = document.querySelector('.date-filter');

    if (uploadBtn && uploadModal) {
      uploadBtn.addEventListener('click', () => {
        uploadModal.style.display = 'block';
      });
    }

    if (closeModal && uploadModal) {
      closeModal.addEventListener('click', () => {
        uploadModal.style.display = 'none';
      });
    }

    if (uploadModal) {
      window.addEventListener('click', (e) => {
        if (e.target === uploadModal) {
          uploadModal.style.display = 'none';
        }
      });
    }

    if (dateFilter) {
      dateFilter.addEventListener('change', (e) => {
        const form = e.target.closest('form');
        if (form) form.submit();
      });
    }
  });

  // 画像モーダル
function openImageModal(imageId, isAdmin) {
  const modal = document.getElementById('imageViewModal');
  const modalImage = document.getElementById('modalImage');
  const deleteForm = document.getElementById('modalDeleteForm');
  const modalUploadDate = document.getElementById('modalUploadDate');

  const imgElement = document.querySelector(`[data-image-id="${imageId}"]`);
  const galleryItem = imgElement.closest('.gallery-item');
  const dateText = galleryItem.querySelector('.upload-date')?.textContent || '';

  // サムネイルではなくオリジナルのURLを使用
  modalImage.src = imgElement.dataset.fullUrl;
  if (modalUploadDate) modalUploadDate.textContent = dateText;
  if (deleteForm) deleteForm.action = `/images/${imageId}`;

  modal.classList.add('active');
}

document.getElementById('closeImageModal').addEventListener('click', () => {
  document.getElementById('imageViewModal').classList.remove('active');
});

document.getElementById('closeImageModalBtn').addEventListener('click', () => {
  document.getElementById('imageViewModal').classList.remove('active');
});

window.addEventListener('click', (e) => {
  const modal = document.getElementById('imageViewModal');
  if (e.target === modal) {
    modal.classList.remove('active');
  }
});
</script>
