<%
  require 'kramdown'
  rendered_content = @team_profile&.content.present? \
    ? Kramdown::Document.new(@team_profile.content).to_html \
    : nil
%>

<!-- EasyMDE CSS -->
<link rel="stylesheet" href="https://unpkg.com/easymde/dist/easymde.min.css">

<div class="container">
  <header class="page-header">
    <h1>チーム概要</h1>
    <p>私たちのチームについて</p>
  </header>

  <% if notice %>
    <div class="flash flash-notice"><%= notice %></div>
  <% end %>
  <% if alert %>
    <div class="flash flash-alert"><%= alert %></div>
  <% end %>

  <div class="page-content">
    <% if current_user&.admin? %>
      <div class="edit-btn-container">
        <button class="btn btn-primary" id="editAboutBtn">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle;margin-right:6px"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          チーム概要を編集
        </button>
      </div>
    <% end %>

    <div id="aboutView" class="about-view">
      <% if rendered_content %>
        <div class="about-content markdown-body">
          <%= rendered_content.html_safe %>
        </div>
      <% else %>
        <div class="about-empty">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          <p>チームの概要情報がまだ設定されていません。</p>
          <% if current_user&.admin? %>
            <p class="empty-hint">「チーム概要を編集」ボタンから内容を追加してください。</p>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- チーム概要編集モーダル -->
<% if current_user&.admin? %>
  <div class="modal" id="editAboutModal">
    <div class="modal-content modal-lg">
      <div class="modal-header">
        <h2>チーム概要を編集</h2>
        <button class="modal-close" id="closeEditAbout" aria-label="閉じる">&times;</button>
      </div>
      <div class="modal-body">
        <p class="editor-hint">マークダウン形式で入力できます</p>
        <%= form_with url: about_path, method: :patch, id: "editAboutForm", local: true do |f| %>
          <div class="form-group">
            <%= f.text_area :content,
                id: "aboutContent",
                rows: 15,
                placeholder: "チームの概要をマークダウンで入力してください...\n\n例:\n## チーム名\n\nここにチームの説明を書きます。\n\n- 特徴1\n- 特徴2",
                value: @team_profile&.content %>
          </div>
          <div class="form-actions">
            <%= f.submit "保存する", class: "btn btn-primary" %>
            <button type="button" class="btn btn-secondary" id="cancelAboutEdit">キャンセル</button>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<style>
  /* ===== フラッシュメッセージ ===== */
  .flash {
    padding: 12px 18px;
    border-radius: 8px;
    margin: 16px 0;
    font-size: 0.95rem;
    font-weight: 500;
  }
  .flash-notice {
    background: #d1fae5;
    color: #065f46;
    border: 1px solid #6ee7b7;
  }
  .flash-alert {
    background: #fee2e2;
    color: #991b1b;
    border: 1px solid #fca5a5;
  }

  /* ===== 編集ボタン ===== */
  .edit-btn-container {
    display: flex;
    justify-content: flex-end;
    margin: 16px 0 24px;
  }

  /* ===== 本文表示エリア ===== */
  .about-view {
    margin-top: 8px;
  }

  .about-content {
    padding: 36px 40px;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    line-height: 1.85;
    box-shadow: 0 1px 6px rgba(0,0,0,0.06);
  }

  /* ===== マークダウンスタイル ===== */
  .markdown-body h1, .markdown-body h2, .markdown-body h3,
  .markdown-body h4, .markdown-body h5, .markdown-body h6 {
    margin-top: 1.5em;
    margin-bottom: 0.6em;
    font-weight: 700;
    line-height: 1.3;
  }
  .markdown-body h1 { font-size: 2rem; border-bottom: 2px solid #e5e7eb; padding-bottom: 0.3em; }
  .markdown-body h2 { font-size: 1.5rem; border-bottom: 1px solid #e5e7eb; padding-bottom: 0.2em; }
  .markdown-body h3 { font-size: 1.25rem; }
  .markdown-body p  { margin: 0.8em 0; }
  .markdown-body ul, .markdown-body ol { padding-left: 1.8em; margin: 0.8em 0; }
  .markdown-body li { margin: 0.3em 0; }
  .markdown-body strong { font-weight: 700; }
  .markdown-body em { font-style: italic; }
  .markdown-body code {
    background: #f3f4f6;
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.9em;
    font-family: 'Courier New', monospace;
  }
  .markdown-body pre {
    background: #1e2937;
    color: #e5e7eb;
    padding: 16px 20px;
    border-radius: 8px;
    overflow-x: auto;
    margin: 1em 0;
  }
  .markdown-body pre code {
    background: none;
    color: inherit;
    padding: 0;
  }
  .markdown-body blockquote {
    border-left: 4px solid #6366f1;
    margin: 1em 0;
    padding: 8px 16px;
    color: #6b7280;
    background: #f9fafb;
    border-radius: 0 6px 6px 0;
  }
  .markdown-body a { color: #6366f1; text-decoration: underline; }
  .markdown-body hr { border: none; border-top: 1px solid #e5e7eb; margin: 2em 0; }
  .markdown-body table { border-collapse: collapse; width: 100%; margin: 1em 0; }
  .markdown-body th, .markdown-body td {
    border: 1px solid #e5e7eb;
    padding: 8px 12px;
    text-align: left;
  }
  .markdown-body th { background: #f9fafb; font-weight: 600; }

  /* ===== 空状態 ===== */
  .about-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 80px 20px;
    color: #9ca3af;
    text-align: center;
    background: #f9fafb;
    border: 2px dashed #e5e7eb;
    border-radius: 12px;
    gap: 12px;
  }
  .about-empty svg { opacity: 0.5; }
  .about-empty p { margin: 0; font-size: 1rem; }
  .empty-hint { font-size: 0.875rem !important; color: #6366f1 !important; }

  /* ===== モーダル ===== */
  .modal {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(15, 23, 42, 0.6);
    backdrop-filter: blur(4px);
    z-index: 1000;
    animation: fadeIn 0.2s ease;
  }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

  .modal-content {
    background: #fff;
    border-radius: 16px;
    width: 90%;
    max-width: 860px;
    margin: 40px auto;
    box-shadow: 0 20px 60px rgba(0,0,0,0.2);
    overflow: hidden;
    animation: slideUp 0.25s ease;
    max-height: calc(100vh - 80px);
    display: flex;
    flex-direction: column;
  }
  @keyframes slideUp {
    from { transform: translateY(20px); opacity: 0; }
    to   { transform: translateY(0);    opacity: 1; }
  }

  .modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 28px;
    border-bottom: 1px solid #e5e7eb;
    background: #f9fafb;
  }
  .modal-header h2 {
    margin: 0;
    font-size: 1.2rem;
    font-weight: 700;
    color: #111827;
  }
  .modal-close {
    background: none;
    border: none;
    font-size: 1.6rem;
    color: #6b7280;
    cursor: pointer;
    line-height: 1;
    padding: 2px 6px;
    border-radius: 4px;
    transition: background 0.15s, color 0.15s;
  }
  .modal-close:hover { background: #e5e7eb; color: #111827; }

  .modal-body {
    padding: 24px 28px;
    overflow-y: auto;
    flex: 1;
  }

  .editor-hint {
    font-size: 0.85rem;
    color: #6b7280;
    margin: 0 0 14px;
  }

  .form-group { margin-bottom: 16px; }

  .form-actions {
    display: flex;
    gap: 12px;
    justify-content: flex-end;
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid #e5e7eb;
  }

  /* EasyMDE 調整 */
  .EasyMDEContainer { border-radius: 8px; overflow: hidden; }
  .EasyMDEContainer .CodeMirror {
    border-radius: 0;
    min-height: 320px;
    font-size: 0.95rem;
  }
</style>

<!-- EasyMDE JS -->
<script src="https://unpkg.com/easymde/dist/easymde.min.js"></script>

<script>
  <% if current_user&.admin? %>
    const editAboutBtn    = document.getElementById('editAboutBtn');
    const editAboutModal  = document.getElementById('editAboutModal');
    const closeEditAbout  = document.getElementById('closeEditAbout');
    const cancelAboutEdit = document.getElementById('cancelAboutEdit');
    const textarea        = document.getElementById('aboutContent');

    let easyMDE = null;

    function openModal() {
      editAboutModal.style.display = 'block';
      document.body.style.overflow = 'hidden';

      // EasyMDE を初回だけ初期化
      if (!easyMDE) {
        easyMDE = new EasyMDE({
          element: textarea,
          spellChecker: false,
          autofocus: true,
          placeholder: "チームの概要をマークダウンで入力してください...",
          toolbar: [
            "bold", "italic", "heading", "|",
            "unordered-list", "ordered-list", "|",
            "link", "quote", "code", "horizontal-rule", "|",
            "preview", "side-by-side", "fullscreen", "|",
            "guide"
          ],
          status: ["lines", "words"],
        });
      }
    }

    function closeModal() {
      editAboutModal.style.display = 'none';
      document.body.style.overflow = '';
    }

    editAboutBtn.addEventListener('click', openModal);
    closeEditAbout.addEventListener('click', closeModal);
    cancelAboutEdit.addEventListener('click', closeModal);

    window.addEventListener('click', (e) => {
      if (e.target === editAboutModal) closeModal();
    });

    window.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && editAboutModal.style.display === 'block') closeModal();
    });

    // フォーム送信前に EasyMDE の値を textarea に同期
    document.getElementById('editAboutForm').addEventListener('submit', () => {
      if (easyMDE) easyMDE.codemirror.save();
    });
  <% end %>
</script>
