<div class="container">
  <header class="page-header">
    <h1>お問い合わせ</h1>
    <p>ご質問やご要望をお知らせください</p>
  </header>

  <div class="page-content">
    <div class="edit-btn-container">
      <button class="btn btn-secondary" id="editContactBtn">編集</button>
    </div>

    <div id="contactView" class="contact-view">
      <div class="contact-info">
        <p>お問い合わせ先の情報がまだ設定されていません。</p>
      </div>
    </div>

    <div class="contact-form-section">
      <h2>お問い合わせフォーム</h2>
      <form id="contactForm" class="contact-form">
        <div class="form-group">
          <label for="contactName">お名前</label>
          <input type="text" id="contactName" required placeholder="お名前を入力してください">
        </div>
        <div class="form-group">
          <label for="contactEmail">メールアドレス</label>
          <input type="email" id="contactEmail" required placeholder="メールアドレスを入力してください">
        </div>
        <div class="form-group">
          <label for="contactSubject">件名</label>
          <input type="text" id="contactSubject" required placeholder="件名を入力してください">
        </div>
        <div class="form-group">
          <label for="contactMessage">メッセージ</label>
          <textarea id="contactMessage" rows="6" required placeholder="メッセージを入力してください"></textarea>
        </div>
        <button type="submit" class="btn btn-primary">送信</button>
      </form>
    </div>
  </div>

  <!-- お問い合わせ先編集フォーム（モーダル） -->
  <div class="modal" id="editContactModal">
    <div class="modal-content modal-lg">
      <span class="close" id="closeEditContact">&times;</span>
      <h2>お問い合わせ先を編集</h2>
      <form id="editContactForm">
        <div class="form-group">
          <label for="contactContent">お問い合わせ先情報</label>
          <textarea id="contactContent" rows="10" placeholder="メールアドレス、SNS、その他連絡先など"></textarea>
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn-primary">保存</button>
          <button type="button" class="btn btn-secondary" id="cancelContactEdit">キャンセル</button>
        </div>
      </form>
    </div>
  </div>
</div>

<style>
  .contact-view {
    margin-top: 30px;
    margin-bottom: 40px;
  }

  .contact-info {
    padding: 30px;
    background: #f9f9f9;
    border-radius: 8px;
  }

  .contact-form-section {
    margin-top: 40px;
  }

  .contact-form {
    max-width: 600px;
    margin-top: 20px;
  }

  .edit-btn-container {
    margin: 20px 0;
  }

  @media (max-width: 768px) {
    .contact-form {
      max-width: 100%;
    }
  }
</style>

<script>
  const editContactBtn = document.getElementById('editContactBtn');
  const editContactModal = document.getElementById('editContactModal');
  const closeEditContact = document.getElementById('closeEditContact');
  const cancelContactEdit = document.getElementById('cancelContactEdit');

  editContactBtn.addEventListener('click', () => {
    editContactModal.style.display = 'block';
  });

  closeEditContact.addEventListener('click', () => {
    editContactModal.style.display = 'none';
  });

  cancelContactEdit.addEventListener('click', () => {
    editContactModal.style.display = 'none';
  });

  window.addEventListener('click', (e) => {
    if (e.target === editContactModal) {
      editContactModal.style.display = 'none';
    }
  });
</script>
