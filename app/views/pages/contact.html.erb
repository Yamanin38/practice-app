<div class="container">
  <header class="page-header">
    <h1>お問い合わせ</h1>
    <p>このサイトに関してのご質問やご要望などがあればお知らせください</p>
  </header>

  <div class="page-content">
    <div id="contactView" class="contact-view">
    </div>

    <div class="contact-form-section">
  <h2>お問い合わせフォーム</h2>
  
  <% if flash[:notice].present? %>
    <div class="flash flash-notice" style="margin-bottom: 20px;">
      <%= flash[:notice] %>
    </div>
  <% end %>

  <% if flash[:alert].present? %>
    <div class="flash flash-alert" style="margin-bottom: 20px;">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <%# model: @contact をベースに構築 %>
  <%= form_with model: @contact, scope: :contact, url: contact_path, class: "contact-form", local: true do |f| %>
    <div class="form-group">
      <%= f.label :name, "お名前" %>
      <%# 第2引数ではなく、キーワード引数でオプションを渡します %>
      <%= f.text_field :name, required: true, placeholder: "お名前を入力してください" %>
    </div>
    <div class="form-group">
      <%= f.label :email, "メールアドレス" %>
      <%= f.email_field :email, required: true, placeholder: "メールアドレスを入力してください" %>
    </div>
    <div class="form-group">
      <%= f.label :subject, "件名" %>
      <%= f.text_field :subject, required: true, placeholder: "件名を入力してください" %>
    </div>
    <div class="form-group">
      <%= f.label :message, "メッセージ" %>
      <%= f.text_area :message, rows: 6, required: true, placeholder: "メッセージを入力してください" %>
    </div>
    <%= f.submit "送信", class: "btn btn-primary" %>
  <% end %>
</div>

<style>
  .contact-view {
    margin-top: 30px;
    margin-bottom: 40px;
  }

  .contact-info {
    padding: 30px;
    background: #f9f9f9;
    border-radius: 8px;
  }

  .contact-form {
    max-width: 600px;
    margin-top: 20px;
  }

  .edit-btn-container {
    margin: 20px 0;
  }

  .form-group input, .form-group textarea {
    color: #000000;
  }

  /* お問い合わせフォーム全体を囲むセクションを中央寄せ */
  .contact-form-section {
    max-width: 600px;      /* フォームの最大幅（お好みで調整してください） */
    margin: 0 auto;        /* 左右のマージンを自動にして中央寄せ */
    padding: 20px;         /* 内側の余白 */
  }

  /* フォームのタイトル（h2）を中央揃えにする場合（お好みで） */
  .contact-form-section h2 {
    text-align: center;
    margin-bottom: 24px;
  }

  /* フォーム要素自体の横幅をセクションいっぱいに広げる */
  .contact-form {
    width: 100%;
  }

  /* 送信ボタンも中央に配置したい場合 */
  .contact-form .btn {
    display: block;
    width: 100%;          /* ボタンを横幅いっぱいに広げる場合 */
    /* width: 200px; margin: 0 auto; /* ボタンの幅を固定して中央寄せにする場合はこちら */
  }

  /* ★追加：外側のボックス自体を600pxに制限して中央寄せにする */
  .page-content {
    max-width: 600px;
    margin: 0 auto;
    /* もし背景や枠線との隙間が気になる場合は padding: 20px 30px; などを追加してください */
  }

  .contact-view {
    margin-top: 30px;
    margin-bottom: 40px;
  }

  /* ★修正：max-width と margin を削除し、横幅いっぱい（上の600pxに合わせる）にする */
  .contact-form-section {
    width: 100%;
    padding: 20px 0; /* 左右の余白を0にして、外枠いっぱいに広げる */
  }

  .contact-form-section h2 {
    text-align: center;
    margin-bottom: 24px;
  }

  .contact-form {
    width: 100%;
  }

  /* .form-group input, .form-group textarea などの既存のスタイルはそのまま */
  .form-group input,
  .form-group textarea {
    color: #000000;
  }

  /* 送信ボタン（前回の残りがあればそのまま） */
  .contact-form .btn {
    display: block;
    width: 100%;
  }

  @media (max-width: 768px) {
    .contact-form {
      max-width: 100%;
    }
  }
</style>
