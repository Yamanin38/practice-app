<div class="container">
  <header class="page-header">
    <h1>お問い合わせ</h1>
    <p>ご質問やご要望をお知らせください</p>
  </header>

  <div class="page-content">
    <div id="contactView" class="contact-view">
    </div>

    <div class="contact-form-section">
  <h2>お問い合わせフォーム</h2>
  
  <%# 成功時のメッセージ %>
  <% if flash[:notice].present? %>
    <div class="flash flash-notice" style="margin-bottom: 20px;">
      <%= flash[:notice] %>
    </div>
  <% end %>

  <%# エラー時のメッセージ %>
  <% if flash[:alert].present? %>
    <div class="flash flash-alert" style="margin-bottom: 20px;">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <%# ★ココを変更： url: ではなく model: @contact, url: contact_path にします %>
  <%= form_with model: @contact, url: contact_path, id: "contactForm", class: "contact-form", local: true do |f| %>
    <div class="form-group">
      <%= f.label :name, "お名前" %>
      <%= f.text_field :name, id: "contactName", required: true, placeholder: "お名前を入力してください" %>
    </div>
    <div class="form-group">
      <%= f.label :email, "メールアドレス" %>
      <%= f.email_field :email, id: "contactEmail", required: true, placeholder: "メールアドレスを入力してください" %>
    </div>
    <div class="form-group">
      <%= f.label :subject, "件名" %>
      <%= f.text_field :subject, id: "contactSubject", required: true, placeholder: "件名を入力してください" %>
    </div>
    <div class="form-group">
      <%= f.label :message, "メッセージ" %>
      <%= f.text_area :message, id: "contactMessage", rows: 6, required: true, placeholder: "メッセージを入力してください" %>
    </div>
    <%= f.submit "送信", class: "btn btn-primary" %>
  <% end %>
</div>

<style>
  .contact-view {
    margin-top: 30px;
    margin-bottom: 40px;
  }

  .contact-info {
    padding: 30px;
    background: #f9f9f9;
    border-radius: 8px;
  }

  .contact-form {
    max-width: 600px;
    margin-top: 20px;
  }

  .edit-btn-container {
    margin: 20px 0;
  }

  .form-group input, .form-group textarea {
    color: #000000;
  }

  @media (max-width: 768px) {
    .contact-form {
      max-width: 100%;
    }
  }
</style>
