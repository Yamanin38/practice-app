<div class="container">
  <header class="page-header">
    <h1>チーム規約</h1>
    <p>チームのルール</p>
  </header>

  <div class="page-content">
    <div class="edit-btn-container">
      <button class="btn btn-secondary" id="editRulesBtn">編集</button>
    </div>

    <div id="rulesView" class="rules-view">
      <div class="rules-content">
        <p>チーム規約がまだ設定されていません。</p>
      </div>
    </div>
  </div>

  <!-- チーム規約編集フォーム（モーダル） -->
  <div class="modal" id="editRulesModal">
    <div class="modal-content modal-lg">
      <span class="close" id="closeEditRules">&times;</span>
      <h2>チーム規約を編集</h2>
      <form id="editRulesForm">
        <div class="form-group">
          <label for="rulesContent">チーム規約</label>
          <textarea id="rulesContent" rows="12" placeholder="チームのルール・規約を入力してください"></textarea>
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn-primary">保存</button>
          <button type="button" class="btn btn-secondary" id="cancelRulesEdit">キャンセル</button>
        </div>
      </form>
    </div>
  </div>
</div>

<style>
  .rules-view {
    margin-top: 30px;
  }

  .rules-content {
    padding: 30px;
    background: #f9f9f9;
    border-radius: 8px;
    line-height: 1.8;
    white-space: pre-wrap;
  }

  .edit-btn-container {
    margin: 20px 0;
  }
</style>

<script>
  const editRulesBtn = document.getElementById('editRulesBtn');
  const editRulesModal = document.getElementById('editRulesModal');
  const closeEditRules = document.getElementById('closeEditRules');
  const cancelRulesEdit = document.getElementById('cancelRulesEdit');

  editRulesBtn.addEventListener('click', () => {
    editRulesModal.style.display = 'block';
  });

  closeEditRules.addEventListener('click', () => {
    editRulesModal.style.display = 'none';
  });

  cancelRulesEdit.addEventListener('click', () => {
    editRulesModal.style.display = 'none';
  });

  window.addEventListener('click', (e) => {
    if (e.target === editRulesModal) {
      editRulesModal.style.display = 'none';
    }
  });
</script>
