<%
  require 'kramdown'
  if local_assigns[:content].present?
    html = Kramdown::Document.new(local_assigns[:content]).to_html
    # テーブルをスクロール可能なラッパーで囲む
    rendered_content = html.gsub(/<table>/, '<div class="table-wrapper"><table>').gsub(/<\/table>/, '</table></div>')
  else
    rendered_content = nil
  end
%>

<!-- EasyMDE CSS -->
<link rel="stylesheet" href="https://unpkg.com/easymde/dist/easymde.min.css">

<div class="container">
  <header class="page-header">
    <h1><%= local_assigns[:title] %></h1>
    <p><%= local_assigns[:subtitle] %></p>
  </header>

  <% if notice %>
    <div class="flash flash-notice"><%= notice %></div>
  <% end %>
  <% if alert %>
    <div class="flash flash-alert"><%= alert %></div>
  <% end %>

  <div class="page-content">
    <% if current_user&.admin? %>
      <div class="edit-btn-container">
        <button class="btn btn-primary" id="editAboutBtn">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle;margin-right:6px"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          <%= local_assigns[:title] %>を編集
        </button>
      </div>
    <% end %>

    <div id="aboutView" class="about-view">
      <% if rendered_content %>
        <div class="about-content markdown-body">
          <%= rendered_content.html_safe %>
        </div>
      <% else %>
        <div class="about-empty">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          <p><%= local_assigns[:empty_message] %></p>
          <% if current_user&.admin? %>
            <p class="empty-hint">「<%= local_assigns[:title] %>を編集」ボタンから内容を追加してください。</p>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- チーム概要編集モーダル -->
<% if current_user&.admin? %>
  <div class="modal" id="editAboutModal">
    <div class="modal-content modal-lg">
      <div class="modal-header">
        <h2><%= local_assigns[:title] %>を編集</h2>
        <div class="modal-header-actions">
          <%# form属性で下のフォームIDと紐付け、ヘッダー内からでも送信可能 %>
          <button type="submit" form="editAboutForm" class="btn btn-primary btn-sm" id="saveAboutBtn">保存する</button>
          <button class="modal-close" id="closeEditAbout" aria-label="閉じる">&times;</button>
        </div>
      </div>
      <div class="modal-body">
        <p class="editor-hint">マークダウン形式で入力できます</p>
        <%= form_with url: local_assigns[:update_path], method: :patch, id: "editAboutForm", local: true do |f| %>
          <div class="form-group">
            <%= f.text_area :content,
                id: "aboutContent",
                rows: 15,
                placeholder: local_assigns[:placeholder],
                value: local_assigns[:content] %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- 変更破棄確認モーダル -->
  <div class="modal" id="discardConfirmModal">
    <div class="modal-content modal-sm">
      <div class="modal-header">
        <h2>変更を破棄しますか？</h2>
      </div>
      <div class="modal-body confirm-body">
        <p>編集中の内容は保存されません。</p>
        <div class="confirm-actions">
          <button class="btn btn-danger" id="confirmDiscard">破棄する</button>
          <button class="btn btn-back-to-edit" id="cancelDiscard">編集に戻る</button>
        </div>
      </div>
    </div>
  </div>
<% end %>


<style>
  /* ===== フラッシュメッセージ ===== */
  .flash {
    padding: 12px 18px;
    border-radius: 8px;
    margin: 16px 0;
    font-size: 0.95rem;
    font-weight: 500;
  }
  .flash-notice {
    background: #d1fae5;
    color: #065f46;
    border: 1px solid #6ee7b7;
  }
  .flash-alert {
    background: #fee2e2;
    color: #991b1b;
    border: 1px solid #fca5a5;
  }

  /* ===== 編集ボタン ===== */
  .edit-btn-container {
    display: flex;
    justify-content: flex-end;
    margin: 16px 0 24px;
  }

  /* ===== 本文表示エリア ===== */
  .about-view {
    margin-top: 8px;
  }

  .about-content {
    padding: 10px 40px;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    line-height: 1.85;
    box-shadow: 0 1px 6px rgba(0,0,0,0.06);
    /* はみ出し防止 */
    overflow: hidden;
    min-width: 0;
  }

  @media (max-width: 600px) {
    .about-content {
      padding: 20px 16px;
    }
  }

  /* ===== マークダウンスタイル ===== */
  .markdown-body {
    /* 長い単語・URLをすべて折り返す */
    overflow-wrap: break-word;
    word-break: break-word;
    word-wrap: break-word;
    /* 子要素が親をはみ出さないように */
    min-width: 0;
    max-width: 100%;
  }
  .markdown-body h1, .markdown-body h2, .markdown-body h3,
  .markdown-body h4, .markdown-body h5, .markdown-body h6 {
    margin-top: 1.5em;
    margin-bottom: 0.6em;
    font-weight: 700;
    line-height: 1.3;
    /* 見出しも折り返す */
    overflow-wrap: break-word;
    word-break: break-word;
  }
  .markdown-body h1 { font-size: 2rem; border-bottom: 2px solid #e5e7eb; padding-bottom: 0.3em; }
  .markdown-body h2 { font-size: 1.5rem; border-bottom: 1px solid #e5e7eb; padding-bottom: 0.2em; }
  .markdown-body h3 { font-size: 1.25rem; }
  .markdown-body p  { margin: 0.8em 0; }
  .markdown-body ul, .markdown-body ol { padding-left: 1.8em; margin: 0.8em 0; }
  .markdown-body li { margin: 0.3em 0; }
  .markdown-body strong { font-weight: 700; }
  .markdown-body em { font-style: italic; }
  .markdown-body img {
    max-width: 100%;
    height: auto;
    display: block;
  }
  .markdown-body code {
    background: #f3f4f6;
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.9em;
    font-family: 'Courier New', monospace;
    /* インラインコードは折り返す */
    overflow-wrap: break-word;
    word-break: break-all;
  }
  .markdown-body pre {
    background: #1e2937;
    color: #e5e7eb;
    padding: 16px 20px;
    border-radius: 8px;
    /* コードブロックは横スクロール（折り返しなし） */
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    margin: 1em 0;
    max-width: 100%;
  }
  .markdown-body pre code {
    background: none;
    color: inherit;
    padding: 0;
    overflow-wrap: normal;
    word-break: normal;
    white-space: pre;
  }
  .markdown-body blockquote {
    border-left: 4px solid #6366f1;
    margin: 1em 0;
    padding: 8px 16px;
    color: #6b7280;
    background: #f9fafb;
    border-radius: 0 6px 6px 0;
    overflow-wrap: break-word;
    word-break: break-word;
  }
  .markdown-body a {
    color: #6366f1;
    text-decoration: underline;
    /* 長いURLも折り返す */
    overflow-wrap: break-word;
    word-break: break-all;
  }
  .markdown-body hr { border: none; border-top: 1px solid #e5e7eb; margin: 2em 0; }
  /* テーブルはスマホで横スクロール */
  .markdown-body .table-wrapper {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    margin: 1em 0;
  }
  .markdown-body table { border-collapse: collapse; width: 100%; min-width: 400px; }
  .markdown-body th, .markdown-body td {
    border: 1px solid #e5e7eb;
    padding: 8px 12px;
    text-align: left;
    white-space: nowrap;
  }
  .markdown-body th { background: #f9fafb; font-weight: 600; }

  @media (max-width: 600px) {
    .markdown-body h1 { font-size: 1.5rem; }
    .markdown-body h2 { font-size: 1.25rem; }
    .markdown-body h3 { font-size: 1.1rem; }
    .markdown-body pre {
      padding: 12px 14px;
      font-size: 0.85rem;
    }
  }

  /* ===== 空状態 ===== */
  .about-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 80px 20px;
    color: #9ca3af;
    text-align: center;
    background: #f9fafb;
    border: 2px dashed #e5e7eb;
    border-radius: 12px;
    gap: 12px;
  }
  .about-empty svg { opacity: 0.5; }
  .about-empty p { margin: 0; font-size: 1rem; }
  .empty-hint { font-size: 0.875rem !important; color: #6366f1 !important; }

  /* ===== モーダル ===== */
  .modal {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(15, 23, 42, 0.6);
    backdrop-filter: blur(4px);
    z-index: 1000;
    animation: fadeIn 0.2s ease;
  }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

  .modal-content {
    background: #fff;
    border-radius: 16px;
    width: 90%;
    max-width: 860px;
    margin: 40px auto;
    box-shadow: 0 20px 60px rgba(0,0,0,0.2);
    overflow: hidden;
    animation: slideUp 0.25s ease;
    max-height: calc(100vh - 80px);
    display: flex;
    flex-direction: column;
  }
  @keyframes slideUp {
    from { transform: translateY(20px); opacity: 0; }
    to   { transform: translateY(0);    opacity: 1; }
  }

  .modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid #e5e7eb;
    background: #f9fafb;
    gap: 12px;
  }
  .modal-header h2 {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 700;
    color: #111827;
    flex: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .modal-header-actions {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }
  .modal-close {
    background: none;
    border: none;
    font-size: 1.6rem;
    color: #6b7280;
    cursor: pointer;
    line-height: 1;
    padding: 2px 6px;
    border-radius: 4px;
    transition: background 0.15s, color 0.15s;
  }
  .modal-close:hover { background: #e5e7eb; color: #111827; }

  /* 小さいボタン */
  .btn-sm {
    padding: 6px 14px;
    font-size: 0.85rem;
  }

  .modal-body {
    padding: 24px 28px;
    overflow-y: auto;
    flex: 1;
  }

  .editor-hint {
    font-size: 0.85rem;
    color: #6b7280;
    margin: 0 0 14px;
  }

  .form-group { margin-bottom: 16px; }

  /* 確認モーダル */
  .modal-sm {
    max-width: 420px;
    margin: 120px auto;
  }
  .confirm-body {
    text-align: center;
  }
  .confirm-body p {
    color: #6b7280;
    margin: 0 0 24px;
    font-size: 0.95rem;
  }
  .confirm-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
  }
  .btn-danger {
    background: #ef4444;
    color: #fff;
    border: none;
    padding: 10px 22px;
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s;
  }
  .btn-danger:hover { background: #dc2626; }

  .btn-back-to-edit {
    background: #2980b9;
    color: #fff;
    border: none;
    padding: 10px 22px;
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s;
  }
  .btn-back-to-edit:hover { background: #1f6391; }

  /* EasyMDE 調整 */
  .EasyMDEContainer { border-radius: 8px; overflow: hidden; }
  .EasyMDEContainer .CodeMirror {
    border-radius: 0;
    min-height: 340px;
    font-size: 0.95rem;
  }
</style>

<!-- EasyMDE JS -->
<script src="https://unpkg.com/easymde/dist/easymde.min.js"></script>

<script>
  <% if current_user&.admin? %>
    const editAboutBtn       = document.getElementById('editAboutBtn');
    const editAboutModal     = document.getElementById('editAboutModal');
    const closeEditAbout     = document.getElementById('closeEditAbout');
    const discardConfirmModal = document.getElementById('discardConfirmModal');
    const confirmDiscard     = document.getElementById('confirmDiscard');
    const cancelDiscard      = document.getElementById('cancelDiscard');
    const textarea           = document.getElementById('aboutContent');
    const saveForm           = document.getElementById('editAboutForm');

    // ページロード時点のサーバー保存済み内容（破棄時にここへ戻す）
    const savedContent = textarea.value;
    let originalContent = '';
    let easyMDE = null;

    // ===== モーダルを開く =====
    function openEditModal() {
      editAboutModal.style.display = 'block';
      document.body.style.overflow = 'hidden';

      if (!easyMDE) {
        // EasyMDE を初回だけ初期化
        easyMDE = new EasyMDE({
          element: textarea,
          spellChecker: false,
          autofocus: true,
          placeholder: "<%= j local_assigns[:placeholder] %>",
          toolbar: [
            "bold", "italic", "heading", "|",
            "unordered-list", "ordered-list", "|",
            "link", "quote", "code", "horizontal-rule", "|",
            "preview", "side-by-side", "fullscreen", "|",
            "guide"
          ],
          status: ["lines", "words"],
        });
      } else {
        // 2回目以降: 常にサーバー保存済み内容にリセット（破棄後も正しく戻る）
        easyMDE.value(savedContent);
      }

      // 「変更あり」の基準をリセット
      originalContent = easyMDE.value();
    }

    // ===== 変更があるか判定 =====
    function hasChanges() {
      if (!easyMDE) return false;
      return easyMDE.value() !== originalContent;
    }

    // ===== 編集モーダルを閉じる（確定） =====
    function forceCloseEditModal() {
      editAboutModal.style.display = 'none';
      document.body.style.overflow = '';
    }

    // ===== 確認モーダルを開く =====
    function openDiscardConfirm() {
      discardConfirmModal.style.display = 'block';
    }

    // ===== 確認モーダルを閉じる =====
    function closeDiscardConfirm() {
      discardConfirmModal.style.display = 'none';
    }

    // ===== ✕ ボタン: 変更があれば確認、なければ即閉じ =====
    closeEditAbout.addEventListener('click', () => {
      if (hasChanges()) {
        openDiscardConfirm();
      } else {
        forceCloseEditModal();
      }
    });

    // ===== 確認モーダル: 「破棄する」 =====
    confirmDiscard.addEventListener('click', () => {
      if (easyMDE) {
        easyMDE.value(savedContent); // 確実にリセットする
        originalContent = savedContent;
      }
      closeDiscardConfirm();
      forceCloseEditModal();
    });

    // ===== 確認モーダル: 「編集に戻る」 =====
    cancelDiscard.addEventListener('click', () => {
      closeDiscardConfirm();
    });

    // ===== 外クリックでは閉じない（両モーダル共通） =====
    // ※ 何もしないことで閉じない挙動を実現
    editAboutModal.addEventListener('click', (e) => {
      e.stopPropagation();
    });
    discardConfirmModal.addEventListener('click', (e) => {
      e.stopPropagation();
    });

    // ===== Escape キーも無効化 =====
    window.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') e.preventDefault();
    });

    // ===== 開くボタン =====
    editAboutBtn.addEventListener('click', openEditModal);

    // ===== フォーム送信前に EasyMDE の値を textarea に同期 =====
    saveForm.addEventListener('submit', () => {
      if (easyMDE) easyMDE.codemirror.save();
    });
  <% end %>
</script>
