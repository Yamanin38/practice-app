<%
  if local_assigns[:rendered_html].present?
    # テーブルをスクロール可能なラッパーで囲む（コントローラ側で変換済みのHTMLに対して適用）
    rendered_content = local_assigns[:rendered_html].gsub(/<table>/, '<div class="table-wrapper"><table>').gsub(/<\/table>/, '</table></div>')
  else
    rendered_content = nil
  end
%>

<!-- EasyMDE CSS -->
<link rel="stylesheet" href="https://unpkg.com/easymde/dist/easymde.min.css">

<div class="container">
  <header class="page-header">
    <h1><%= local_assigns[:title] %></h1>
    <p><%= local_assigns[:subtitle] %></p>
  </header>
  
  <% if alert %>
    <div class="flash flash-alert"><%= alert %></div>
  <% end %>

  <div class="page-content page-content--plain">
    <% if @user&.admin? %>
      <div class="edit-btn-container">
        <button class="btn btn-primary" id="editAboutBtn">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle;margin-right:6px"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          <%= local_assigns[:title] %>を編集
        </button>
      </div>
    <% end %>

    <div id="aboutView" class="about-view">
      <% if rendered_content %>
        <div class="about-content markdown-body">
          <%= rendered_content.html_safe %>
        </div>
      <% else %>
        <div class="about-empty">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          <p><%= local_assigns[:empty_message] %></p>
          <% if @user&.admin? %>
            <p class="empty-hint">「<%= local_assigns[:title] %>を編集」ボタンから内容を追加してください。</p>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- チーム概要編集モーダル -->
<% if @user&.admin? %>
  <div class="modal" id="editAboutModal">
    <div class="modal-content modal-lg">
      <div class="modal-header">
        <h2><%= local_assigns[:title] %>を編集</h2>
        <div class="modal-header-actions">
          <%# form属性で下のフォームIDと紐付け、ヘッダー内からでも送信可能 %>
          <button type="submit" form="editAboutForm" class="btn btn-primary btn-sm" id="saveAboutBtn">保存する</button>
          <button class="modal-close" id="closeEditAbout" aria-label="閉じる">&times;</button>
        </div>
      </div>
      <div class="modal-body">
        <%= form_with url: local_assigns[:update_path], method: :patch, id: "editAboutForm", local: true do |f| %>
          <div class="form-group">
            <%= f.text_area :content,
                id: "aboutContent",
                rows: 15,
                placeholder: local_assigns[:placeholder],
                value: local_assigns[:content] %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- 変更破棄確認モーダル -->
  <div class="modal" id="discardConfirmModal">
    <div class="modal-content modal-sm">
      <div class="modal-header">
        <h2>変更を破棄しますか？</h2>
      </div>
      <div class="modal-body confirm-body">
        <p>編集中の内容は保存されません。</p>
        <div class="confirm-actions">
          <button class="btn btn-danger" id="confirmDiscard">破棄する</button>
          <button class="btn btn-back-to-edit" id="cancelDiscard">編集に戻る</button>
        </div>
      </div>
    </div>
  </div>
<% end %>


<style>
  /* ===== このpartialで上書きが必要な箇所のみ記述 ===== */
  /* ※ 大部分のスタイルは pages.css の CSS変数を継承 */

  /* --- モーダル自体の高さを画面内に完全に収める（はみ出し防止の土台） --- */
  #editAboutModal .modal-content {
    display: flex;
    flex-direction: column;
    height: 80vh; /* max-heightから固定のheightに変更することでサイズを安定化 */
    max-height: 80vh;
    overflow: hidden;
  }

  #editAboutModal .modal-body {
    display: flex;
    flex-direction: column;
    flex: 1;
    overflow: hidden; /* モーダル本体は絶対にスクロールさせない */
    padding-bottom: 20px;
    min-height: 0;    /* Flexの子要素が中身に引っ張られて伸びるのを防ぐ */
  }

  #editAboutForm {
    display: flex;
    flex-direction: column;
    flex: 1;
    overflow: hidden;
    min-height: 0;
  }

  #editAboutForm .form-group {
    display: flex;
    flex-direction: column;
    flex: 1;
    overflow: hidden;
    margin-bottom: 0;
    min-height: 0;
  }

  /* --- EasyMDE ツールバー・エディタを枠内に閉じ込める --- */
  .EasyMDEContainer {
    display: flex;
    flex-direction: column;
    flex: 1;
    overflow: hidden;
    border-radius: 8px;
    border: 1px solid var(--clr-border, #5a3510);
    min-height: 0;
  }

  /* ツールバーの高さが潰れないように固定 */
  .EasyMDEContainer .editor-toolbar {
    flex-shrink: 0;
    background: #956900;
    border-color: #150d00;
  }

  /* エディタ本体：無限に伸びるのを防ぐ最重要設定 */
  .EasyMDEContainer .CodeMirror {
    flex: 1;
    min-height: 0;            /* これがないと文字量に応じて枠が伸びます */
    height: 100% !important;  /* height: auto をやめて100%に固定 */
    border-radius: 0;
    font-size: 0.95rem;
    background: var(--clr-bg, #150d00) !important;
    color: var(--clr-text, #e8d5b0) !important;
    border: none;
  }

  /* スクロール領域をエディタの内側に限定する */
  .EasyMDEContainer .CodeMirror-scroll {
    background: var(--clr-bg, #150d00);
    height: 100% !important;
    min-height: 0 !important;
    overflow-y: auto !important; /* 縦スクロールを強制的に有効化 */
    /* ⭕ 追記：iOS（iPhone）でのスクロールを強制的に有効化する魔法のプロパティ */
    -webkit-overflow-scrolling: touch !important;
  }

  .editor-toolbar a {
    color: var(--clr-text-muted, #a08060) !important;
  }
  .editor-toolbar a:hover,
  .editor-toolbar a.active {
    background: rgba(200,130,10,.2);
    border-color: var(--clr-border-lite, #7a4e20);
    color: var(--clr-gold-light, #e8a820) !important;
  }
  .editor-preview, .editor-preview-side {
    background: var(--clr-surface, #241400);
    color: var(--clr-text, #e8d5b0);
    border-color: var(--clr-border, #5a3510);
  }
  .CodeMirror-cursor { border-left: 2px solid var(--clr-gold-light, #e8a820); }
  .cm-s-easymde .cm-header { color: var(--clr-gold-light, #e8a820); }
  .cm-s-easymde .cm-link { color: var(--clr-gold, #c8820a); }
  .cm-s-easymde .cm-string { color: #d0b090; }
  
  @media (max-width: 1024px) {
    #editAboutModal .modal-content {
      height: 60vh;      /* PC時の80vhから60vhに縮小（お好みの高さに調整してください） */
      max-height: 60vh;
    }
  }

  /* =================================================== */
  /* ここに追加：モーダルの中央配置とスマホ特有のスクロール対策 */
  /* =================================================== */
  
  /* モーダルの背景（暗転部分）の設定 */
  .modal {
    /* JSで display: flex に切り替わったときに中央寄せを機能させる */
    align-items: center;
    justify-content: center;
    /* モーダル内を一番下までスクロールした際、背景まで一緒にスクロールしてしまう現象を防ぐ */
    overscroll-behavior: contain;
  }

  /* 外部CSSによる余計な余白(margin)を打ち消し、確実にど真ん中に配置する */
  #editAboutModal .modal-content,
  #discardConfirmModal .modal-content {
    margin: 0;
  }

  /* モーダルの背景（暗転エリア） */
  .modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(18, 10, 0, 0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(3px);
    /* ⭕ 追記: スクロールが背景に突き抜けるのを防ぐ */
    overscroll-behavior: contain;
  }

  .modal-wrapper form {
    overflow-y: auto;
    flex: 1;
    margin: 0 -24px -24px;
    padding: 0 24px 24px;
    /* ⭕ 追記: フォーム内スクロールの突き抜け防止とiOSの滑らかスクロール */
    overscroll-behavior: contain;
    -webkit-overflow-scrolling: touch;
  }

  /* ⭕ 追記: テキストエリア単体でのスクロール突き抜けも個別にブロックする */
  #editArticleModal textarea {
    overscroll-behavior: contain;
  }

  /* EasyMDEのエディタ内でスクロールが突き抜けて背景が動くのを防ぐ */
  .EasyMDEContainer .CodeMirror-scroll {
    overscroll-behavior: contain !important;
  }

</style>

<!-- EasyMDE JS -->
<script src="https://unpkg.com/easymde/dist/easymde.min.js"></script>

<script>
  <% if @user&.admin? %>
    const editAboutBtn       = document.getElementById('editAboutBtn');
    const editAboutModal     = document.getElementById('editAboutModal');
    const closeEditAbout     = document.getElementById('closeEditAbout');
    const discardConfirmModal = document.getElementById('discardConfirmModal');
    const confirmDiscard     = document.getElementById('confirmDiscard');
    const cancelDiscard      = document.getElementById('cancelDiscard');
    const textarea           = document.getElementById('aboutContent');
    const saveForm           = document.getElementById('editAboutForm');

    const savedContent = textarea.value;
    let originalContent = '';
    let easyMDE = null;

    // ⭕ 修正: 開いた瞬間の背景のスクロール位置を記憶する変数を追加
    let aboutModalScrollY = 0; 

    // ===== モーダルを開く =====
    function openEditModal() {
      editAboutModal.style.display = 'flex';
      
      // ⭕ 修正: モーダルが開いた瞬間に背景（body）を現在の位置で物理的にピン留め固定する
      aboutModalScrollY = window.scrollY;
      document.body.style.position = 'fixed';
      document.body.style.top = `-${aboutModalScrollY}px`;
      document.body.style.width = '100%';
      document.body.style.overflow = 'hidden';

      if (!easyMDE) {
        easyMDE = new EasyMDE({
          element: textarea,
          spellChecker: false,
          autofocus: true,
          placeholder: "<%= j local_assigns[:placeholder] %>",
          toolbar: [
            "bold", "italic", "heading", "|",
            "unordered-list", "ordered-list", "|",
            "link", "quote", "code", "horizontal-rule", "|",
            "preview", "side-by-side", "fullscreen", "|",
            "guide"
          ],
          status: ["lines", "words"],
        });
      } else {
        easyMDE.value(savedContent);
      }

      originalContent = easyMDE.value();

      setTimeout(() => {
        if (easyMDE) {
          easyMDE.codemirror.refresh();
        }
      }, 50);
    }

    // ===== 変更があるか判定 =====
    function hasChanges() {
      if (!easyMDE) return false;
      return easyMDE.value() !== originalContent;
    }

    // ===== 編集モーダルを閉じる（確定） =====
    function forceCloseEditModal() {
      editAboutModal.style.display = 'none';
      
      // ⭕ 修正: 背景のピン留めを解除し、元のスクロール位置に違和感なく戻す
      document.body.style.position = '';
      document.body.style.top = '';
      document.body.style.width = '';
      document.body.style.overflow = '';
      window.scrollTo(0, aboutModalScrollY);
    }

    // ===== 確認モーダルを開く =====
    function openDiscardConfirm() {
      discardConfirmModal.style.display = 'flex';
    }

    // ===== 確認モーダルを閉じる =====
    function closeDiscardConfirm() {
      discardConfirmModal.style.display = 'none';
    }

    // ===== ✕ ボタン: 変更があれば確認、なければ即閉じ =====
    closeEditAbout.addEventListener('click', () => {
      if (hasChanges()) {
        openDiscardConfirm();
      } else {
        forceCloseEditModal();
      }
    });

    // ===== 確認モーダル: 「破棄する」 =====
    confirmDiscard.addEventListener('click', () => {
      if (easyMDE) {
        easyMDE.value(savedContent);
        originalContent = savedContent;
      }
      closeDiscardConfirm();
      forceCloseEditModal();
    });

    // ===== 確認モーダル: 「編集に戻る」 =====
    cancelDiscard.addEventListener('click', () => {
      closeDiscardConfirm();
    });

    // ===== 外クリックでは閉じない（両モーダル共通） =====
    editAboutModal.addEventListener('click', (e) => {
      e.stopPropagation();
    });
    discardConfirmModal.addEventListener('click', (e) => {
      e.stopPropagation();
    });

    // ===== Escape キーも無効化 =====
    window.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') e.preventDefault();
    });

    // ===== 開くボタン =====
    editAboutBtn.addEventListener('click', openEditModal);

    // ===== フォーム送信前に EasyMDE の値を textarea に同期 =====
    saveForm.addEventListener('submit', () => {
      if (easyMDE) easyMDE.codemirror.save();
    });
  <% end %>
</script>