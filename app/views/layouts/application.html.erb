<!DOCTYPE html>
<html>
  <head>
    <link rel="icon" href="/favicon.png">
    <title>Thrones Site - チームの紹介サイト</title>
    <meta name="theme-color" content="#1b0b00">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <script>
      // 画面が描画される前に訪問済みか判定し、htmlタグにクラスを付ける（最速のFOUC対策）
      if (sessionStorage.getItem('site_visited') === '1') {
        document.documentElement.classList.add('site-visited');
      }
    </script>
    <style>
      /* 訪問済みの場合は、どんな状況でもドアを強制的に非表示にする */
      html.site-visited .door-overlay {
        display: none !important;
        opacity: 0 !important;
        visibility: hidden !important;
        animation: none !important;
      }
    </style>

  <body>
    <!-- ===== ドア開放アニメーション オーバーレイ ===== -->
    <div id="doorOverlay" class="door-overlay" aria-hidden="true">
      <div class="door-scene">
        <div class="door-frame">
          <%= image_tag 'door.png', alt: 'door-left',  class: 'door-img door-img--left'  %>
          <%= image_tag 'door.png', alt: 'door-right', class: 'door-img door-img--right' %>
        </div>
        <div class="door-light"></div>
        <div class="door-welcome">
          <span class="door-welcome-text">ようこそ、スローンズへ！</span>
        </div>
      </div>
    </div>
    <!-- ===== /ドア開放アニメーション ===== -->
    <nav class="navbar" <% if @current_user_view %>data-current-user='<%= { username: @current_user_view.username, role: @current_user_view.role }.to_json %>'<% end %>>
  <div class="navbar-container">
    <div class="navbar-logo">
      <a href="/">Thrones</a>
    </div>

    <ul class="nav-menu" id="navMenu">
      <li class="nav-item"><a href="/" class="nav-link <%= 'active' if current_page?('/') %>">ホーム</a></li>
      <li class="nav-item"><a href="/about" class="nav-link <%= 'active' if current_page?('/about') %>">チーム概要</a></li>
      <li class="nav-item"><a href="/gallery" class="nav-link <%= 'active' if current_page?('/gallery') %>">ギャラリー</a></li>
      <li class="nav-item"><a href="/articles" class="nav-link <%= 'active' if current_page?('/articles') %>">活動記録</a></li>
      <li class="nav-item"><a href="/recruitment" class="nav-link <%= 'active' if current_page?('/recruitment') %>">入隊案内</a></li>
      <li class="nav-item"><a href="/rules" class="nav-link <%= 'active' if current_page?('/rules') %>">チーム規約</a></li>
      <li class="nav-item"><a href="/contact" class="nav-link <%= 'active' if current_page?('/contact') %>">お問い合わせ</a></li>
    </ul>

    <div class="nav-auth" id="navAuth">
      <a href="<%= login_path %>" class="btn btn-secondary btn-sm" id="loginBtn">ログイン</a>
      <button class="btn btn-secondary btn-sm" id="logoutBtn" style="display: none;">ログアウト</button>
      <span class="user-info" id="userInfo" style="display: none;">
        <span id="userName"></span>
        <span class="user-role" id="userRole"></span>
      </span>
    </div>

    <div class="hamburger" id="hamburger">
      <span></span>
      <span></span>
      <span></span>
    </div>
    
    
  </div>
</nav>

    <main class="main-content">
      <%= yield %>
    </main>

    <footer class="footer">
      <p>
        このページで利用している株式会社スクウェア・エニックスを代表とする共同著作者が権利を所有する画像の転載・配布は禁止いたします。<br>
        (C) ARMOR PROJECT/BIRD STUDIO/SQUARE ENIX All Rights Reserved.
      </p>
      <p>&copy; 2026 Thrones Site. All rights reserved.</p>
    </footer>

    <style>
    /* ============================================================
       ドア開放アニメーション
       ============================================================ */

    /* オーバーレイ全画面 */
    .door-overlay {
      position: fixed;
      inset: 0;
      z-index: 9999;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #1a0c00;
      pointer-events: all;
      opacity: 1;
      overflow: hidden;  /* 内容が画面外に漏れないよう */
      transition: opacity 0.6s ease;
    }
    .door-overlay.hidden {
      opacity: 0;
      pointer-events: none;
    }
    .door-overlay.gone {
      display: none;
    }

    /* ドアのシーン全体 */
    .door-scene {
      position: relative;
      width: 100%;
      height: 100%;
      display: flex;
      flex-direction: row;      /* パネルを横並び */
      align-items: center;
      justify-content: center;
      overflow: hidden;
      background: radial-gradient(ellipse at center, #3a1a00 0%, #1a0800 60%, #0a0400 100%);
    }

    /* 石畳の床（下部） */
    .door-scene::before {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 35%;
      background:
        repeating-linear-gradient(90deg,  rgba(80,50,20,0.3) 0px, rgba(80,50,20,0.3) 1px, transparent 1px, transparent 60px),
        repeating-linear-gradient(0deg,   rgba(80,50,20,0.3) 0px, rgba(80,50,20,0.3) 1px, transparent 1px, transparent 40px),
        linear-gradient(to top, #0a0400, transparent);
      pointer-events: none;
    }

    /* ドア枠 */
    .door-frame {
      position: relative;
      width: min(320px, 70vw);
      height: min(440px, 60dvh, 60vh);
      display: flex;
      flex-shrink: 0;
    }

    /* ドア画像：door-frame全体を埋め、clip-pathで左右半分のみ表示。
       width:100% にすることで transform-origin がフレームの端に正確に一致する */
    .door-img {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      object-fit: contain;
      object-position: center top;
    }
    /* 左半分のみ表示、左端をヒンジに回転 */
    .door-img--left {
      clip-path: inset(0 50% 0 0);
      transform-origin: left center;
    }
    /* 右半分のみ表示、右端をヒンジに回転 */
    .door-img--right {
      clip-path: inset(0 0 0 50%);
      transform-origin: right center;
    }

    /* ============================================================
       アニメーション定義
       すべて「animating」クラス一発で animation-delay を使い制御。
       クラスを途中で付け外しすると resetがかかり二重再生になるため。
       ============================================================ */
    @keyframes doorShake {
      0%,100% { transform: translateX(0); }
      20%      { transform: translateX(-7px); }
      40%      { transform: translateX(5px); }
      60%      { transform: translateX(-4px); }
      80%      { transform: translateX(3px); }
    }
    @keyframes openLeft {
      0%   { transform: perspective(700px) rotateY(0deg); }
      100% { transform: perspective(700px) rotateY(-80deg); }
    }
    @keyframes openRight {
      0%   { transform: perspective(700px) rotateY(0deg); }
      100% { transform: perspective(700px) rotateY(80deg); }
    }
    @keyframes lightGlow {
      0%   { opacity: 0; }
      100% { opacity: 1; }
    }
    @keyframes welcomeFadeIn {
      0%   { opacity: 0; transform: translateX(-50%) translateY(16px) scale(0.85); }
      100% { opacity: 1; transform: translateX(-50%) translateY(0)     scale(1); }
    }
    @keyframes welcomePulse {
      0%,100% { text-shadow: 0 0 16px #ffcc00, 0 0 36px rgba(255,180,0,0.5); }
      50%      { text-shadow: 0 0 32px #ffdd44, 0 0 72px rgba(255,200,0,0.8); }
    }

    /* animating クラスが付いたら全シーケンスを delay で順番に実行 */
    .door-overlay.animating .door-frame {
      animation: doorShake 0.45s ease-in-out 0.2s both;
    }
    .door-overlay.animating .door-img--left {
      animation: openLeft 1.3s cubic-bezier(0.22, 1, 0.36, 1) 0.85s both;
    }
    .door-overlay.animating .door-img--right {
      animation: openRight 1.3s cubic-bezier(0.22, 1, 0.36, 1) 0.85s both;
    }
    .door-overlay.animating .door-light {
      animation: lightGlow 0.8s ease 1.2s both;
    }
    .door-overlay.animating .door-welcome {
      animation:
        welcomeFadeIn 0.55s ease 1.5s both,
        welcomePulse  2s ease-in-out 2.05s infinite;
    }

    /* 中央から漏れる光 */
    .door-light {
      position: absolute;
      top: 0; left: 50%;
      transform: translateX(-50%);
      width: 60px;
      height: 100%;
      opacity: 0;
      background: radial-gradient(ellipse at center, rgba(255,200,80,0.35) 0%, transparent 70%);
      box-shadow: 0 0 120px 80px rgba(255,170,30,0.2);
      pointer-events: none;
    }

    /* ようこそメッセージ */
    .door-welcome {
      position: absolute;
      bottom: 10%;
      left: 50%;
      transform: translateX(-50%);
      opacity: 0;
      pointer-events: none;
      white-space: nowrap;
    }
    .door-welcome-text {
      font-family: 'Cinzel', Georgia, serif;
      font-size: clamp(0.9rem, 2.8vw, 1.5rem);
      font-weight: 700;
      color: #ffe080;
      letter-spacing: 0.12em;
      text-shadow: 0 0 16px #ffcc00, 0 0 36px rgba(255,180,0,0.5);
    }

    /* 元の style タグ */

    /* 1. 親要素である navbar に基準となる設定を追加（すでにある場合は background などはそのままに、以下を追記） */
.navbar {
    position: relative;
}

/* 2. ログインボタンのブロックを画面右端に固定 */
#navAuth {
    position: absolute;
    right: 50px;       /* 画面右端からの好みの余白 */
    top: 50%;          /* 上下中央に配置 */
    transform: translateY(-50%); /* 上下中央のズレを補正 */
}

@media (max-width: 1024px) {
  .footer p{
    font-size: 9px;
  }
}
/* 画面幅が768px以下（スマホ・タブレット等）のときの調整 */
@media (max-width: 768px) {
    #navAuth {
        right: 50px; /* ハンバーガーメニューと被らないように位置を左へずらす */
    }
}
/* ============================================================
   PC表示向け（1025px以上）：メニューを完全中央寄せにする設定
   ============================================================ */
@media (min-width: 1025px) {
  .navbar-container {
    justify-content: space-between;
  }

  /* 2. メニューは自身のサイズを維持して中央に位置させる */
  .nav-menu {
    flex: 0 0 auto;
  }

  /* 3. 前々回に設定した #navAuth の絶対配置を解除し、右側に広げる */
  #navAuth {
    position: static;   /* 絶対配置(absolute)を解除 */
    top: auto;
    right: auto;
    transform: none;    /* 上下中央の補正をリセット */
    
    flex: 1;            /* 左のロゴと同じ重み（幅）を持たせる */
    display: flex;
    justify-content: flex-end; /* ボタンやアカウント情報を右寄せにする */
    gap: 12px;          /* 要素同士の隙間 */
  }
}
    </style>

    <script>
      const hamburger = document.getElementById('hamburger');
      const navMenu = document.getElementById('navMenu');
      const loginBtn = document.getElementById('loginBtn');
      const logoutBtn = document.getElementById('logoutBtn');
      const userInfo = document.getElementById('userInfo');
      const userName = document.getElementById('userName');
      const userRole = document.getElementById('userRole');

      // ============================================================
      // データベース処理に紐づくボタンの二重送信防止（グレーアウト）
      // ============================================================
      document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('form').forEach((form) => {
          form.addEventListener('submit', (e) => {
            if (e.defaultPrevented) return; // すでに別処理でキャンセルされている場合は何もしない

            const submitBtns = form.querySelectorAll(
              'button[type="submit"], input[type="submit"]'
            );

            submitBtns.forEach((btn) => {
              btn.disabled = true;
              if (btn.tagName === 'INPUT') {
                btn.dataset.originalValue = btn.value;
                btn.value = '処理中...';
              } else {
                btn.dataset.originalHtml = btn.innerHTML;
                btn.innerHTML = '処理中...';
              }
            });
          });
        });
      });

      // ログイン状態をチェック（Rails session から取得、サーバーサイド）
      function checkLoginStatus() {
        const userElement = document.querySelector('[data-current-user]');
        const user = userElement ? JSON.parse(userElement.dataset.currentUser) : null;

        if (user) {
          loginBtn.style.display = 'none';
          logoutBtn.style.display = 'inline-block';
          userInfo.style.display = 'inline-flex';
          userName.textContent = user.username;
          const roleText = user.role === 'admin' ? '管理者' : 'メンバー';
          userRole.textContent = roleText;
          userRole.className = `user-role ${user.role === 'admin' ? 'admin' : 'member'}`;
        } else {
          loginBtn.style.display = 'inline-block';
          logoutBtn.style.display = 'none';
          userInfo.style.display = 'none';
        }
      }

      checkLoginStatus();

      logoutBtn.addEventListener('click', () => {
      logoutBtn.disabled = true;            // ← 追加
      logoutBtn.textContent = '処理中...';   // ← 追加
      const form = document.createElement('form');
      form.method = 'POST';
      form.action = '/logout';

      // ← これが抜けていた！
      const csrfInput = document.createElement('input');
      csrfInput.type = 'hidden';
      csrfInput.name = 'authenticity_token';
      csrfInput.value = document.querySelector('[name="csrf-token"]').content;
      form.appendChild(csrfInput);

      const methodInput = document.createElement('input');
      methodInput.type = 'hidden';
      methodInput.name = '_method';
      methodInput.value = 'delete';
      form.appendChild(methodInput);

      document.body.appendChild(form);
      form.submit();
      });

      // ハンバーガーメニュー
      hamburger.addEventListener('click', () => {
        navMenu.classList.toggle('active');
        hamburger.classList.toggle('active');
      });

      document.querySelectorAll('.nav-link').forEach(link => {
        link.addEventListener('click', () => {
          navMenu.classList.remove('active');
          hamburger.classList.remove('active');
        });
      });
    </script>

    <script>
    // ============================================================
    // ドア開放アニメーション
    // 【デバッグモード】判定を無効化し、常にアニメーションを再生する。
    // 本番に戻す際は DEBUG_MODE を false に変えるか、
    // 下の本番用ブロックのコメントを外す。
    // ============================================================
    (function() {
      var overlay = document.getElementById('doorOverlay');
      if (!overlay) return;

      // ▼▼▼ デバッグ用：常に再生（判定をすべてスキップ）▼▼▼
      var DEBUG_MODE = false;
      // ▲▲▲ デバッグ用 ▲▲▲

      if (!DEBUG_MODE) {
        // --- 本番用ロジック（DEBUG_MODE = false のとき有効）---
        var currentHost = window.location.hostname;
        var referrerHost = '';
        try {
          if (document.referrer) {
            referrerHost = new URL(document.referrer).hostname;
          }
        } catch(e) {}

        var isInternalNav = sessionStorage.getItem('site_visited') === '1';
        var isFromSameSite = referrerHost === currentHost;

        if (isInternalNav || isFromSameSite) {
          overlay.classList.add('gone');
          sessionStorage.setItem('site_visited', '1');
          document.documentElement.classList.add('site-visited');
          return;
        }
        sessionStorage.setItem('site_visited', '1');
        // --- /本番用ロジック ---
      }

      // animating クラスを付けるだけ。タイミングは CSS の animation-delay に任せる。
      overlay.classList.add('animating');

      setTimeout(function() {
        overlay.classList.add('hidden');
      }, 2900);

      setTimeout(function() {
        overlay.classList.add('gone');
        document.documentElement.classList.add('site-visited');
      }, 3500);
    })();
    </script>
  </body>
</html>
