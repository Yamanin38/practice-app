<!DOCTYPE html>
<html>
  <head>
    <title>Thrones Site - チームの紹介サイト</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="navbar" <% if current_user %>data-current-user='<%= { username: current_user.username, role: current_user.role }.to_json %>'<% end %>>
  <div class="navbar-container">
    
    <div class="navbar-logo">
      <a href="/">チームサイト</a>
    </div>

    <ul class="nav-menu" id="navMenu">
      <li class="nav-item"><a href="/" class="nav-link <%= 'active' if current_page?('/') %>">ホーム</a></li>
      <li class="nav-item"><a href="/about" class="nav-link <%= 'active' if current_page?('/about') %>">チーム概要</a></li>
      <li class="nav-item"><a href="/gallery" class="nav-link <%= 'active' if current_page?('/gallery') %>">ギャラリー</a></li>
      <li class="nav-item"><a href="/articles" class="nav-link <%= 'active' if current_page?('/articles') %>">活動記録</a></li>
      <li class="nav-item"><a href="/recruitment" class="nav-link <%= 'active' if current_page?('/recruitment') %>">入隊案内</a></li>
      <li class="nav-item"><a href="/rules" class="nav-link <%= 'active' if current_page?('/rules') %>">チーム規約</a></li>
      <li class="nav-item"><a href="/contact" class="nav-link <%= 'active' if current_page?('/contact') %>">お問い合わせ</a></li>
      <li class="nav-item admin-menu" id="adminMenu" style="display: none;">
        <a href="<%= admin_settings_path %>" class="nav-link <%= 'active' if current_page?(admin_settings_path) %>">管理画面</a>
      </li>
    </ul>

    <div class="nav-auth" id="navAuth">
      <a href="<%= login_path %>" class="btn btn-secondary btn-sm" id="loginBtn">ログイン</a>
      <button class="btn btn-secondary btn-sm" id="logoutBtn" style="display: none;">ログアウト</button>
      <span class="user-info" id="userInfo" style="display: none;">
        <span id="userName"></span>
        <span class="user-role" id="userRole"></span>
      </span>
    </div>

    <div class="hamburger" id="hamburger">
      <span></span>
      <span></span>
      <span></span>
    </div>
    
  </div>
</nav>

    <main class="main-content">
      <%= yield %>
    </main>

    <footer class="footer">
      <p>&copy; 2026 Thrones Site. All rights reserved.</p>
    </footer>

    <script>
      const hamburger = document.getElementById('hamburger');
      const navMenu = document.getElementById('navMenu');
      const loginBtn = document.getElementById('loginBtn');
      const logoutBtn = document.getElementById('logoutBtn');
      const userInfo = document.getElementById('userInfo');
      const userName = document.getElementById('userName');
      const userRole = document.getElementById('userRole');
      const adminMenu = document.getElementById('adminMenu');

      // ログイン状態をチェック（Rails session から取得、サーバーサイド）
      function checkLoginStatus() {
        const userElement = document.querySelector('[data-current-user]');
        const user = userElement ? JSON.parse(userElement.dataset.currentUser) : null;

        if (user) {
          loginBtn.style.display = 'none';
          logoutBtn.style.display = 'inline-block';
          userInfo.style.display = 'inline-flex';
          userName.textContent = user.username;
          const roleText = user.role === 'admin' ? '管理者' : 'メンバー';
          userRole.textContent = roleText;
          userRole.className = `user-role ${user.role === 'admin' ? 'admin' : 'member'}`;

          if (user.role === 'admin') {
            // adminMenu.style.display = 'block';
          }
        } else {
          loginBtn.style.display = 'inline-block';
          logoutBtn.style.display = 'none';
          userInfo.style.display = 'none';
          adminMenu.style.display = 'none';
        }
      }

      checkLoginStatus();

      logoutBtn.addEventListener('click', () => {
      const form = document.createElement('form');
      form.method = 'POST';
      form.action = '/logout';

      // ← これが抜けていた！
      const csrfInput = document.createElement('input');
      csrfInput.type = 'hidden';
      csrfInput.name = 'authenticity_token';
      csrfInput.value = document.querySelector('[name="csrf-token"]').content;
      form.appendChild(csrfInput);

      const methodInput = document.createElement('input');
      methodInput.type = 'hidden';
      methodInput.name = '_method';
      methodInput.value = 'delete';
      form.appendChild(methodInput);

      document.body.appendChild(form);
      form.submit();
      });

      // ハンバーガーメニュー
      hamburger.addEventListener('click', () => {
        navMenu.classList.toggle('active');
        hamburger.classList.toggle('active');
      });

      document.querySelectorAll('.nav-link').forEach(link => {
        link.addEventListener('click', () => {
          navMenu.classList.remove('active');
          hamburger.classList.remove('active');
        });
      });
    </script>
  </body>
</html>
