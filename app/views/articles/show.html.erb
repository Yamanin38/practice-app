<div class="container main-content">
  
  <div style="margin-bottom: 24px; display: flex; gap: 12px;">
    <%= link_to "◀ トップページ", root_path, class: "btn btn-secondary btn-sm" %>
    <%= link_to "◀ 活動記録一覧", articles_path, class: "btn btn-secondary btn-sm" %>
  </div>

  <article class="page-content" style="padding: 40px;">
    
    <header style="margin-bottom: 30px; border-bottom: 1px solid var(--clr-border); padding-bottom: 20px;">
      
      <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px;">
        <span class="user-role member">
          <%= @article.user.username %>
        </span>
        <span style="color: var(--clr-text-muted); font-size: 14px; font-family: monospace;">
          <%= @article.created_at.strftime('%Y/%m/%d %H:%M') %>
        </span>
      </div>
      
      <h1 style="font-family: var(--font-heading); color: #2e1a00; font-size: 32px; line-height: 1.4; margin-bottom: 16px; text-shadow: 0 1px 1px rgba(255,255,255,0.8);">
        <%= @article.title %>
      </h1>

      <%# 修正: any? を削除し、present? だけで文字が存在するか判定します %>
      <% if @article.tags.present? %>
        <div style="display: flex; flex-wrap: wrap; gap: 8px;">
          
          <%# 修正: 文字列をカンマ(,)で分割して、1つずつ取り出します %>
          <% @article.tags.split(',').each do |tag_name| %>
            
            <%# 余白を削り、空っぽのタグがあればスキップする安全対策 %>
            <% cleaned_tag = tag_name.strip %>
            <% next if cleaned_tag.blank? %>
            
            <span style="background: rgba(184, 114, 10, 0.15); color: #5a3510; border: 1px solid rgba(184, 114, 10, 0.4); padding: 4px 10px; border-radius: var(--radius-sm); font-size: 12px; font-weight: 700;">
              #<%= cleaned_tag %>
            </span>
          <% end %>
          
        </div>
      <% end %>
    </header>

    <%# 修正1: attached? ではなく、データが存在するかを any? で判定します %>
    <% if @article.images.any? %>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; margin-bottom: 36px;">
        <% @article.images.each do |image| %>
          <div style="border: 1px solid var(--clr-border); border-radius: var(--radius-sm); overflow: hidden; box-shadow: var(--shadow-inset); background: #120a00;">
            
            <% if image.file_attachment.present? %>
              <%# onclickを追加し、クリック時に画像のURL(this.src)をモーダルに渡す %>
              <%= image_tag image.file_attachment, 
                    style: "width: 100%; height: 200px; object-fit: cover; display: block; cursor: zoom-in; transition: filter 0.2s;", 
                    onmouseover: "this.style.filter='brightness(1.15)'",
                    onmouseout: "this.style.filter='brightness(1)'",
                    onclick: "openImageModal(this.src)" %>
            <% end %>
            
          </div>
        <% end %>
      </div>
    <% end %>

    <div class="markdown-body">
      <%# コントローラで変換したHTMLを安全に出力 %>
      <%= @html_content.html_safe %>
    </div>

    <% if current_user %>
      <div class="form-actions" style="margin-top: 60px; padding-top: 24px; border-top: 1px dashed var(--clr-border); justify-content: flex-end;">
        <button type="button" class="btn btn-primary" onclick="openEditModal()">この活動記録を編集</button>
        <% if current_user.admin? %>
          <button type="button" class="btn btn-danger"
            onclick="openDeleteConfirmModal()">削除する</button>
        <% end %>
      </div>
    <% end %>
    
  </article>
</div>

<div id="editArticleModal" class="modal-overlay" style="display: none;">
  <div class="modal-wrapper">
    <div class="modal-header-custom">
      <h2>活動記録の編集</h2>
      <span class="modal-close-custom" onclick="closeEditModal()">&times;</span>
    </div>
    
    <%# すでにコントローラにある update アクションへデータを送信します %>
    <%# フォーム本体 %>
    <%= form_with model: @article, local: true do |f| %>
      <div class="form-group" style="margin-bottom: 16px;">
        <%= f.label :title, "タイトル", style: "display: block; margin-bottom: 6px; color: var(--clr-text);" %>
        <%= f.text_field :title, class: "form-control", style: "width: 100%; padding: 10px; background: #fff; border: 1px solid var(--clr-border); border-radius: var(--radius-sm); color: #333;", required: true, placeholder: "タイトル(40字以内)", data: { maxweight: 40 } %>
      </div>

      <div class="form-group" style="margin-bottom: 16px;">
        <%= f.label :content, "本文 (Markdown)", style: "display: block; margin-bottom: 6px; color: var(--clr-text);" %>
        <%# ⭕ 修正: resize: vertical; を追加し、横方向への拡大を禁止 %>
        <%= f.text_area :content, rows: 12, class: "form-control", style: "width: 100%; padding: 10px; background: #fff; border: 1px solid var(--clr-border); border-radius: var(--radius-sm); font-family: monospace; color: #333; resize: vertical;", required: true, placeholder: "本文(2000字以内)", data: { maxweight: 2000 } %>
      </div>

      <div class="form-group" style="margin-bottom: 16px;">
        <%= f.label :tags, "タグ (カンマ区切り)", style: "display: block; margin-bottom: 6px; color: var(--clr-text);" %>
        <%= f.text_field :tags, class: "form-control", style: "width: 100%; padding: 10px; background: #fff; border: 1px solid var(--clr-border); border-radius: var(--radius-sm); color: #333;", placeholder: "例: 日記, お知らせ" %>
      </div>

      <div class="form-group" style="margin-bottom: 24px;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px;">
          <label style="color: var(--clr-text); margin: 0;">添付画像 (最大4枚)</label>
          
          <div class="filter-section" style="position: relative;">
            <button type="button" class="btn-cal-toggle" id="calToggleBtn" style="padding: 4px 10px; font-size: 12px;">
              📅 <span id="calToggleText">日付で絞り込む</span>
            </button>
            <div class="calendar-filter" id="calendarFilter" style="display:none; position: absolute; bottom: 100%; right: 0; width: 260px; margin-bottom: 8px; z-index: 10001;">
              <div class="calendar-header">
                <button type="button" class="cal-nav" id="calPrev">&#8249;</button>
                <span class="cal-title" id="calTitle">
                  <select id="calYearSelect" class="cal-year-select"></select>
                  <span id="calMonthText"></span>
                </span>
                <button type="button" class="cal-nav" id="calNext">&#8250;</button>
              </div>
              <div class="calendar-weekdays">
                <span>日</span><span>月</span><span>火</span><span>水</span><span>木</span><span>金</span><span>土</span>
              </div>
              <div class="calendar-days" id="calendarDays"></div>
              <input type="hidden" id="calSelectedDate" value="">
              <div class="calendar-actions">
                <button type="button" class="btn-cal-clear" id="calClear">すべて表示</button>
              </div>
            </div>
          </div>
        </div>
        
        <div class="image-selector-container" style="display: flex; gap: 10px; overflow-x: auto; padding: 4px 0;">
          <% if @all_images.present? %>
            <% @all_images.each do |image| %>
              <% is_checked = @article.images.include?(image) %>
              
              <label class="image-checkbox-label" data-date="<%= image.created_at.strftime('%Y-%m-%d') %>" style="cursor: pointer; position: relative; flex-shrink: 0;">
                <input type="checkbox" name="image_ids[]" value="<%= image.id %>" 
                       <%= 'checked' if is_checked %> 
                       style="display: none;"
                       onchange="toggleImageSelect(this)">
                
                <div class="image-thumbnail" style="width: 80px; height: 80px; border-radius: 4px; overflow: hidden; border: <%= is_checked ? '3px solid var(--clr-primary, #e8a820)' : '1px solid var(--clr-border)' %>; opacity: <%= is_checked ? '1' : '0.5' %>; transition: all 0.2s;">
                  <% if image.file_attachment.present? %>
                    <%= image_tag image.file_attachment, style: "width: 100%; height: 100%; object-fit: cover; display: block;" %>
                  <% end %>
                </div>
              </label>
            <% end %>
          <% else %>
            <p style="color: var(--clr-text-muted); font-size: 14px;">選択できる画像がありません。</p>
          <% end %>
        </div>
      </div>

      <div class="form-actions" style="display: flex; gap: 12px; justify-content: flex-end; border-top: none; padding-top: 0; margin-top: 0;">
        <button type="button" class="btn btn-secondary" onclick="closeEditModal()">キャンセル</button>
        <%= f.submit "変更を保存する", class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>

<div id="imageLightbox" class="lightbox-overlay" onclick="closeImageModal()">
  <span class="lightbox-close">&times;</span>
  <img id="lightboxImage" class="lightbox-content">
</div>

<!-- 削除確認モーダル -->
<div id="deleteConfirmModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,.75); backdrop-filter: blur(6px); z-index: 2000; align-items: center; justify-content: center;">
  <div style="background: var(--clr-surface); border: 1px solid var(--clr-border-lite); border-radius: var(--radius-lg); width: 90%; max-width: 420px; box-shadow: 0 20px 60px rgba(0,0,0,.9); animation: slideDown .3s ease;">
    <div style="display: flex; align-items: center; justify-content: space-between; padding: 16px 22px; border-bottom: 1px solid var(--clr-border); background: var(--clr-surface-3); border-radius: var(--radius-lg) var(--radius-lg) 0 0;">
      <h2 style="font-family: var(--font-heading); margin: 0; font-size: 1.05rem; color: var(--clr-gold-light);">🗑️ 削除の確認</h2>
      <button id="closeDeleteConfirmModal" style="background: none; border: none; font-size: 1.5rem; color: var(--clr-text-muted); cursor: pointer; line-height: 1; padding: 3px 7px;">&times;</button>
    </div>
    <div style="padding: 24px 28px;">
      <p style="color: var(--clr-text); margin-bottom: 24px;">本当にこの活動記録を削除しますか？<br>元に戻すことはできません。</p>
      <div style="display: flex; gap: 12px; justify-content: flex-end;">
        <button class="btn btn-secondary" id="cancelDeleteBtn">キャンセル</button>
        <%= button_to "削除する", article_path(@article), method: :delete, class: "btn btn-danger", form: { style: "margin: 0;" } %>
      </div>
    </div>
  </div>
</div>
<style>
  /* ライトボックスの背景（扉アニメーションの上に来るようz-indexを高めに設定） */
  .lightbox-overlay {
    display: none;
    position: fixed;
    z-index: 10000;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(18, 10, 0, 0.85); /* ダークブラウンの半透明 */
    backdrop-filter: blur(4px); /* 背景を少しぼかす */
    cursor: zoom-out;
  }

  /* 拡大された実際の画像 */
  .lightbox-content {
    margin: auto;
    display: block;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    max-width: 95%;
    max-height: 95vh;
    object-fit: contain; /* 縦横比を崩さずに全体を表示 */
    border: 2px solid var(--clr-border-lite, #5a3510);
    box-shadow: 0 0 30px rgba(0,0,0,0.9);
    border-radius: 4px;
    animation: fadeIn 0.3s ease;
  }

  /* 閉じるボタン */
  .lightbox-close {
    position: absolute;
    top: 20px;
    right: 40px;
    color: #ffebc2;
    font-size: 40px;
    font-family: sans-serif;
    font-weight: bold;
    cursor: pointer;
    transition: color 0.2s;
  }
  .lightbox-close:hover {
    color: #fff;
  }

  /* モーダルの背景（暗転エリア） */
  .modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(18, 10, 0, 0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(3px);
  }

  /* モーダル本体のウインドウ */
  .modal-wrapper {
    background: var(--clr-surface-2, #2e1a00);
    border: 2px solid var(--clr-border);
    border-radius: var(--radius-sm);
    padding: 24px;
    width: 90%;
    max-width: 650px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.6);
    animation: modalSlideUp 0.25s ease-out;
    position: relative;
    display: flex;
  flex-direction: column;
  max-height: 90vh;
  }

  .modal-wrapper form {
  overflow-y: auto;
  flex: 1;
  margin: 0 -24px -24px;
  padding: 0 24px 24px;
}

  .modal-header-custom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--clr-border-lite);
    padding-bottom: 12px;
    margin-bottom: 20px;
  }

  .modal-header-custom h2 {
    margin: 0;
    font-size: 16px;
    color: var(--clr-gold-light);
    font-family: var(--font-heading);
    letter-spacing: 0.05em;
  }

  .modal-close-custom {
    font-size: 28px;
    cursor: pointer;
    color: var(--clr-text-muted);
    line-height: 1;
  }

  .modal-close-custom:hover {
    color: var(--clr-gold-light);
  }

  #articleModal .modal-content,
#editArticleModal .modal-content {
  position: relative;
  display: flex;             /* 追加: 内部をFlexboxにする */
  flex-direction: column;    /* 追加: 縦並びにする */
  max-height: 90vh;          /* 追加: モーダルの最大高さを画面の90%に制限 */
}

  @keyframes modalSlideUp {
    from { opacity: 0; transform: translateY(15px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translate(-50%, -48%); }
    to { opacity: 1; transform: translate(-50%, -50%); }
  }

  /* ======== カレンダー機能のスタイル ======== */
  .btn-cal-toggle {
    background: linear-gradient(180deg, #3a2108 0%, #241400 100%);
    border: 1px solid #5a3510;
    border-radius: 6px;
    font-weight: 700;
    cursor: pointer;
    color: #e8a820;
    box-shadow: 0 1px 0 rgba(255,200,80,.12) inset, 0 3px 8px rgba(0,0,0,.5), 0 1px 0 rgba(0,0,0,.7);
    transition: filter 0.2s ease;
    white-space: nowrap;
  }
  .btn-cal-toggle:hover { filter: brightness(1.2); border-color: #c8820a; }
  .btn-cal-toggle.active {
    background: linear-gradient(180deg, #c8820a 0%, #7a4800 100%);
    border-color: #6a3e00; color: #fff8e0;
  }
  .calendar-filter {
    background: linear-gradient(180deg, #2e1a00 0%, #1e1000 100%);
    border: 1px solid #5a3510; border-radius: 8px; padding: 14px; width: 280px;
    box-shadow: 0 8px 24px rgba(0,0,0,.7), inset 0 1px 0 rgba(255,200,80,.12);
  }
  .calendar-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
  .cal-title { font-weight: 700; font-size: 15px; color: #e8a820; position: absolute; left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  pointer-events: none; /* 矢印がクリックできなくなるのを防ぐ */
  /* 追加: これにより中身の要素（年と月）が強制的に横並びになります */
  white-space: nowrap;}
  .cal-nav {
    background: linear-gradient(180deg, #3a2108 0%, #241400 100%);
    border: 1px solid #5a3510; border-radius: 4px; font-size: 18px;
    cursor: pointer; color: #e8a820; padding: 2px 10px;
  }
  .cal-nav:hover { filter: brightness(1.3); }
  .calendar-weekdays { display: grid; grid-template-columns: repeat(7, 1fr); text-align: center; font-size: 12px; color: #7a5030; margin-bottom: 4px; }
  .calendar-weekdays span:first-child { color: #c05040; }
  .calendar-weekdays span:last-child { color: #8090c0; }
  .calendar-days { display: grid; grid-template-columns: repeat(7, 1fr); gap: 2px; }
  .cal-day { aspect-ratio: 1; display: flex; align-items: center; justify-content: center; font-size: 13px; border-radius: 50%; color: #4a3020; cursor: default; }
  .cal-day.has-image { color: #e8d5b0; cursor: pointer; font-weight: 700; }
  .cal-day.has-image:hover { background: rgba(200,130,10,.25); color: #e8a820; }
  .cal-day.selected { background: linear-gradient(135deg, #c8820a, #7a4800); color: #fff8e0 !important; }
  .cal-day.today { border: 1px solid #c8820a; }
  .calendar-actions { display: flex; gap: 8px; margin-top: 10px; justify-content: flex-end; }
  .btn-cal-clear {
    background: linear-gradient(180deg, #3a2108 0%, #241400 100%); border: 1px solid #5a3510;
    border-radius: 4px; padding: 6px 14px; font-size: 13px; color: #a08060; cursor: pointer;
  }
  .btn-cal-clear:hover { filter: brightness(1.3); color: #e8d5b0; }
  
  .cal-year-select {
    background-color: transparent; color: inherit; border: 1px solid #7a4818;
    border-radius: 4px; padding: 2px 24px 2px 8px; font-weight: bold; cursor: pointer;
    appearance: none;
    background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23e8a820' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
    background-repeat: no-repeat; background-position: right 4px center; background-size: 14px;
    text-align: center;         /* 一部のブラウザ用 */
  text-align-last: center;    /* select内のテキストを中央寄せにする主要プロパティ */
  padding: 2px 24px 2px 8px;  /* 既存のパディング */
  }
  .cal-year-select option { background-color: #3a2108; color: #e8d5b0; }
  .cal-year-select, #artCalMonthText, #calMonthText {
  pointer-events: auto;
}
.cal-nav {
  z-index: 1; /* 矢印をタイトルより前面に */
}
#calMonthText {
  margin-left: 6px;
}
</style>

<script>
  // 画像を開く処理
  function openImageModal(imageSrc) {
    var modal = document.getElementById("imageLightbox");
    var expandedImg = document.getElementById("lightboxImage");
    modal.style.display = "block";
    expandedImg.src = imageSrc; // クリックされた画像のURLをセット
    document.body.style.overflow = "hidden"; // 背景のスクロールを止める
  }

  // 画像を閉じる処理
  function closeImageModal() {
    var modal = document.getElementById("imageLightbox");
    modal.style.display = "none";
    document.body.style.overflow = "auto"; // スクロールを再開
  }

  function openEditModal() {
    document.getElementById("editArticleModal").style.display = "flex";
    document.body.style.overflow = "hidden"; // 背面のスクロールを固定
  }

  function closeEditModal() {
    document.getElementById("editArticleModal").style.display = "none";
    document.body.style.overflow = "auto"; // スクロールを戻す
  }

  document.addEventListener("DOMContentLoaded", function() {
  // URLのクエリパラメータ（?edit=true など）を取得
  const urlParams = new URLSearchParams(window.location.search);
  
  // もし edit パラメータが 'true' だったら、編集モーダルを開く
  if (urlParams.get('edit') === 'true') {
    if (typeof openEditModal === "function") {
      openEditModal();
      
      // 任意：URLから「?edit=true」の見た目を消したい場合は、以下の1行を入れると綺麗になります
      const cleanUrl = window.location.protocol + "//" + window.location.host + window.location.pathname;
      window.history.replaceState({ path: cleanUrl }, '', cleanUrl);
    }
  }
});

  // 画像選択のチェックボックスを切り替えたときのスタイル変更
  function toggleImageSelect(checkbox) {
    var thumbnail = checkbox.nextElementSibling; // 隣の div.image-thumbnail を取得
    
    // 4枚制限の簡易チェック（任意）
    var checkedBoxes = document.querySelectorAll('input[name="image_ids[]"]:checked');
    if (checkedBoxes.length > 4) {
      alert("画像は最大4枚までしか選択できません。");
      checkbox.checked = false;
      return;
    }

    if (checkbox.checked) {
      thumbnail.style.border = "3px solid var(--clr-primary, #e8a820)"; // 選択時は目立たせる
      thumbnail.style.opacity = "1";
    } else {
      thumbnail.style.border = "1px solid var(--clr-border)";
      thumbnail.style.opacity = "0.5"; // 非選択時は少し暗く
    }
  }

  // ======== ここからカレンダー絞り込みの処理 ========
  document.addEventListener('DOMContentLoaded', () => {
    const calendarFilter = document.getElementById('calendarFilter');
    const calToggleBtn = document.getElementById('calToggleBtn');

    // ── 文字数カウント（半角0.5文字換算） ──
    function calcWeight(str) {
      let weight = 0;
      for (const ch of str) {
        weight += /[\x00-\x7F]/.test(ch) ? 0.5 : 1;
      }
      return weight;
    }

    document.querySelectorAll('[data-maxweight]').forEach(input => {
      const max = parseFloat(input.dataset.maxweight);
      input.addEventListener('input', () => {
        const weight = calcWeight(input.value);
        if (weight > max) {
          let trimmed = '', total = 0;
          for (const ch of input.value) {
            const w = /[\x00-\x7F]/.test(ch) ? 0.5 : 1;
            if (total + w > max) break;
            trimmed += ch;
            total += w;
          }
          input.value = trimmed;
        }
      });
    });
    
    // UIが存在しないページの場合は実行しない
    if (!calendarFilter || !calToggleBtn) return;

    // @all_images から画像が存在する日付のリスト（重複なし）を生成
    const uploadDates = <%= raw @all_images.map { |img| img.created_at.strftime('%Y-%m-%d') }.uniq.to_json %>;
    const uploadDateSet = new Set(uploadDates);

    let calYear, calMonth;
    const today = new Date();
    const selectedDateInput = document.getElementById('calSelectedDate');

    calYear = today.getFullYear();
    calMonth = today.getMonth();

    const yearSelect = document.getElementById('calYearSelect');
    for (let y = 2026; y <= today.getFullYear() + 10; y++) {
      const option = document.createElement('option');
      option.value = y;
      option.text = y + '年';
      yearSelect.appendChild(option);
    }

    yearSelect.addEventListener('change', function() {
      calYear = parseInt(this.value); 
      renderCalendar();
    });

    function renderCalendar() {
      const daysEl = document.getElementById('calendarDays');
      document.getElementById('calYearSelect').value = calYear;
      document.getElementById('calMonthText').textContent = `${calMonth + 1}月`;
      daysEl.innerHTML = '';

      const firstDay = new Date(calYear, calMonth, 1).getDay();
      const daysInMonth = new Date(calYear, calMonth + 1, 0).getDate();
      const selectedVal = selectedDateInput.value;

      document.getElementById('calToggleText').textContent = selectedVal ? selectedVal : '日付で絞り込む';

      for (let i = 0; i < firstDay; i++) {
        const blank = document.createElement('div');
        blank.className = 'cal-day';
        daysEl.appendChild(blank);
      }

      for (let d = 1; d <= daysInMonth; d++) {
        const dateStr = `${calYear}-${String(calMonth + 1).padStart(2, '0')}-${String(d).padStart(2, '0')}`;
        const div = document.createElement('div');
        div.className = 'cal-day';
        div.textContent = d;

        if (uploadDateSet.has(dateStr)) {
          div.classList.add('has-image');
          div.addEventListener('click', (e) => {
            e.stopPropagation();
            selectedDateInput.value = dateStr;
            renderCalendar();
            filterImagesByDate(dateStr); // 絞り込み実行
            calendarFilter.style.display = 'none';
            calToggleBtn.classList.remove('active');
          });
        }

        if (dateStr === selectedVal) div.classList.add('selected');

        const todayStr = `${today.getFullYear()}-${String(today.getMonth() + 1).padStart(2, '0')}-${String(today.getDate()).padStart(2, '0')}`;
        if (dateStr === todayStr) div.classList.add('today');

        daysEl.appendChild(div);
      }
      // ───【ここを追加】───
      // 常に6行（7列 × 6行 = 42マス）分の高さを維持するため、月末の足りない分を空白で埋める
      const currentCells = firstDay + daysInMonth;
      for (let i = currentCells; i < 42; i++) {
        const blank = document.createElement('div');
        blank.className = 'cal-day';
        daysEl.appendChild(blank);
      }
      // ─────────────────────
    }

    // 表示切り替えロジック（AjaxではなくDOMの表示・非表示を切り替える）
    function filterImagesByDate(dateStr) {
      const labels = document.querySelectorAll('.image-checkbox-label');
      
      labels.forEach(label => {
        // 対象の日付と一致するか、日付指定がない(クリア状態)なら表示する
        if (!dateStr || label.dataset.date === dateStr) {
          label.style.display = '';
        } else {
          label.style.display = 'none';
        }
      });
    }

    document.getElementById('calPrev').addEventListener('click', () => {
      calMonth--;
      if (calMonth < 0) { calMonth = 11; calYear--; }
      renderCalendar();
    });

    document.getElementById('calNext').addEventListener('click', () => {
      calMonth++;
      if (calMonth > 11) { calMonth = 0; calYear++; }
      renderCalendar();
    });

    // クリアボタン
    document.getElementById('calClear').addEventListener('click', () => {
      selectedDateInput.value = '';
      renderCalendar();
      filterImagesByDate(''); // 全て表示
      calendarFilter.style.display = 'none';
      calToggleBtn.classList.remove('active');
    });

    calToggleBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = calendarFilter.style.display !== 'none';
      calendarFilter.style.display = isOpen ? 'none' : 'block';
      calToggleBtn.classList.toggle('active', !isOpen);
    });

    document.addEventListener('click', (e) => {
      if (!calendarFilter.contains(e.target) && e.target !== calToggleBtn) {
        calendarFilter.style.display = 'none';
        calToggleBtn.classList.remove('active');
      }
    });

    renderCalendar();
  });


// 変更後
function openDeleteConfirmModal() {
  const modal = document.getElementById('deleteConfirmModal');
  modal.style.display = 'flex';
  document.body.style.overflow = 'hidden';
}

document.getElementById('closeDeleteConfirmModal').addEventListener('click', () => {
  document.getElementById('deleteConfirmModal').style.display = 'none';
  document.body.style.overflow = '';
});

document.getElementById('cancelDeleteBtn').addEventListener('click', () => {
  document.getElementById('deleteConfirmModal').style.display = 'none';
  document.body.style.overflow = '';
});

</script>