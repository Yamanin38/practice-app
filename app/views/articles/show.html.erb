<div class="container main-content">
  
  <div style="margin-bottom: 24px; display: flex; gap: 12px;">
    <%= link_to "◀ トップページ", root_path, class: "btn btn-secondary btn-sm" %>
    <%= link_to "◀ 記事一覧", articles_path, class: "btn btn-secondary btn-sm" %>
  </div>

  <article class="page-content" style="padding: 40px;">
    
    <header style="margin-bottom: 30px; border-bottom: 1px solid var(--clr-border); padding-bottom: 20px;">
      
      <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px;">
        <span class="user-role member">
          <%= @article.user.username %>
        </span>
        <span style="color: var(--clr-text-muted); font-size: 14px; font-family: monospace;">
          <%= @article.created_at.strftime('%Y/%m/%d %H:%M') %>
        </span>
      </div>
      
      <h1 style="font-family: var(--font-heading); color: #2e1a00; font-size: 32px; line-height: 1.4; margin-bottom: 16px; text-shadow: 0 1px 1px rgba(255,255,255,0.8);">
        <%= @article.title %>
      </h1>

      <%# 修正: any? を削除し、present? だけで文字が存在するか判定します %>
      <% if @article.tags.present? %>
        <div style="display: flex; flex-wrap: wrap; gap: 8px;">
          
          <%# 修正: 文字列をカンマ(,)で分割して、1つずつ取り出します %>
          <% @article.tags.split(',').each do |tag_name| %>
            
            <%# 余白を削り、空っぽのタグがあればスキップする安全対策 %>
            <% cleaned_tag = tag_name.strip %>
            <% next if cleaned_tag.blank? %>
            
            <span style="background: rgba(184, 114, 10, 0.15); color: #5a3510; border: 1px solid rgba(184, 114, 10, 0.4); padding: 4px 10px; border-radius: var(--radius-sm); font-size: 12px; font-weight: 700;">
              #<%= cleaned_tag %>
            </span>
          <% end %>
          
        </div>
      <% end %>
    </header>

    <%# 修正1: attached? ではなく、データが存在するかを any? で判定します %>
    <% if @article.images.any? %>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; margin-bottom: 36px;">
        <% @article.images.each do |image| %>
          <div style="border: 1px solid var(--clr-border); border-radius: var(--radius-sm); overflow: hidden; box-shadow: var(--shadow-inset); background: #120a00;">
            
            <% if image.file_attachment.present? %>
              <%# onclickを追加し、クリック時に画像のURL(this.src)をモーダルに渡す %>
              <%= image_tag image.file_attachment, 
                    style: "width: 100%; height: 200px; object-fit: cover; display: block; cursor: zoom-in; transition: filter 0.2s;", 
                    onmouseover: "this.style.filter='brightness(1.15)'",
                    onmouseout: "this.style.filter='brightness(1)'",
                    onclick: "openImageModal(this.src)" %>
            <% end %>
            
          </div>
        <% end %>
      </div>
    <% end %>

    <div class="markdown-body">
      <%# コントローラで変換したHTMLを安全に出力 %>
      <%= @html_content.html_safe %>
    </div>

    <% if current_user && (current_user == @article.user || current_user.admin?) %>
      <div class="form-actions" style="margin-top: 60px; padding-top: 24px; border-top: 1px dashed var(--clr-border); justify-content: flex-end;">
        <button type="button" class="btn btn-primary" onclick="openEditModal()">この記事を編集</button>
        <%= button_to "削除する", article_path(@article), method: :delete, data: { turbo_confirm: "この記事を削除しますか？\n元に戻すことはできません。" }, class: "btn btn-danger" %>
      </div>
    <% end %>
    
  </article>
</div>

<div id="editArticleModal" class="modal-overlay" style="display: none;">
  <div class="modal-wrapper">
    <div class="modal-header-custom">
      <h2>記事の編集</h2>
      <span class="modal-close-custom" onclick="closeEditModal()">&times;</span>
    </div>
    
    <%# すでにコントローラにある update アクションへデータを送信します %>
    <%# フォーム本体 %>
    <%= form_with model: @article, local: true do |f| %>
      <div class="form-group" style="margin-bottom: 16px;">
        <%= f.label :title, "タイトル", style: "display: block; margin-bottom: 6px; color: var(--clr-text);" %>
        <%= f.text_field :title, class: "form-control", style: "width: 100%; padding: 10px; background: #fff; border: 1px solid var(--clr-border); border-radius: var(--radius-sm); color: #333;" %>
      </div>

      <div class="form-group" style="margin-bottom: 16px;">
        <%= f.label :content, "本文 (Markdown)", style: "display: block; margin-bottom: 6px; color: var(--clr-text);" %>
        <%# ⭕ 修正: resize: vertical; を追加し、横方向への拡大を禁止 %>
        <%= f.text_area :content, rows: 12, class: "form-control", style: "width: 100%; padding: 10px; background: #fff; border: 1px solid var(--clr-border); border-radius: var(--radius-sm); font-family: monospace; color: #333; resize: vertical;" %>
      </div>

      <div class="form-group" style="margin-bottom: 16px;">
        <%= f.label :tags, "タグ (カンマ区切り)", style: "display: block; margin-bottom: 6px; color: var(--clr-text);" %>
        <%= f.text_field :tags, class: "form-control", style: "width: 100%; padding: 10px; background: #fff; border: 1px solid var(--clr-border); border-radius: var(--radius-sm); color: #333;", placeholder: "例: 日記, お知らせ" %>
      </div>

      <div class="form-group" style="margin-bottom: 24px;">
        <label style="display: block; margin-bottom: 6px; color: var(--clr-text);">添付画像 (最大4枚)</label>
        
        <div class="image-selector-container" style="display: flex; gap: 10px; overflow-x: auto; padding: 4px 0;">
          <% if @all_images.present? %>
            <% @all_images.each do |image| %>
              <%# 既にこの記事に紐付いている画像か判定 %>
              <% is_checked = @article.images.include?(image) %>
              
              <label class="image-checkbox-label" style="cursor: pointer; position: relative; flex-shrink: 0;">
                <input type="checkbox" name="image_ids[]" value="<%= image.id %>" 
                       <%= 'checked' if is_checked %> 
                       style="display: none;" 
                       onchange="toggleImageSelect(this)">
                
                <div class="image-thumbnail" style="width: 80px; height: 80px; border-radius: 4px; overflow: hidden; border: <%= is_checked ? '3px solid var(--clr-primary, #e8a820)' : '1px solid var(--clr-border)' %>; opacity: <%= is_checked ? '1' : '0.5' %>; transition: all 0.2s;">
                  <% if image.file_attachment.present? %>
                    <%= image_tag image.file_attachment, style: "width: 100%; height: 100%; object-fit: cover; display: block;" %>
                  <% end %>
                </div>
              </label>
            <% end %>
          <% else %>
            <p style="color: var(--clr-text-muted); font-size: 14px;">選択できる画像がありません。</p>
          <% end %>
        </div>
      </div>

      <div class="form-actions" style="display: flex; gap: 12px; justify-content: flex-end; border-top: none; padding-top: 0; margin-top: 0;">
        <button type="button" class="btn btn-secondary" onclick="closeEditModal()">キャンセル</button>
        <%= f.submit "変更を保存する", class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>

<div id="imageLightbox" class="lightbox-overlay" onclick="closeImageModal()">
  <span class="lightbox-close">&times;</span>
  <img id="lightboxImage" class="lightbox-content">
</div>

<style>
  /* ライトボックスの背景（扉アニメーションの上に来るようz-indexを高めに設定） */
  .lightbox-overlay {
    display: none;
    position: fixed;
    z-index: 10000;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(18, 10, 0, 0.85); /* ダークブラウンの半透明 */
    backdrop-filter: blur(4px); /* 背景を少しぼかす */
    cursor: zoom-out;
  }

  /* 拡大された実際の画像 */
  .lightbox-content {
    margin: auto;
    display: block;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    max-width: 95%;
    max-height: 95vh;
    object-fit: contain; /* 縦横比を崩さずに全体を表示 */
    border: 2px solid var(--clr-border-lite, #5a3510);
    box-shadow: 0 0 30px rgba(0,0,0,0.9);
    border-radius: 4px;
    animation: fadeIn 0.3s ease;
  }

  /* 閉じるボタン */
  .lightbox-close {
    position: absolute;
    top: 20px;
    right: 40px;
    color: #ffebc2;
    font-size: 40px;
    font-family: sans-serif;
    font-weight: bold;
    cursor: pointer;
    transition: color 0.2s;
  }
  .lightbox-close:hover {
    color: #fff;
  }

  /* モーダルの背景（暗転エリア） */
  .modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(18, 10, 0, 0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(3px);
  }

  /* モーダル本体のウインドウ */
  .modal-wrapper {
    background: var(--clr-surface-2, #2e1a00);
    border: 2px solid var(--clr-border);
    border-radius: var(--radius-sm);
    padding: 24px;
    width: 90%;
    max-width: 650px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.6);
    animation: modalSlideUp 0.25s ease-out;
  }

  .modal-header-custom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--clr-border-lite);
    padding-bottom: 12px;
    margin-bottom: 20px;
  }

  .modal-header-custom h2 {
    margin: 0;
    font-size: 16px;
    color: var(--clr-gold-light);
    font-family: var(--font-heading);
    letter-spacing: 0.05em;
  }

  .modal-close-custom {
    font-size: 28px;
    cursor: pointer;
    color: var(--clr-text-muted);
    line-height: 1;
  }

  .modal-close-custom:hover {
    color: var(--clr-gold-light);
  }

  @keyframes modalSlideUp {
    from { opacity: 0; transform: translateY(15px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translate(-50%, -48%); }
    to { opacity: 1; transform: translate(-50%, -50%); }
  }
</style>

<script>
  // 画像を開く処理
  function openImageModal(imageSrc) {
    var modal = document.getElementById("imageLightbox");
    var expandedImg = document.getElementById("lightboxImage");
    modal.style.display = "block";
    expandedImg.src = imageSrc; // クリックされた画像のURLをセット
    document.body.style.overflow = "hidden"; // 背景のスクロールを止める
  }

  // 画像を閉じる処理
  function closeImageModal() {
    var modal = document.getElementById("imageLightbox");
    modal.style.display = "none";
    document.body.style.overflow = "auto"; // スクロールを再開
  }

  function openEditModal() {
    document.getElementById("editArticleModal").style.display = "flex";
    document.body.style.overflow = "hidden"; // 背面のスクロールを固定
  }

  function closeEditModal() {
    document.getElementById("editArticleModal").style.display = "none";
    document.body.style.overflow = "auto"; // スクロールを戻す
  }

  // 画像選択のチェックボックスを切り替えたときのスタイル変更
  function toggleImageSelect(checkbox) {
    var thumbnail = checkbox.nextElementSibling; // 隣の div.image-thumbnail を取得
    
    // 4枚制限の簡易チェック（任意）
    var checkedBoxes = document.querySelectorAll('input[name="image_ids[]"]:checked');
    if (checkedBoxes.length > 4) {
      alert("画像は最大4枚までしか選択できません。");
      checkbox.checked = false;
      return;
    }

    if (checkbox.checked) {
      thumbnail.style.border = "3px solid var(--clr-primary, #e8a820)"; // 選択時は目立たせる
      thumbnail.style.opacity = "1";
    } else {
      thumbnail.style.border = "1px solid var(--clr-border)";
      thumbnail.style.opacity = "0.5"; // 非選択時は少し暗く
    }
  }

</script>