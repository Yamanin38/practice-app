<div class="container">
  <header class="page-header">
    <h1>記事</h1>
    <p>チームの活動記録と思い出</p>
  </header>

  <div class="page-content">
    <div class="articles-actions">
      <% if current_user %>
        <button class="btn btn-primary" id="newArticleBtn">新しい記事を投稿</button>
      <% end %>
      <div class="filter-section">
        <input type="text" placeholder="記事を検索..." id="searchArticles" class="search-input">
      </div>
    </div>

    <div class="articles-list" id="articlesList">
      <% if @articles.any? %>
        <% @articles.each do |article| %>
          <div class="article-card" data-article-id="<%= article.id %>">
            <% if article.images.any? %>
              <div class="article-thumbnails">
                <% article.images.first(4).each do |img| %>
                  <% if img.file.attached? %>
                    <div class="article-thumb" data-full-url="<%= url_for(img.file) %>">
                        <%= image_tag img.file.variant(resize_to_fill: [200, 200]), class: "thumb-img" %>
                    </div>
                  <% end %>
                <% end %>
              </div>
            <% end %>
            <div class="article-body">
              <h3><%= article.title %></h3>
              <p class="article-content-preview"><%= article.content %></p>
              <% if article.tags.present? %>
                <div class="article-tags">
                  <% article.tags.split(",").map(&:strip).each do |tag| %>
                    <span class="tag"><%= tag %></span>
                  <% end %>
                </div>
              <% end %>
              <p class="article-meta">
                <%= article.user.username %> ・ <%= article.created_at.strftime("%Y年%m月%d日") %>
              </p>
              <% if current_user&.admin? || current_user == article.user %>
                <div class="article-actions">
                  <button class="btn btn-secondary btn-sm edit-article-btn"
                    data-id="<%= article.id %>"
                    data-title="<%= article.title %>"
                    data-content="<%= article.content %>"
                    data-tags="<%= article.tags %>"
                    data-image-ids="<%= article.images.pluck(:id).join(',') %>">
                    編集
                  </button>
                  <%= button_to "削除", article_path(article), method: :delete,
                      class: "btn btn-danger btn-sm",
                      data: { confirm: "本当に削除しますか？" } %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="empty-state">
          <p>記事がまだ投稿されていません</p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- 記事投稿モーダル -->
  <div class="modal" id="articleModal">
    <div class="modal-content modal-lg">
      <span class="close" id="closeArticleModal">&times;</span>
      <h2>記事を投稿</h2>
      <%= form_with url: articles_path, method: :post, id: "articleForm", scope: :article do |f| %>
        <div class="form-group">
            <%= f.label :title, "タイトル" %>
            <%= f.text_field :title, required: true, placeholder: "記事のタイトルを入力してください" %>
        </div>
        <div class="form-group">
            <%= f.label :content, "本文" %>
            <%= f.text_area :content, rows: 6, required: true, placeholder: "記事の内容を入力してください" %>
        </div>
        <div class="form-group">
            <%= f.label :tags, "タグ（カンマで区切る）" %>
            <%= f.text_field :tags, placeholder: "例：イベント, 冒険, 面白かった" %>
        </div>

        <!-- 画像選択 -->
        <div class="form-group">
          <label>画像を選択（最大4枚）</label>
          <div class="image-picker" id="imagePicker">
            <% if @all_images.any? %>
              <% @all_images.each do |img| %>
                <% if img.file.attached? %>
                  <div class="picker-item" data-image-id="<%= img.id %>">
                    <%= image_tag img.file.variant(resize_to_fill: [120, 120]), class: "picker-thumb" %>
                    <div class="picker-check">✓</div>
                    <input type="checkbox" name="image_ids[]" value="<%= img.id %>" class="picker-checkbox" style="display:none;">
                  </div>
                <% end %>
              <% end %>
            <% else %>
              <p class="no-images-msg">ギャラリーに画像がありません</p>
            <% end %>
          </div>
          <p class="picker-hint">選択中: <span id="selectedCount">0</span> / 4枚</p>
        </div>

        <div class="form-actions">
          <%= f.submit "投稿", class: "btn btn-primary" %>
          <button type="button" class="btn btn-secondary" id="cancelArticle">キャンセル</button>
        </div>
      <% end %>
    </div>
  </div>

  <!-- 記事編集モーダル -->
  <div class="modal" id="editArticleModal">
    <div class="modal-content modal-lg">
      <span class="close" id="closeEditModal">&times;</span>
      <h2>記事を編集</h2>
      <form id="editArticleForm" method="post">
        <input type="hidden" name="_method" value="patch">
        <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
        <div class="form-group">
          <label>タイトル</label>
          <input type="text" name="article[title]" id="editArticleTitle" required>
        </div>
        <div class="form-group">
          <label>本文</label>
          <textarea name="article[content]" id="editArticleContent" rows="6" required></textarea>
        </div>
        <div class="form-group">
          <label>タグ</label>
          <input type="text" name="article[tags]" id="editArticleTags" placeholder="例：イベント, 冒険">
        </div>

        <!-- 記事詳細モーダル -->
        <div class="modal" id="articleViewModal">
        <div class="modal-content modal-lg article-view-modal-content">
            <span class="close" id="closeArticleViewModal">&times;</span>

            <div id="viewModalImageArea" class="view-modal-images"></div>

            <div id="viewModalPreview" class="view-modal-preview" style="display:none;">
            <button class="preview-close-btn" id="closePreview">&times;</button>
            <img id="viewModalPreviewImg" src="" alt="プレビュー" class="preview-full-img">
            </div>

            <div class="view-modal-body">
            <h2 id="viewModalTitle"></h2>
            <p id="viewModalMeta" class="article-meta"></p>
            <div id="viewModalTags" class="article-tags"></div>
            <p id="viewModalContent" class="view-modal-content-text"></p>
            </div>
        </div>
        </div>

        <!-- 画像選択 -->
        <div class="form-group">
          <label>画像を選択（最大4枚）</label>
          <div class="image-picker" id="editImagePicker">
            <% if @all_images.any? %>
              <% @all_images.each do |img| %>
                <% if img.file.attached? %>
                  <div class="picker-item" data-image-id="<%= img.id %>">
                    <%= image_tag img.file.variant(resize_to_fill: [120, 120]), class: "picker-thumb" %>
                    <div class="picker-check">✓</div>
                    <input type="checkbox" name="image_ids[]" value="<%= img.id %>" class="picker-checkbox" style="display:none;">
                  </div>
                <% end %>
              <% end %>
            <% else %>
              <p class="no-images-msg">ギャラリーに画像がありません</p>
            <% end %>
          </div>
          <p class="picker-hint">選択中: <span id="editSelectedCount">0</span> / 4枚</p>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary">更新</button>
          <button type="button" class="btn btn-secondary" id="cancelEdit">キャンセル</button>
        </div>
      </form>
    </div>
  </div>
</div>

<style>
  .articles-list {
    display: flex;
    flex-direction: column;
    gap: 24px;
    margin-top: 30px;
  }

  .article-card {
    border: 1px solid #ddd;
    border-radius: 8px;
    background: white;
    overflow: hidden;
  }

  .article-thumbnails {
    display: flex;
    gap: 4px;
    background: #000;
  }

  .article-thumb {
    flex: 1;
    aspect-ratio: 16/9;
    overflow: hidden;
    max-width: 25%;
  }

  .thumb-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .article-body {
    padding: 20px;
  }

  .article-body h3 {
    margin: 0 0 10px 0;
    color: #2c3e50;
    font-size: 20px;
  }

  .article-content-preview {
    color: #555;
    white-space: pre-wrap;
    margin-bottom: 12px;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 12px;
  }

  .tag {
    background: #ebf5fb;
    color: #2980b9;
    padding: 3px 10px;
    border-radius: 12px;
    font-size: 12px;
    font-weight: 600;
  }

  .article-meta {
    color: #999;
    font-size: 13px;
    margin-bottom: 12px;
  }

  .article-actions {
    display: flex;
    gap: 8px;
  }

  .btn-danger {
    background: #e74c3c;
    color: white;
    border: none;
    padding: 6px 14px;
    border-radius: 4px;
    cursor: pointer;
    font-size: 13px;
    font-weight: 600;
  }

  .btn-danger:hover {
    background: #c0392b;
  }

  /* 画像ピッカー */
  .image-picker {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(90px, 1fr));
    gap: 8px;
    max-height: 280px;
    overflow-y: auto;
    border: 1px solid #ddd;
    border-radius: 6px;
    padding: 10px;
    background: #fafafa;
  }

  .picker-item {
    position: relative;
    aspect-ratio: 1;
    border-radius: 6px;
    overflow: hidden;
    cursor: pointer;
    border: 3px solid transparent;
    transition: border-color 0.2s ease;
  }

  .picker-item.selected {
    border-color: #3498db;
  }

  .picker-item.disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .picker-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .picker-check {
    position: absolute;
    top: 4px;
    right: 4px;
    width: 22px;
    height: 22px;
    background: #3498db;
    color: white;
    border-radius: 50%;
    display: none;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: bold;
  }

  .picker-item.selected .picker-check {
    display: flex;
  }

  .picker-hint {
    color: #888;
    font-size: 13px;
    margin-top: 6px;
  }

  .no-images-msg {
    color: #aaa;
    font-size: 14px;
    padding: 20px;
    text-align: center;
    grid-column: 1 / -1;
  }

  .articles-actions {
    display: flex;
    gap: 15px;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
  }

  .article-actions .btn-secondary {
  background-color: #ecf0f1;
  color: #2c3e50;
  border: 1px solid #bdc3c7;
  padding: 6px 14px;
  font-size: 13px;
  font-weight: 600;
}

.article-actions .btn-secondary:hover {
  background-color: #dde1e3;
}

.article-card {
  cursor: pointer;
}

.article-view-modal-content {
  max-width: 760px;
  padding: 0;
  overflow: hidden;
}

.view-modal-images {
  display: flex;
  gap: 3px;
  background: #111;
  min-height: 0;
}

.view-modal-images.has-images {
  min-height: 200px;
}

.view-modal-img-wrap {
  flex: 1;
  overflow: hidden;
  cursor: pointer;
  position: relative;
  max-height: 260px;
}

.view-modal-img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: opacity 0.2s ease;
}

.view-modal-img-wrap:hover img {
  opacity: 0.85;
}

.view-modal-preview {
  position: relative;
  background: #000;
  display: flex;
  align-items: center;
  justify-content: center;
  max-height: 400px;
}

.preview-full-img {
  max-width: 100%;
  max-height: 400px;
  object-fit: contain;
  display: block;
}

.preview-close-btn {
  position: absolute;
  top: 10px;
  right: 14px;
  background: rgba(0,0,0,0.5);
  color: white;
  border: none;
  border-radius: 50%;
  width: 32px;
  height: 32px;
  font-size: 20px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
  line-height: 1;
}

.preview-close-btn:hover {
  background: rgba(255,255,255,0.2);
}

.view-modal-body {
  padding: 24px;
}

.view-modal-body h2 {
  margin: 0 0 8px 0;
  color: #2c3e50;
  font-size: 22px;
}

.view-modal-content-text {
  color: #444;
  white-space: pre-wrap;
  line-height: 1.8;
  margin-top: 12px;
}

  @media (max-width: 768px) {
    .article-thumb {
      max-width: 50%;
    }

    .articles-actions {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {

  // ── モーダル開閉ヘルパー ──
  function openModal(id) {
    document.getElementById(id).style.display = 'block';
  }
  function closeModal(id) {
    document.getElementById(id).style.display = 'none';
  }

  // ── 投稿モーダル ──
  const newArticleBtn = document.getElementById('newArticleBtn');
  if (newArticleBtn) {
    newArticleBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      openModal('articleModal');
    });
  }
  document.getElementById('closeArticleModal').addEventListener('click', () => closeModal('articleModal'));
  document.getElementById('cancelArticle').addEventListener('click', () => closeModal('articleModal'));

  // ── 編集モーダル ──
  document.getElementById('closeEditModal').addEventListener('click', () => closeModal('editArticleModal'));
  document.getElementById('cancelEdit').addEventListener('click', () => closeModal('editArticleModal'));

  // ── 詳細モーダル ──
  document.getElementById('closeArticleViewModal').addEventListener('click', () => closeModal('articleViewModal'));
  document.getElementById('closePreview').addEventListener('click', () => {
    document.getElementById('viewModalPreview').style.display = 'none';
    document.getElementById('viewModalImageArea').style.display = 'flex';
  });

  // ── 背景クリックで閉じる ──
  window.addEventListener('click', (e) => {
    ['articleModal', 'editArticleModal', 'articleViewModal'].forEach(id => {
      const el = document.getElementById(id);
      if (e.target === el) el.style.display = 'none';
    });
  });

  // ── 画像ピッカー ──
  function initPicker(pickerId, counterId, maxCount) {
    const picker = document.getElementById(pickerId);
    const counter = document.getElementById(counterId);
    if (!picker || !counter) return;

    picker.querySelectorAll('.picker-item').forEach(item => {
      item.addEventListener('click', () => {
        const checkbox = item.querySelector('.picker-checkbox');
        const selectedCount = picker.querySelectorAll('.picker-item.selected').length;

        if (item.classList.contains('selected')) {
          item.classList.remove('selected');
          checkbox.checked = false;
        } else {
          if (selectedCount >= maxCount) return;
          item.classList.add('selected');
          checkbox.checked = true;
        }

        const newCount = picker.querySelectorAll('.picker-item.selected').length;
        counter.textContent = newCount;
        picker.querySelectorAll('.picker-item:not(.selected)').forEach(i => {
          i.classList.toggle('disabled', newCount >= maxCount);
        });
      });
    });
  }

  initPicker('imagePicker', 'selectedCount', 4);
  initPicker('editImagePicker', 'editSelectedCount', 4);

  // ── 編集ボタン ──
  document.querySelectorAll('.edit-article-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const id = btn.dataset.id;
      const imageIds = btn.dataset.imageIds ? btn.dataset.imageIds.split(',').filter(Boolean) : [];

      document.getElementById('editArticleTitle').value = btn.dataset.title;
      document.getElementById('editArticleContent').value = btn.dataset.content;
      document.getElementById('editArticleTags').value = btn.dataset.tags || '';
      document.getElementById('editArticleForm').action = `/articles/${id}`;

      const picker = document.getElementById('editImagePicker');
      picker.querySelectorAll('.picker-item').forEach(item => {
        item.classList.remove('selected', 'disabled');
        item.querySelector('.picker-checkbox').checked = false;
      });

      imageIds.forEach(imgId => {
        const item = picker.querySelector(`[data-image-id="${imgId.trim()}"]`);
        if (item) {
          item.classList.add('selected');
          item.querySelector('.picker-checkbox').checked = true;
        }
      });

      const count = picker.querySelectorAll('.picker-item.selected').length;
      document.getElementById('editSelectedCount').textContent = count;
      picker.querySelectorAll('.picker-item:not(.selected)').forEach(i => {
        i.classList.toggle('disabled', count >= 4);
      });

      openModal('editArticleModal');
    });
  });

  // ── 削除ボタンの伝播を止める ──
  document.querySelectorAll('.article-actions form').forEach(form => {
    form.addEventListener('click', (e) => e.stopPropagation());
  });

  // ── 記事カードクリックで詳細モーダル ──
  document.querySelectorAll('.article-card').forEach(card => {
    card.addEventListener('click', (e) => {
      if (e.target.closest('.article-actions')) return;

      const title = card.querySelector('h3').textContent;
      const content = card.querySelector('.article-content-preview').textContent;
      const meta = card.querySelector('.article-meta').textContent;
      const tagsEl = card.querySelector('.article-tags');

      document.getElementById('viewModalTitle').textContent = title;
      document.getElementById('viewModalContent').textContent = content;
      document.getElementById('viewModalMeta').textContent = meta;

      const tagsContainer = document.getElementById('viewModalTags');
      tagsContainer.innerHTML = '';
      if (tagsEl) {
        tagsEl.querySelectorAll('.tag').forEach(tag => {
          const span = document.createElement('span');
          span.className = 'tag';
          span.textContent = tag.textContent;
          tagsContainer.appendChild(span);
        });
      }

      const imageArea = document.getElementById('viewModalImageArea');
      imageArea.innerHTML = '';
      imageArea.classList.remove('has-images');
      imageArea.style.display = 'flex';

      card.querySelectorAll('.article-thumb').forEach(thumb => {
        const img = thumb.querySelector('img');
        if (!img) return;
        imageArea.classList.add('has-images');

        const wrap = document.createElement('div');
        wrap.className = 'view-modal-img-wrap';

        const image = document.createElement('img');
        image.src = img.src;
        image.alt = '';

        const fullUrl = thumb.dataset.fullUrl || img.src;
        wrap.appendChild(image);
        wrap.addEventListener('click', () => {
          document.getElementById('viewModalPreviewImg').src = fullUrl;
          document.getElementById('viewModalPreview').style.display = 'flex';
          imageArea.style.display = 'none';
        });

        imageArea.appendChild(wrap);
      });

      document.getElementById('viewModalPreview').style.display = 'none';
      openModal('articleViewModal');
    });
  });

  // ── 検索 ──
  document.getElementById('searchArticles').addEventListener('input', (e) => {
    const q = e.target.value.toLowerCase();
    document.querySelectorAll('.article-card').forEach(card => {
      card.style.display = card.textContent.toLowerCase().includes(q) ? 'block' : 'none';
    });
  });

});
</script>