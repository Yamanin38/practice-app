<div class="container">
  <header class="page-header">
    <h1>記事</h1>
    <p>チームの活動記録と思い出</p>
  </header>

  <div class="page-content">
    <div class="articles-actions">
      <% if current_user %>
        <button class="btn btn-primary" id="newArticleBtn">新しい記事を投稿</button>
      <% end %>
      <div class="filter-section-row">
        <div class="filter-section" id="articleFilterSection">
          <%= form_with url: articles_path, method: :get, local: true, class: "date-filter-form", data: { turbo: false } do |f| %>
            <button type="button" class="btn-cal-toggle" id="artCalToggleBtn">
              📅 <span id="artCalToggleText"><%= params[:date].present? ? params[:date] : "日付で絞り込む" %></span>
            </button>
            <div class="calendar-filter" id="artCalendarFilter" style="display:none; position: absolute; top: calc(100% + 8px); left: 0; width: 260px; margin-bottom: 8px; z-index: 2100;">
              <div class="calendar-header">
                <button type="button" class="cal-nav" id="artCalPrev">&#8249;</button>
                <span class="cal-title" id="artCalTitle">
                  <select id="artCalYearSelect" class="cal-year-select"></select>
                  <span id="artCalMonthText"></span>
                </span>
                <button type="button" class="cal-nav" id="artCalNext">&#8250;</button>
              </div>
              <div class="calendar-weekdays">
                <span>日</span><span>月</span><span>火</span><span>水</span><span>木</span><span>金</span><span>土</span>
              </div>
              <div class="calendar-days" id="artCalendarDays"></div>
              <input type="hidden" name="date" id="artCalSelectedDate" value="<%= params[:date] %>">
              <div class="calendar-actions">
                <button type="button" class="btn-cal-clear" id="artCalClear">クリア</button>
              </div>
            </div>
          <% end %>
        </div>
        <input type="text" placeholder="記事を検索..." id="searchArticles" class="search-input">
      </div>
    </div>

    <div class="articles-list" id="articlesList">
      <% if @articles.any? %>
        <% @articles.each do |article| %>
          <div class="article-card" data-url="<%= article_path(article) %>">
            <% if article.images.any? %>
              <div class="article-thumbnails">
                <% article.images.first(4).each do |img| %>
                  <% if img.file.attached? %>
                    <div class="article-thumb" data-full-url="<%= url_for(img.file) %>">
                        <%= image_tag img.file.variant(resize_to_fill: [800, 800]), class: "thumb-img" %>
                    </div>
                  <% end %>
                <% end %>
              </div>
            <% end %>
            <div class="article-body">
              <h3><%= article.title %></h3>
              <p class="article-content-preview"><%= truncate(article.content, length: 60) %></p>
              <% if article.tags.present? %>
                <div class="article-tags">
                  <% article.tags.split(",").map(&:strip).each do |tag| %>
                    <span class="tag"><%= tag %></span>
                  <% end %>
                </div>
              <% end %>
              <p class="article-meta">
                <%= article.user.username %> ・ <%= article.created_at.strftime("%Y年%m月%d日") %>
              </p>
              <% if current_user&.admin? || current_user == article.user %>
                <div class="article-actions">
                  <%# ボタンから、詳細ページへのパラメータ付きリンク（aタグ）に変更 %>
                  <%= link_to "編集", article_path(article, edit: true), class: "btn btn-secondary btn-sm" %>

                  <%= button_to "削除", article_path(article), method: :delete,
                      class: "btn btn-danger btn-sm",
                      data: { confirm: "本当に削除しますか？" } %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="empty-state">
          <p>記事がまだ投稿されていません</p>
        </div>
      <% end %>
    </div>
  </div>

  <div class="modal" id="articleModal">
    <div class="modal-content modal-lg">
      <span class="close" id="closeArticleModal">&times;</span>
      <h2>記事を投稿</h2>
      <%= form_with url: articles_path, method: :post, id: "articleForm", scope: :article do |f| %>
        
        <div class="form-group" style="margin-bottom: 16px;">
          <%= f.label :title, "タイトル", style: "display: block; margin-bottom: 6px; color: var(--clr-text);" %>
          <%= f.text_field :title, class: "form-control", style: "width: 100%; padding: 10px; background: #fff; border: 1px solid var(--clr-border); border-radius: var(--radius-sm); color: #333;", required: true %>
        </div>

        <div class="form-group" style="margin-bottom: 16px;">
          <%= f.label :content, "本文 (Markdown)", style: "display: block; margin-bottom: 6px; color: var(--clr-text);" %>
          <%= f.text_area :content, rows: 12, class: "form-control", style: "width: 100%; padding: 10px; background: #fff; border: 1px solid var(--clr-border); border-radius: var(--radius-sm); font-family: monospace; color: #333; resize: vertical;", required: true %>
        </div>

        <div class="form-group" style="margin-bottom: 16px;">
          <%= f.label :tags, "タグ (カンマ区切り)", style: "display: block; margin-bottom: 6px; color: var(--clr-text);" %>
          <%= f.text_field :tags, class: "form-control", style: "width: 100%; padding: 10px; background: #fff; border: 1px solid var(--clr-border); border-radius: var(--radius-sm); color: #333;", placeholder: "例: 日記, お知らせ" %>
        </div>

        <div class="form-group" style="margin-bottom: 24px;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px;">
          <label style="color: var(--clr-text); margin: 0;">添付画像 (最大4枚)</label>
          
          <div class="filter-section" style="position: relative;">
            <button type="button" class="btn-cal-toggle" id="calToggleBtn" style="padding: 4px 10px; font-size: 12px;">
              📅 <span id="calToggleText">日付で絞り込む</span>
            </button>
            <div class="calendar-filter" id="calendarFilter" style="display:none; position: absolute; bottom: 100%; right: 0; width: 260px; margin-bottom: 8px; z-index: 2100;">
              <div class="calendar-header">
                <button type="button" class="cal-nav" id="calPrev">&#8249;</button>
                <span class="cal-title" id="calTitle">
                  <select id="calYearSelect" class="cal-year-select"></select>
                  <span id="calMonthText"></span>
                </span>
                <button type="button" class="cal-nav" id="calNext">&#8250;</button>
              </div>
              <div class="calendar-weekdays">
                <span>日</span><span>月</span><span>火</span><span>水</span><span>木</span><span>金</span><span>土</span>
              </div>
              <div class="calendar-days" id="calendarDays"></div>
              <input type="hidden" id="calSelectedDate" value="">
              <div class="calendar-actions">
                <button type="button" class="btn-cal-clear" id="calClear">すべて表示</button>
              </div>
            </div>
          </div>
        </div>
        
        <div class="image-selector-container" style="display: flex; gap: 10px; overflow-x: auto; padding: 4px 0;">
          <% if @all_images.present? %>
            <% @all_images.each do |image| %>
              <% is_checked = false %>
              
              <label class="image-checkbox-label" data-date="<%= image.created_at.strftime('%Y-%m-%d') %>" style="cursor: pointer; position: relative; flex-shrink: 0;">
                <input type="checkbox" name="image_ids[]" value="<%= image.id %>" 
                       <%= 'checked' if is_checked %> 
                       style="display: none;"
                       onchange="toggleImageSelect(this)">
                
                <div class="image-thumbnail" style="width: 80px; height: 80px; border-radius: 4px; overflow: hidden; border: <%= is_checked ? '3px solid var(--clr-primary, #e8a820)' : '1px solid var(--clr-border)' %>; opacity: <%= is_checked ? '1' : '0.5' %>; transition: all 0.2s;">
                  <% if image.file_attachment.present? %>
                    <%= image_tag image.file_attachment, style: "width: 100%; height: 100%; object-fit: cover; display: block;" %>
                  <% end %>
                </div>
              </label>
            <% end %>
          <% else %>
            <p style="color: var(--clr-text-muted); font-size: 14px;">選択できる画像がありません。</p>
          <% end %>
        </div>
      </div>
      <div class="form-actions" style="display: flex; gap: 12px; justify-content: flex-end; margin-top: 24px;">
        <button type="button" class="btn btn-secondary" id="cancelPostBtn" onclick="document.getElementById('articleModal').style.display='none'">キャンセル</button>
        <%= f.submit "投稿する", class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>

  <div class="modal" id="editArticleModal">
    <div class="modal-content modal-lg">
      <span class="close" id="closeEditModal">&times;</span>
      <h2>記事を編集</h2>
      <form id="editArticleForm" method="post">
        <input type="hidden" name="_method" value="patch">
        <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
        
        <div class="form-group" style="margin-bottom: 16px;">
          <label style="display: block; margin-bottom: 6px; color: var(--clr-text);">タイトル</label>
          <input type="text" name="article[title]" id="editArticleTitle" class="form-control" style="width: 100%; padding: 10px; background: #fff; border: 1px solid var(--clr-border); border-radius: var(--radius-sm); color: #333;" required>
        </div>
        
        <div class="form-group" style="margin-bottom: 16px;">
          <label style="display: block; margin-bottom: 6px; color: var(--clr-text);">本文 (Markdown)</label>
          <textarea name="article[content]" id="editArticleContent" rows="12" class="form-control" style="width: 100%; padding: 10px; background: #fff; border: 1px solid var(--clr-border); border-radius: var(--radius-sm); font-family: monospace; color: #333; resize: vertical;" required></textarea>
        </div>
        
        <div class="form-group" style="margin-bottom: 16px;">
          <label style="display: block; margin-bottom: 6px; color: var(--clr-text);">タグ (カンマ区切り)</label>
          <input type="text" name="article[tags]" id="editArticleTags" class="form-control" style="width: 100%; padding: 10px; background: #fff; border: 1px solid var(--clr-border); border-radius: var(--radius-sm); color: #333;" placeholder="例：イベント, 冒険">
        </div>

        <div class="form-group" style="margin-bottom: 24px;">
          <label style="display: block; margin-bottom: 6px; color: var(--clr-text);">添付画像 (最大4枚)</label>
          <div class="image-selector-container" style="display: flex; gap: 10px; overflow-x: auto; padding: 4px 0;">
            <% if @all_images.present? %>
              <% @all_images.each do |image| %>
                <label class="image-checkbox-label" style="cursor: pointer; position: relative; flex-shrink: 0;">
                  <input type="checkbox" name="image_ids[]" value="<%= image.id %>" 
                         class="picker-checkbox" 
                         style="display: none;" 
                         onchange="toggleImageSelect(this)">
                  <div class="image-thumbnail" style="width: 80px; height: 80px; border-radius: 4px; overflow: hidden; border: 1px solid var(--clr-border); opacity: 0.5; transition: all 0.2s;">
                    <% if image.file_attachment.present? %>
                      <%= image_tag image.file_attachment, style: "width: 100%; height: 100%; object-fit: cover; display: block;" %>
                    <% end %>
                  </div>
                </label>
              <% end %>
            <% else %>
              <p style="color: var(--clr-text-muted); font-size: 14px;">ギャラリーに画像がありません。</p>
            <% end %>
          </div>
        </div>

        <div class="form-actions" style="display: flex; gap: 12px; justify-content: flex-end; margin-top: 24px;">
          <button type="button" class="btn btn-secondary" id="cancelEdit">キャンセル</button>
          <button type="submit" class="btn btn-primary">更新</button>
        </div>
      </form>
    </div>
  </div>
</div>

<style>
  /* ── フィルター行（カレンダー＋検索） ── */
  .filter-section-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  /* ── カレンダーフィルター（ギャラリーページから流用） ── */
  .filter-section {
    position: relative;
  }

  .btn-cal-toggle {
    background: linear-gradient(180deg, #3a2108 0%, #241400 100%);
    border: 1px solid #5a3510;
    border-radius: 6px;
    padding: 10px 16px;
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    color: #e8a820;
    box-shadow:
      0 1px 0 rgba(255,200,80,.12) inset,
      0 3px 8px rgba(0,0,0,.5),
      0 1px 0 rgba(0,0,0,.7);
    transition: filter 0.2s ease;
    white-space: nowrap;
    text-shadow: 0 1px 2px rgba(0,0,0,.5);
  }

  .btn-cal-toggle:hover {
    filter: brightness(1.2);
    border-color: #c8820a;
  }

  .btn-cal-toggle.active {
    background: linear-gradient(180deg, #c8820a 0%, #7a4800 100%);
    border-color: #6a3e00;
    color: #fff8e0;
    box-shadow:
      0 1px 0 rgba(255,200,80,.25) inset,
      0 3px 10px rgba(0,0,0,.6);
  }

  .calendar-filter {
    position: absolute;
    /* top: calc(100% + 8px); */
    /* left: 0; */
    background: linear-gradient(180deg, #2e1a00 0%, #1e1000 100%);
    border: 1px solid #5a3510;
    border-radius: 8px;
    padding: 14px;
    width: 280px;
    box-shadow:
      0 8px 24px rgba(0,0,0,.7),
      inset 0 1px 0 rgba(255,200,80,.12);
    z-index: 100;
  }

  .calendar-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
  }

  .cal-title {
    font-weight: 700;
    font-size: 15px;
    color: #e8a820;
    text-shadow: 0 1px 3px rgba(0,0,0,.5);
  }

  .cal-nav {
    background: linear-gradient(180deg, #3a2108 0%, #241400 100%);
    border: 1px solid #5a3510;
    border-radius: 4px;
    font-size: 18px;
    cursor: pointer;
    color: #e8a820;
    padding: 2px 10px;
    line-height: 1;
    box-shadow:
      0 1px 0 rgba(255,200,80,.12) inset,
      0 2px 4px rgba(0,0,0,.5);
    transition: filter .15s;
  }

  .cal-nav:hover { filter: brightness(1.3); }

  .calendar-weekdays {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    text-align: center;
    font-size: 12px;
    font-weight: 700;
    color: #7a5030;
    margin-bottom: 4px;
  }

  .calendar-weekdays span:first-child { color: #c05040; }
  .calendar-weekdays span:last-child  { color: #8090c0; }

  .calendar-days {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 2px;
  }

  .cal-day {
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    border-radius: 50%;
    cursor: default;
    color: #4a3020;
  }

  .cal-day.has-image {
    color: #e8d5b0;
    cursor: pointer;
    font-weight: 700;
  }

  .cal-day.has-image:hover {
    background: rgba(200,130,10,.25);
    color: #e8a820;
  }

  .cal-day.selected {
    background: linear-gradient(135deg, #c8820a, #7a4800);
    color: #fff8e0 !important;
    box-shadow: 0 2px 6px rgba(0,0,0,.5);
  }

  .cal-day.today {
    border: 1px solid #c8820a;
  }

  .calendar-actions {
    display: flex;
    gap: 8px;
    margin-top: 10px;
    justify-content: flex-end;
  }

  .btn-cal-clear {
    background: linear-gradient(180deg, #3a2108 0%, #241400 100%);
    border: 1px solid #5a3510;
    border-radius: 4px;
    padding: 6px 14px;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    color: #a08060;
    box-shadow:
      0 1px 0 rgba(255,200,80,.08) inset,
      0 2px 4px rgba(0,0,0,.4);
    transition: filter .15s;
  }

  .btn-cal-clear:hover { filter: brightness(1.3); color: #e8d5b0; }

  /* ── 以下は元のスタイルそのまま ── */
  .articles-list {
    display: flex;
    flex-direction: column;
    gap: 24px;
    margin-top: 30px;
  }

  .article-card {
    border: 1px solid #7a4818;
    border-radius: 8px;
    background: linear-gradient(180deg, #4a2a0a 0%, #3a2108 100%);
    overflow: hidden;
    cursor: pointer;
    box-shadow:
      0 6px 16px rgba(0,0,0,.7),
      inset 0 2px 0 rgba(255,200,80,.2),
      inset 0 -2px 0 rgba(0,0,0,.4);
    transition: all .25s ease;
  }

  .article-card:hover {
    transform: translateY(-3px);
    border-color: #c8820a;
    box-shadow:
      0 10px 24px rgba(0,0,0,.8),
      inset 0 2px 0 rgba(255,200,80,.3),
      inset 0 -2px 0 rgba(0,0,0,.5);
  }

  .article-thumbnails {
    display: flex;
    gap: 4px;
    background: #241400;
  }

  .article-thumb {
    flex: 1;
    aspect-ratio: 16/9;
    overflow: hidden;
    max-width: 25%;
  }

  .thumb-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .article-body {
    padding: 20px;
  }

  .article-body h3 {
    margin: 0 0 10px 0;
    color: #e8a820;
    font-size: 20px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    white-space: normal;
    text-shadow: 0 1px 3px rgba(0,0,0,.5);
  }

  .article-content-preview {
    color: #a08060;
    margin-bottom: 12px;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    white-space: normal;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 12px;
  }

  .tag {
    background: rgba(200,130,10,.18);
    color: #e8a820;
    border: 1px solid rgba(200,130,10,.35);
    padding: 3px 10px;
    border-radius: 12px;
    font-size: 12px;
    font-weight: 700;
  }

  .article-meta {
    color: #7a5030;
    font-size: 13px;
    margin-bottom: 12px;
  }

  .article-actions {
    display: flex;
    gap: 8px;
  }

  .btn-danger {
    background: #e74c3c;
    color: white;
    border: none;
    padding: 6px 14px;
    border-radius: 4px;
    cursor: pointer;
    font-size: 13px;
    font-weight: 600;
  }

  .btn-danger:hover { background: #c0392b; }

  .image-picker {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(90px, 1fr));
    gap: 8px;
    max-height: 280px;
    overflow-y: auto;
    border: 1px solid #5a3510;
    border-radius: 6px;
    padding: 10px;
    background: #150d00;
    box-shadow: inset 0 2px 6px rgba(0,0,0,.5);
  }

  .picker-item {
    position: relative;
    aspect-ratio: 1;
    border-radius: 6px;
    overflow: hidden;
    cursor: pointer;
    border: 3px solid transparent;
    transition: border-color 0.2s ease;
  }

  .picker-item.selected { border-color: #c8820a; }
  .picker-item.disabled { opacity: 0.4; cursor: not-allowed; }

  .picker-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .picker-check {
    position: absolute;
    top: 4px;
    right: 4px;
    width: 22px;
    height: 22px;
    background: #3498db;
    color: white;
    border-radius: 50%;
    display: none;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: bold;
  }

  .picker-item.selected .picker-check { display: flex; }

  .picker-hint {
    color: #888;
    font-size: 13px;
    margin-top: 6px;
  }

  .no-images-msg {
    color: #aaa;
    font-size: 14px;
    padding: 20px;
    text-align: center;
    grid-column: 1 / -1;
  }

  .articles-actions {
    display: flex;
    gap: 15px;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
  }

  .article-actions .btn-secondary {
    background-color: #ecf0f1;
    color: #e8a81b
    border: 1px solid #352f12;
    padding: 6px 14px;
    font-size: 13px;
    font-weight: 600;
    line-height: 1;
    /* 以下を inline-flex と中央揃えに変更 */
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .article-actions .btn-secondary:hover { background-color: #dde1e3; }

  /* ─── 記事詳細モーダル ─── */
  #articleViewModal {
    display: none;
    position: fixed;
    z-index: 2000;
    inset: 0;
    background: rgba(10, 14, 23, 0.75);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    justify-content: center;
    align-items: center;
    padding: 20px;
  }

  #articleViewModal.modal-open { display: flex; }

  .article-view-modal-content {
    position: relative;
    background: #fff;
    border-radius: 16px;
    width: 95vw;
    max-width: 1200px;
    max-height: 92vh;
    overflow-y: auto;
    box-shadow: 0 32px 80px rgba(0,0,0,0.35), 0 0 0 1px rgba(255,255,255,0.06);
    animation: modalRise 0.28s cubic-bezier(0.34, 1.3, 0.64, 1) both;
    scrollbar-width: none;
  }

  .article-view-modal-content::-webkit-scrollbar { display: none; }

  @keyframes modalRise {
    from { opacity: 0; transform: translateY(24px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0)    scale(1);    }
  }

  .article-view-header {
    position: absolute;
    top: 14px;
    right: 14px;
    z-index: 10;
  }

  .article-view-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: none;
    cursor: pointer;
    background: rgba(255,255,255,0.85);
    color: #374151;
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
    backdrop-filter: blur(4px);
    transition: background 0.15s, color 0.15s, transform 0.15s;
  }

  .article-view-close:hover {
    background: #1a1a2e;
    color: #fff;
    transform: rotate(90deg);
  }

  .view-modal-hero {
    width: 100%;
    display: grid;
    gap: 3px;
