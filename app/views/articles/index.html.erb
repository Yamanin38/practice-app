/* ─── 記事詳細モーダル ─── */
#articleViewModal {
  display: none;
  position: fixed;
  z-index: 2000;
  inset: 0;
  background: rgba(10, 14, 23, 0.75);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  justify-content: center;
  align-items: center;
  padding: 20px;
}

#articleViewModal.modal-open {
  display: flex;
}

.article-view-modal-content {
  position: relative;
  background: #fff;
  border-radius: 16px;
  width: 95vw;
  max-width: 1200px;     /* 680px → 960px */
  max-height: 92vh;      /* 90vh → 92vh */
  overflow-y: auto;
  box-shadow: 0 32px 80px rgba(0,0,0,0.35), 0 0 0 1px rgba(255,255,255,0.06);
  animation: modalRise 0.28s cubic-bezier(0.34, 1.3, 0.64, 1) both;
  scrollbar-width: none;
}

.article-view-modal-content::-webkit-scrollbar { display: none; }

@keyframes modalRise {
  from { opacity: 0; transform: translateY(24px) scale(0.97); }
  to   { opacity: 1; transform: translateY(0)    scale(1);    }
}

/* 閉じるボタン（右上に浮かす） */
.article-view-header {
  position: absolute;
  top: 14px;
  right: 14px;
  z-index: 10;
}

.article-view-close {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 34px;
  height: 34px;
  border-radius: 50%;
  border: none;
  cursor: pointer;
  background: rgba(255,255,255,0.85);
  color: #374151;
  box-shadow: 0 2px 8px rgba(0,0,0,0.15);
  backdrop-filter: blur(4px);
  transition: background 0.15s, color 0.15s, transform 0.15s;
}

.article-view-close:hover {
  background: #1a1a2e;
  color: #fff;
  transform: rotate(90deg);
}

/* ヒーロー画像グリッド */
.view-modal-hero {
  width: 100%;
  display: grid;
  gap: 3px;
  border-radius: 16px 16px 0 0;
  overflow: hidden;
  background: #fff;      /* f3f4f6 → fff */
  min-height: 0;
  padding: 16px;  /* ← 追加：画像外枠に余白 */

  /* ▼ 追加：ギャラリー全体のサイズをここで決めます */
  aspect-ratio: 16 / 9; /* 全体を綺麗な横長に固定 */
  max-height: 600px;    /* PC表示時に大きくなりすぎないよう制限 */
  box-sizing: border-box; /* ← 【追加】パディングのズレによる見切れを防ぐ */
}

.view-modal-hero.hero-1 { grid-template-columns: 1fr; }
.view-modal-hero.hero-2 { grid-template-columns: 1fr 1fr; }
.view-modal-hero.hero-3 { 
  grid-template-columns: 2fr 1fr; 
  grid-template-rows: calc((100% - 3px) / 2) calc((100% - 3px) / 2); /* ← 【修正】Safariの計算バグを回避 */
}

.view-modal-hero.hero-4 {
  grid-template-columns: 1fr 1fr;
  grid-template-rows: calc((100% - 3px) / 2) calc((100% - 3px) / 2); /* ← 【修正】Safariの計算バグを回避 */
  /* grid-auto-rows: auto; ← ★元のコードにあれば削除 */
  /* align-items: start;   ← ★元のコードにあれば削除 */
}

.view-modal-hero.hero-3 .view-hero-img-wrap:first-child { grid-row: 1 / 3; }

.view-hero-img-wrap {
  width: 100%;
  height: 100%;
  min-height: 0; /* ← 【追加】画像が無理に押し広がるのを防ぐ */
  overflow: hidden;
  cursor: zoom-in;
  position: relative;
  border-radius: 10px;
  object-fit: contain;
}

.view-hero-img-wrap img {
  position: absolute; /* ← 【追加】画像が枠のサイズを押し広げるのを完全に防ぎます */
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover; /* ← 元のデザイン（枠を埋め尽くす）に戻す場合は cover にします */
  display: block;
  transition: transform 0.4s ease;
  background: #f3f4f6;
}

.view-hero-img-wrap:hover img { transform: scale(1.04); }

/* フルプレビュー */
