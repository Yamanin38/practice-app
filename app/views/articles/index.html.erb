  .cal-nav:hover { filter: brightness(1.3); }
  .calendar-weekdays { display: grid; grid-template-columns: repeat(7, 1fr); text-align: center; font-size: 12px; color: #7a5030; margin-bottom: 4px; }
  .calendar-weekdays span:first-child { color: #c05040; }
  .calendar-weekdays span:last-child { color: #8090c0; }
  .calendar-days { display: grid; grid-template-columns: repeat(7, 1fr); gap: 2px; min-height: 200px; }
  .cal-day { aspect-ratio: 1; display: flex; align-items: center; justify-content: center; font-size: 13px; border-radius: 50%; color: #4a3020; cursor: default; }
  .cal-day.has-image { color: #e8d5b0; cursor: pointer; font-weight: 700; }
  .cal-day.has-image:hover { background: rgba(200,130,10,.25); color: #e8a820; }
  .cal-day.selected { background: linear-gradient(135deg, #c8820a, #7a4800); color: #fff8e0 !important; }
  .cal-day.today { border: 1px solid #c8820a; }
  .calendar-actions { display: flex; gap: 8px; margin-top: 10px; justify-content: flex-end; }
  .btn-cal-clear {
    background: linear-gradient(180deg, #3a2108 0%, #241400 100%); border: 1px solid #5a3510;
    border-radius: 4px; padding: 6px 14px; font-size: 13px; color: #a08060; cursor: pointer;
  }
  .btn-cal-clear:hover { filter: brightness(1.3); color: #e8d5b0; }
  
  .cal-year-select {
    background-color: transparent; color: inherit; border: 1px solid #7a4818;
    border-radius: 4px; padding: 2px 24px 2px 8px; font-weight: bold; cursor: pointer;
    appearance: none;
    background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23e8a820' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
    background-repeat: no-repeat; background-position: right 4px center; background-size: 14px;
    text-align: center;         /* 一部のブラウザ用 */
  text-align-last: center;    /* select内のテキストを中央寄せにする主要プロパティ */
  padding: 2px 24px 2px 8px;  /* 既存のパディング */
  }
  .cal-year-select option { background-color: #3a2108; color: #e8d5b0; }

  .cal-year-select, #artCalMonthText, #calMonthText {
  pointer-events: auto;
}
.cal-nav {
  z-index: 1; /* 矢印をタイトルより前面に */
}
</style>

<script>
  // ── バックエンドから渡された記事投稿日リスト ──
  // コントローラで @article_dates を設定してください（上部コメント参照）
  const articleDates = <%= @article_dates.to_json.html_safe %>;
  const articleDateSet = new Set(articleDates);

  document.addEventListener('DOMContentLoaded', () => {

    // ── 文字数カウント（半角0.5文字換算） ──
    function calcWeight(str) {
      let weight = 0;
      for (const ch of str) {
        weight += /[\x00-\x7F]/.test(ch) ? 0.5 : 1;
      }
      return weight;
    }

    document.querySelectorAll('[data-maxweight]').forEach(input => {
      const max = parseFloat(input.dataset.maxweight);
      input.addEventListener('input', () => {
        const weight = calcWeight(input.value);
        if (weight > max) {
          let trimmed = '', total = 0;
          for (const ch of input.value) {
            const w = /[\x00-\x7F]/.test(ch) ? 0.5 : 1;
            if (total + w > max) break;
            trimmed += ch;
            total += w;
          }
          input.value = trimmed;
        }
      });
    });

    // ── モーダル開閉ヘルパー ──
    function openModal(id) {
      const el = document.getElementById(id);
      if (id === 'articleViewModal') {
        el.style.display = 'flex';
        el.classList.add('modal-open');
        document.body.style.overflow = 'hidden';
      } else {
        el.style.display = 'block';
      }
    }
    function closeModal(id) {
      const el = document.getElementById(id);
      el.style.display = 'none';
      el.classList.remove('modal-open');
      if (id === 'articleViewModal') document.body.style.overflow = '';
    }

    // ── 投稿モーダル ──
    const newArticleBtn = document.getElementById('newArticleBtn');
    if (newArticleBtn) {
      newArticleBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        openModal('articleModal');
      });
    }
    // ── 投稿モーダル ──
const closeArticleModal = document.getElementById('closeArticleModal');
if (closeArticleModal) {
  closeArticleModal.addEventListener('click', () => closeModal('articleModal'));
}

// IDを「cancelPostBtn」に変更し、存在チェックを入れる
const cancelPostBtn = document.getElementById('cancelPostBtn');
if (cancelPostBtn) {
  cancelPostBtn.addEventListener('click', () => closeModal('articleModal'));
}

// ── 編集モーダル ──（こちらも念のため安全対策をしておきます）
const closeEditModal = document.getElementById('closeEditModal');
if (closeEditModal) {
  closeEditModal.addEventListener('click', () => closeModal('editArticleModal'));
}

const cancelEdit = document.getElementById('cancelEdit');
if (cancelEdit) {
  cancelEdit.addEventListener('click', () => closeModal('editArticleModal'));
}

    // ── 画像ピッカー ──
    function initPicker(pickerId, counterId, maxCount) {
      const picker = document.getElementById(pickerId);
      const counter = document.getElementById(counterId);
      if (!picker || !counter) return;

      picker.querySelectorAll('.picker-item').forEach(item => {
        item.addEventListener('click', () => {
          const checkbox = item.querySelector('.picker-checkbox');
          const selectedCount = picker.querySelectorAll('.picker-item.selected').length;

          if (item.classList.contains('selected')) {
            item.classList.remove('selected');
            checkbox.checked = false;
          } else {
            if (selectedCount >= maxCount) return;
            item.classList.add('selected');
            checkbox.checked = true;
          }

          const newCount = picker.querySelectorAll('.picker-item.selected').length;
          counter.textContent = newCount;
          picker.querySelectorAll('.picker-item:not(.selected)').forEach(i => {
            i.classList.toggle('disabled', newCount >= maxCount);
          });
        });
      });
    }

    initPicker('imagePicker', 'selectedCount', 4);
    initPicker('editImagePicker', 'editSelectedCount', 4);

    // ── 編集ボタン ──
    document.querySelectorAll('.edit-article-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const id = btn.dataset.id;
        const imageIds = btn.dataset.imageIds ? btn.dataset.imageIds.split(',').filter(Boolean) : [];

        document.getElementById('editArticleTitle').value = btn.dataset.title;
        document.getElementById('editArticleContent').value = btn.dataset.content;
        document.getElementById('editArticleTags').value = btn.dataset.tags || '';
        document.getElementById('editArticleForm').action = `/articles/${id}`;

        const picker = document.getElementById('editImagePicker');
        picker.querySelectorAll('.picker-item').forEach(item => {
          item.classList.remove('selected', 'disabled');
          item.querySelector('.picker-checkbox').checked = false;
        });

        imageIds.forEach(imgId => {
          const item = picker.querySelector(`[data-image-id="${imgId.trim()}"]`);
          if (item) {
            item.classList.add('selected');
            item.querySelector('.picker-checkbox').checked = true;
          }
        });

        const count = picker.querySelectorAll('.picker-item.selected').length;
        document.getElementById('editSelectedCount').textContent = count;
        picker.querySelectorAll('.picker-item:not(.selected)').forEach(i => {
          i.classList.toggle('disabled', count >= 4);
        });

        openModal('editArticleModal');
      });
    });

    // ── 削除ボタンの伝播を止める ──
    document.querySelectorAll('.article-actions form').forEach(form => {
      form.addEventListener('click', (e) => e.stopPropagation());
    });

    // ── 記事カードクリックで詳細ページへ遷移 ──
    document.querySelectorAll('.article-card').forEach(card => {
    card.addEventListener('click', (e) => {
      // ★ 編集ボタン、削除ボタン、またはフォーム内の要素（チェックボックス等）がクリックされた場合は、詳細ページへの遷移を完全に無視する
      if (e.target.closest('.edit-article-btn') || e.target.closest('.btn-danger') || e.target.closest('form') || e.target.closest('.modal')) {
        return; 
      }

      // 設定したデータ属性からURLを取得し、show.html.erb へ遷移する
      window.location.href = card.dataset.url;
    });
  });

    // ── 検索 ──
    document.getElementById('searchArticles').addEventListener('input', (e) => {
      const q = e.target.value.toLowerCase();
      document.querySelectorAll('.article-card').forEach(card => {
        card.style.display = card.textContent.toLowerCase().includes(q) ? 'block' : 'none';
      });
    });

    // ────────────────────────────────────────
    // ── 記事ページ用カレンダーフィルター ──
    // ────────────────────────────────────────
    const artCalToggleBtn    = document.getElementById('artCalToggleBtn');
    const artCalendarFilter  = document.getElementById('artCalendarFilter');
    const artSelectedInput   = document.getElementById('artCalSelectedDate');

    let artCalYear, artCalMonth;
    const today = new Date();

    if (artSelectedInput.value) {
      const d = new Date(artSelectedInput.value);
      artCalYear  = d.getFullYear();
      artCalMonth = d.getMonth();
    } else {
      artCalYear  = today.getFullYear();
      artCalMonth = today.getMonth();
    }

    function renderArtCalendar() {
      const daysEl = document.getElementById('artCalendarDays');

      // 【変更】年プルダウンの選択状態を現在の表示年に合わせる
      document.getElementById('artCalYearSelect').value = artCalYear;
      // 【変更】月のテキストだけを更新する
      document.getElementById('artCalMonthText').textContent = `${artCalMonth + 1}月`;
      
      daysEl.innerHTML  = '';

      const firstDay    = new Date(artCalYear, artCalMonth, 1).getDay();
      const daysInMonth = new Date(artCalYear, artCalMonth + 1, 0).getDate();
      const selectedVal = artSelectedInput.value;

      // トグルボタンのテキスト更新
      document.getElementById('artCalToggleText').textContent = selectedVal || '日付で絞り込む';

      // 空白埋め
      for (let i = 0; i < firstDay; i++) {
        const blank = document.createElement('div');
        blank.className = 'cal-day';
        daysEl.appendChild(blank);
      }

      for (let d = 1; d <= daysInMonth; d++) {
        const dateStr = `${artCalYear}-${String(artCalMonth + 1).padStart(2, '0')}-${String(d).padStart(2, '0')}`;
        const div = document.createElement('div');
        div.className = 'cal-day';
        div.textContent = d;

        if (articleDateSet.has(dateStr)) {
          div.classList.add('has-image'); // ギャラリーと同じクラス名を流用（「記事あり」の意味）
          div.addEventListener('click', (e) => {
            e.stopPropagation();
            artSelectedInput.value = dateStr;
            renderArtCalendar();
            // フォームをサブミットして絞り込む
            artSelectedInput.closest('form').submit();
          });
        }

        if (dateStr === selectedVal) div.classList.add('selected');

        const todayStr = `${today.getFullYear()}-${String(today.getMonth() + 1).padStart(2, '0')}-${String(today.getDate()).padStart(2, '0')}`;
        if (dateStr === todayStr) div.classList.add('today');

        daysEl.appendChild(div);
      }
    }

    // ★★★ ここに貼り付けます ★★★
    // ── 記事カレンダー用の年プルダウンを生成する処理 ──
    const artYearSelect = document.getElementById('artCalYearSelect');
    if (artYearSelect) {
      const todayYearForArt = new Date().getFullYear();
      // 2026年から現在の年+10年までを選択肢として追加
      for (let y = 2026; y <= todayYearForArt + 10; y++) {
        const option = document.createElement('option');
        option.value = y;
        option.text = y + '年';
        artYearSelect.appendChild(option);
      }

      // プルダウンで年を変更したときの処理
      artYearSelect.addEventListener('change', function() {
        artCalYear = parseInt(this.value); // 選択された年を代入
        renderArtCalendar(); // カレンダーを再描画
      });
    }
    // ★★★ ここまで ★★★

    // 前月・次月
    document.getElementById('artCalPrev').addEventListener('click', () => {
      artCalMonth--;
      if (artCalMonth < 0) { artCalMonth = 11; artCalYear--; }
      renderArtCalendar();
    });

    document.getElementById('artCalNext').addEventListener('click', () => {
      artCalMonth++;
      if (artCalMonth > 11) { artCalMonth = 0; artCalYear++; }
      renderArtCalendar();
    });

    // クリア
    document.getElementById('artCalClear').addEventListener('click', () => {
      artSelectedInput.value = '';
      renderArtCalendar();
      artSelectedInput.closest('form').submit();
    });

    // トグルボタン
    artCalToggleBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = artCalendarFilter.style.display !== 'none';
      artCalendarFilter.style.display = isOpen ? 'none' : 'block';
      artCalToggleBtn.classList.toggle('active', !isOpen);
    });

    // カレンダー外クリックで閉じる
    document.addEventListener('click', (e) => {
      if (!artCalendarFilter.contains(e.target) && e.target !== artCalToggleBtn) {
        artCalendarFilter.style.display = 'none';
        artCalToggleBtn.classList.remove('active');
      }
    });

    // 初期描画
    renderArtCalendar();

  }); // DOMContentLoaded 終わり

   // 画像選択のチェックボックスを切り替えたときのスタイル変更
  function toggleImageSelect(checkbox) {
    var thumbnail = checkbox.nextElementSibling;
    
    // 同じフォーム内のチェックされたボックスをカウント（4枚制限）
    var form = checkbox.closest('form');
    var checkedBoxes = form.querySelectorAll('input[name="image_ids[]"]:checked');
    
    if (checkedBoxes.length > 4) {
      alert("画像は最大4枚までしか選択できません。");
      checkbox.checked = false;
      return;
    }

    if (checkbox.checked) {
      thumbnail.style.border = "3px solid var(--clr-primary, #e8a820)";
      thumbnail.style.opacity = "1";
    } else {
      thumbnail.style.border = "1px solid var(--clr-border)";
      thumbnail.style.opacity = "0.5";
    }
  }
  // ======== ここからカレンダー絞り込みの処理 ========
  document.addEventListener('DOMContentLoaded', () => {
    const calendarFilter = document.getElementById('calendarFilter');
    const calToggleBtn = document.getElementById('calToggleBtn');
    
    // UIが存在しないページの場合は実行しない
    if (!calendarFilter || !calToggleBtn) return;

    // @all_images から画像が存在する日付のリスト（重複なし）を生成
    const uploadDates = <%= raw @all_images.map { |img| img.created_at.strftime('%Y-%m-%d') }.uniq.to_json %>;
    const uploadDateSet = new Set(uploadDates);

    let calYear, calMonth;
    const today = new Date();
    const selectedDateInput = document.getElementById('calSelectedDate');

    calYear = today.getFullYear();
    calMonth = today.getMonth();

    const yearSelect = document.getElementById('calYearSelect');
    for (let y = 2026; y <= today.getFullYear() + 10; y++) {
      const option = document.createElement('option');
      option.value = y;
      option.text = y + '年';
      yearSelect.appendChild(option);
    }

    yearSelect.addEventListener('change', function() {
      calYear = parseInt(this.value); 
      renderCalendar();
    });

    function renderCalendar() {
      const daysEl = document.getElementById('calendarDays');
      document.getElementById('calYearSelect').value = calYear;
      document.getElementById('calMonthText').textContent = `${calMonth + 1}月`;
      daysEl.innerHTML = '';

      const firstDay = new Date(calYear, calMonth, 1).getDay();
      const daysInMonth = new Date(calYear, calMonth + 1, 0).getDate();
      const selectedVal = selectedDateInput.value;

      document.getElementById('calToggleText').textContent = selectedVal ? selectedVal : '日付で絞り込む';

      for (let i = 0; i < firstDay; i++) {
        const blank = document.createElement('div');
        blank.className = 'cal-day';
        daysEl.appendChild(blank);
      }

      for (let d = 1; d <= daysInMonth; d++) {
        const dateStr = `${calYear}-${String(calMonth + 1).padStart(2, '0')}-${String(d).padStart(2, '0')}`;
        const div = document.createElement('div');
        div.className = 'cal-day';
        div.textContent = d;

        if (uploadDateSet.has(dateStr)) {
          div.classList.add('has-image');
          div.addEventListener('click', (e) => {
            e.stopPropagation();
            selectedDateInput.value = dateStr;
            renderCalendar();
            filterImagesByDate(dateStr); // 絞り込み実行
            calendarFilter.style.display = 'none';
            calToggleBtn.classList.remove('active');
          });
        }

        if (dateStr === selectedVal) div.classList.add('selected');

        const todayStr = `${today.getFullYear()}-${String(today.getMonth() + 1).padStart(2, '0')}-${String(today.getDate()).padStart(2, '0')}`;
        if (dateStr === todayStr) div.classList.add('today');

        daysEl.appendChild(div);
      }
    }

    // 表示切り替えロジック（AjaxではなくDOMの表示・非表示を切り替える）
    function filterImagesByDate(dateStr) {
      const labels = document.querySelectorAll('.image-checkbox-label');
      
      labels.forEach(label => {
        // 対象の日付と一致するか、日付指定がない(クリア状態)なら表示する
        if (!dateStr || label.dataset.date === dateStr) {
          label.style.display = '';
        } else {
          label.style.display = 'none';
        }
      });
    }

    document.getElementById('calPrev').addEventListener('click', () => {
      calMonth--;
      if (calMonth < 0) { calMonth = 11; calYear--; }
      renderCalendar();
    });

    document.getElementById('calNext').addEventListener('click', () => {
      calMonth++;
      if (calMonth > 11) { calMonth = 0; calYear++; }
      renderCalendar();
    });

    // クリアボタン
    document.getElementById('calClear').addEventListener('click', () => {
      selectedDateInput.value = '';
      renderCalendar();
      filterImagesByDate(''); // 全て表示
      calendarFilter.style.display = 'none';
      calToggleBtn.classList.remove('active');
    });

    calToggleBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = calendarFilter.style.display !== 'none';
      calendarFilter.style.display = isOpen ? 'none' : 'block';
      calToggleBtn.classList.toggle('active', !isOpen);
    });

    document.addEventListener('click', (e) => {
      if (!calendarFilter.contains(e.target) && e.target !== calToggleBtn) {
        calendarFilter.style.display = 'none';
        calToggleBtn.classList.remove('active');
      }
    });

    renderCalendar();
  });
  // ※既存のJavaScriptがチェックボックスを自動選択した際にも枠線を更新するための処理
  document.addEventListener("DOMContentLoaded", function() {
    document.querySelectorAll('.picker-checkbox').forEach(function(checkbox) {
      // 編集モーダルを開いたときなどにJS側でcheckedが変更されたら、このイベントを発火させる想定
      checkbox.addEventListener('change', function() {
        toggleImageSelect(this);
      });
    });
  });
</script>