<%#
  ── バックエンド側で追加が必要な対応 ──
  articles_controller.rb の index アクション内に以下を追加してください：

  # 記事が存在する日付の一覧（カレンダー用）
  @article_dates = Article.pluck(:created_at).map { |d| d.to_date.to_s }.uniq

  # 日付絞り込み
  if params[:date].present?
    @articles = @articles.where(created_at: Date.parse(params[:date]).all_day)
  end
%>

<div class="container">
  <header class="page-header">
    <h1>記事</h1>
    <p>チームの活動記録と思い出</p>
  </header>

  <div class="page-content">
    <div class="articles-actions">
      <% if current_user %>
        <button class="btn btn-primary" id="newArticleBtn">新しい記事を投稿</button>
      <% end %>
      <div class="filter-section-row">
        <!-- ▼ カレンダーフィルター（検索ボックスの左側） -->
        <div class="filter-section" id="articleFilterSection">
          <%= form_with url: articles_path, method: :get, local: true, class: "date-filter-form", data: { turbo: false } do |f| %>
            <button type="button" class="btn-cal-toggle" id="artCalToggleBtn">
              📅 <span id="artCalToggleText"><%= params[:date].present? ? params[:date] : "日付で絞り込む" %></span>
            </button>
            <div class="calendar-filter" id="artCalendarFilter" style="display:none;">
              <div class="calendar-header">
                <button type="button" class="cal-nav" id="artCalPrev">&#8249;</button>
                <span class="cal-title" id="artCalTitle"></span>
                <button type="button" class="cal-nav" id="artCalNext">&#8250;</button>
              </div>
              <div class="calendar-weekdays">
                <span>日</span><span>月</span><span>火</span><span>水</span><span>木</span><span>金</span><span>土</span>
              </div>
              <div class="calendar-days" id="artCalendarDays"></div>
              <input type="hidden" name="date" id="artCalSelectedDate" value="<%= params[:date] %>">
              <div class="calendar-actions">
                <button type="button" class="btn-cal-clear" id="artCalClear">クリア</button>
              </div>
            </div>
          <% end %>
        </div>
        <!-- ▲ カレンダーフィルターここまで -->

        <input type="text" placeholder="記事を検索..." id="searchArticles" class="search-input">
      </div>
    </div>

    <div class="articles-list" id="articlesList">
      <% if @articles.any? %>
        <% @articles.each do |article| %>
          <div class="article-card" data-article-id="<%= article.id %>" data-full-title="<%= article.title %>" data-full-content="<%= article.content %>">
            <% if article.images.any? %>
              <div class="article-thumbnails">
                <% article.images.first(4).each do |img| %>
                  <% if img.file.attached? %>
                    <div class="article-thumb" data-full-url="<%= url_for(img.file) %>">
                        <%= image_tag img.file.variant(resize_to_fill: [800, 800]), class: "thumb-img" %>
                    </div>
                  <% end %>
                <% end %>
              </div>
            <% end %>
            <div class="article-body">
              <h3><%= article.title %></h3>
              <p class="article-content-preview"><%= truncate(article.content, length: 60) %></p>
              <% if article.tags.present? %>
                <div class="article-tags">
                  <% article.tags.split(",").map(&:strip).each do |tag| %>
                    <span class="tag"><%= tag %></span>
                  <% end %>
                </div>
              <% end %>
              <p class="article-meta">
                <%= article.user.username %> ・ <%= article.created_at.strftime("%Y年%m月%d日") %>
              </p>
              <% if current_user&.admin? || current_user == article.user %>
                <div class="article-actions">
                  <button class="btn btn-secondary btn-sm edit-article-btn"
                    data-id="<%= article.id %>"
                    data-title="<%= article.title %>"
                    data-content="<%= article.content %>"
                    data-tags="<%= article.tags %>"
                    data-image-ids="<%= article.images.pluck(:id).join(',') %>">
                    編集
                  </button>
                  <%= button_to "削除", article_path(article), method: :delete,
                      class: "btn btn-danger btn-sm",
                      data: { confirm: "本当に削除しますか？" } %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="empty-state">
          <p>記事がまだ投稿されていません</p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- 記事投稿モーダル -->
  <div class="modal" id="articleModal">
    <div class="modal-content modal-lg">
      <span class="close" id="closeArticleModal">&times;</span>
      <h2>記事を投稿</h2>
      <%= form_with url: articles_path, method: :post, id: "articleForm", scope: :article do |f| %>
        <div class="form-group">
            <%= f.label :title, "タイトル" %>
            <%= f.text_field :title, required: true, placeholder: "記事のタイトルを入力してください", data: { maxweight: 40 } %>
        </div>
        <div class="form-group">
            <%= f.label :content, "本文" %>
            <%= f.text_area :content, rows: 6, required: true, placeholder: "記事の内容を入力してください", data: { maxweight: 2000 } %>
        </div>
        <div class="form-group">
            <%= f.label :tags, "タグ（カンマで区切る）" %>
            <%= f.text_field :tags, placeholder: "例：イベント, 冒険, 面白かった" %>
        </div>

        <!-- 画像選択 -->
        <div class="form-group">
          <label>画像を選択（最大4枚）</label>
          <div class="image-picker" id="imagePicker">
            <% if @all_images.any? %>
              <% @all_images.each do |img| %>
                <% if img.file.attached? %>
                  <div class="picker-item" data-image-id="<%= img.id %>">
                    <%= image_tag img.file.variant(resize_to_fill: [120, 120]), class: "picker-thumb" %>
                    <div class="picker-check">✓</div>
                    <input type="checkbox" name="image_ids[]" value="<%= img.id %>" class="picker-checkbox" style="display:none;">
                  </div>
                <% end %>
              <% end %>
            <% else %>
              <p class="no-images-msg">ギャラリーに画像がありません</p>
            <% end %>
          </div>
          <p class="picker-hint">選択中: <span id="selectedCount">0</span> / 4枚</p>
        </div>

        <div class="form-actions">
          <%= f.submit "投稿", class: "btn btn-primary" %>
          <button type="button" class="btn btn-secondary" id="cancelArticle">キャンセル</button>
        </div>
      <% end %>
    </div>
  </div>

  <!-- 記事詳細モーダル -->
<div class="modal" id="articleViewModal">
  <div class="article-view-modal-content">

    <!-- ヒーロー画像エリア -->
    <div id="viewModalImageArea" class="view-modal-hero"></div>

    <!-- 画像フルスクリーンプレビュー -->
    <div id="viewModalPreview" class="view-modal-preview" style="display:none;">
      <button class="preview-close-btn" id="closePreview">&times;</button>
      <img id="viewModalPreviewImg" src="" alt="プレビュー" class="preview-full-img">
    </div>

    <!-- ヘッダー（閉じるボタン） -->
    <div class="article-view-header">
      <button class="article-view-close" id="closeArticleViewModal" aria-label="閉じる">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <!-- 本文エリア -->
    <div class="view-modal-body">
      <div class="view-modal-meta-row">
        <span class="view-modal-author-badge" id="viewModalAuthorBadge"></span>
        <span class="view-modal-date" id="viewModalDate"></span>
      </div>
      <h2 id="viewModalTitle" class="view-modal-title"></h2>
      <div id="viewModalTags" class="view-modal-tags"></div>
      <div class="view-modal-divider"></div>
      <p id="viewModalContent" class="view-modal-content-text"></p>
    </div>

  </div>
</div>

  <!-- 記事編集モーダル -->
  <div class="modal" id="editArticleModal">
    <div class="modal-content modal-lg">
      <span class="close" id="closeEditModal">&times;</span>
      <h2>記事を編集</h2>
      <form id="editArticleForm" method="post">
        <input type="hidden" name="_method" value="patch">
        <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
        <div class="form-group">
          <label>タイトル</label>
          <input type="text" name="article[title]" id="editArticleTitle" required data-maxweight="40">
        </div>
        <div class="form-group">
          <label>本文</label>
          <textarea name="article[content]" id="editArticleContent" rows="6" required data-maxweight="2000"></textarea>
        </div>
        <div class="form-group">
          <label>タグ</label>
          <input type="text" name="article[tags]" id="editArticleTags" placeholder="例：イベント, 冒険">
        </div>

        <!-- 画像選択 -->
        <div class="form-group">
          <label>画像を選択（最大4枚）</label>
          <div class="image-picker" id="editImagePicker">
            <% if @all_images.any? %>
              <% @all_images.each do |img| %>
                <% if img.file.attached? %>
                  <div class="picker-item" data-image-id="<%= img.id %>">
                    <%= image_tag img.file.variant(resize_to_fill: [120, 120]), class: "picker-thumb" %>
                    <div class="picker-check">✓</div>
                    <input type="checkbox" name="image_ids[]" value="<%= img.id %>" class="picker-checkbox" style="display:none;">
                  </div>
                <% end %>
              <% end %>
            <% else %>
              <p class="no-images-msg">ギャラリーに画像がありません</p>
            <% end %>
          </div>
          <p class="picker-hint">選択中: <span id="editSelectedCount">0</span> / 4枚</p>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary">更新</button>
          <button type="button" class="btn btn-secondary" id="cancelEdit">キャンセル</button>
        </div>
      </form>
    </div>
  </div>
  <!-- 記事用画像拡大モーダル -->
    <div class="modal" id="articleImageViewModal">
    <div class="modal-content article-image-view-modal-content">
        <div class="image-modal-header">
        <span class="close" id="closeArticleImageModal">&times;</span>
        </div>
        <div class="image-modal-body">
        <img id="articleModalImage" src="" alt="拡大画像" class="modal-full-image">
        </div>
        <div class="image-modal-footer">
        <button class="btn btn-secondary" id="closeArticleImageModalBtn">閉じる</button>
        </div>
    </div>
    </div>
</div>

<style>
  /* ── フィルター行（カレンダー＋検索） ── */
  .filter-section-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  /* ── カレンダーフィルター（ギャラリーページから流用） ── */
  .filter-section {
    position: relative;
  }

  .btn-cal-toggle {
    background: linear-gradient(180deg, #3a2108 0%, #241400 100%);
    border: 1px solid #5a3510;
    border-radius: 6px;
    padding: 10px 16px;
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    color: #e8a820;
    box-shadow:
      0 1px 0 rgba(255,200,80,.12) inset,
      0 3px 8px rgba(0,0,0,.5),
      0 1px 0 rgba(0,0,0,.7);
    transition: filter 0.2s ease;
    white-space: nowrap;
    text-shadow: 0 1px 2px rgba(0,0,0,.5);
  }

  .btn-cal-toggle:hover {
    filter: brightness(1.2);
    border-color: #c8820a;
  }

  .btn-cal-toggle.active {
    background: linear-gradient(180deg, #c8820a 0%, #7a4800 100%);
    border-color: #6a3e00;
    color: #fff8e0;
    box-shadow:
      0 1px 0 rgba(255,200,80,.25) inset,
      0 3px 10px rgba(0,0,0,.6);
  }

  .calendar-filter {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    background: linear-gradient(180deg, #2e1a00 0%, #1e1000 100%);
    border: 1px solid #5a3510;
    border-radius: 8px;
    padding: 14px;
    width: 280px;
    box-shadow:
      0 8px 24px rgba(0,0,0,.7),
      inset 0 1px 0 rgba(255,200,80,.12);
    z-index: 100;
  }

  .calendar-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
  }

  .cal-title {
    font-weight: 700;
    font-size: 15px;
    color: #e8a820;
    text-shadow: 0 1px 3px rgba(0,0,0,.5);
  }

  .cal-nav {
    background: linear-gradient(180deg, #3a2108 0%, #241400 100%);
    border: 1px solid #5a3510;
    border-radius: 4px;
    font-size: 18px;
    cursor: pointer;
    color: #e8a820;
    padding: 2px 10px;
    line-height: 1;
    box-shadow:
      0 1px 0 rgba(255,200,80,.12) inset,
      0 2px 4px rgba(0,0,0,.5);
    transition: filter .15s;
  }

  .cal-nav:hover { filter: brightness(1.3); }

  .calendar-weekdays {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    text-align: center;
    font-size: 12px;
    font-weight: 700;
    color: #7a5030;
    margin-bottom: 4px;
  }

  .calendar-weekdays span:first-child { color: #c05040; }
  .calendar-weekdays span:last-child  { color: #8090c0; }

  .calendar-days {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 2px;
  }

  .cal-day {
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    border-radius: 50%;
    cursor: default;
    color: #4a3020;
  }

  .cal-day.has-image {
    color: #e8d5b0;
    cursor: pointer;
    font-weight: 700;
  }

  .cal-day.has-image:hover {
    background: rgba(200,130,10,.25);
    color: #e8a820;
  }

  .cal-day.selected {
    background: linear-gradient(135deg, #c8820a, #7a4800);
    color: #fff8e0 !important;
    box-shadow: 0 2px 6px rgba(0,0,0,.5);
  }

  .cal-day.today {
    border: 1px solid #c8820a;
  }

  .calendar-actions {
    display: flex;
    gap: 8px;
    margin-top: 10px;
    justify-content: flex-end;
  }

  .btn-cal-clear {
    background: linear-gradient(180deg, #3a2108 0%, #241400 100%);
    border: 1px solid #5a3510;
    border-radius: 4px;
    padding: 6px 14px;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    color: #a08060;
    box-shadow:
      0 1px 0 rgba(255,200,80,.08) inset,
      0 2px 4px rgba(0,0,0,.4);
    transition: filter .15s;
  }

  .btn-cal-clear:hover { filter: brightness(1.3); color: #e8d5b0; }

  /* ── 以下は元のスタイルそのまま ── */
  .articles-list {
    display: flex;
    flex-direction: column;
    gap: 24px;
    margin-top: 30px;
  }

  .article-card {
    border: 1px solid #7a4818;
    border-radius: 8px;
    background: linear-gradient(180deg, #4a2a0a 0%, #3a2108 100%);
    overflow: hidden;
    cursor: pointer;
    box-shadow:
      0 6px 16px rgba(0,0,0,.7),
      inset 0 2px 0 rgba(255,200,80,.2),
      inset 0 -2px 0 rgba(0,0,0,.4);
    transition: all .25s ease;
  }

  .article-card:hover {
    transform: translateY(-3px);
    border-color: #c8820a;
    box-shadow:
      0 10px 24px rgba(0,0,0,.8),
      inset 0 2px 0 rgba(255,200,80,.3),
      inset 0 -2px 0 rgba(0,0,0,.5);
  }

  .article-thumbnails {
    display: flex;
    gap: 4px;
    background: #241400;
  }

  .article-thumb {
    flex: 1;
    aspect-ratio: 16/9;
    overflow: hidden;
    max-width: 25%;
  }

  .thumb-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .article-body {
    padding: 20px;
  }

  .article-body h3 {
    margin: 0 0 10px 0;
    color: #e8a820;
    font-size: 20px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    white-space: normal;
    text-shadow: 0 1px 3px rgba(0,0,0,.5);
  }

  .article-content-preview {
    color: #a08060;
    margin-bottom: 12px;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    white-space: normal;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 12px;
  }

  .tag {
    background: rgba(200,130,10,.18);
    color: #e8a820;
    border: 1px solid rgba(200,130,10,.35);
    padding: 3px 10px;
    border-radius: 12px;
    font-size: 12px;
    font-weight: 700;
  }

  .article-meta {
    color: #7a5030;
    font-size: 13px;
    margin-bottom: 12px;
  }

  .article-actions {
    display: flex;
    gap: 8px;
  }

  .btn-danger {
    background: #e74c3c;
    color: white;
    border: none;
    padding: 6px 14px;
    border-radius: 4px;
    cursor: pointer;
    font-size: 13px;
    font-weight: 600;
  }

  .btn-danger:hover { background: #c0392b; }

  .image-picker {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(90px, 1fr));
    gap: 8px;
    max-height: 280px;
    overflow-y: auto;
    border: 1px solid #5a3510;
    border-radius: 6px;
    padding: 10px;
    background: #150d00;
    box-shadow: inset 0 2px 6px rgba(0,0,0,.5);
  }

  .picker-item {
    position: relative;
    aspect-ratio: 1;
    border-radius: 6px;
    overflow: hidden;
    cursor: pointer;
    border: 3px solid transparent;
    transition: border-color 0.2s ease;
  }

  .picker-item.selected { border-color: #c8820a; }
  .picker-item.disabled { opacity: 0.4; cursor: not-allowed; }

  .picker-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .picker-check {
    position: absolute;
    top: 4px;
    right: 4px;
    width: 22px;
    height: 22px;
    background: #3498db;
    color: white;
    border-radius: 50%;
    display: none;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: bold;
  }

  .picker-item.selected .picker-check { display: flex; }

  .picker-hint {
    color: #888;
    font-size: 13px;
    margin-top: 6px;
  }

  .no-images-msg {
    color: #aaa;
    font-size: 14px;
    padding: 20px;
    text-align: center;
    grid-column: 1 / -1;
  }

  .articles-actions {
    display: flex;
    gap: 15px;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
  }

  .article-actions .btn-secondary {
    background-color: #ecf0f1;
    color: #2c3e50;
    border: 1px solid #bdc3c7;
    padding: 6px 14px;
    font-size: 13px;
    font-weight: 600;
    line-height: 1;
    display: inline-block;
  }

  .article-actions .btn-secondary:hover { background-color: #dde1e3; }

  /* ─── 記事詳細モーダル ─── */
  #articleViewModal {
    display: none;
    position: fixed;
    z-index: 2000;
    inset: 0;
    background: rgba(10, 14, 23, 0.75);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    justify-content: center;
    align-items: center;
    padding: 20px;
  }

  #articleViewModal.modal-open { display: flex; }

  .article-view-modal-content {
    position: relative;
    background: #fff;
    border-radius: 16px;
    width: 95vw;
    max-width: 1200px;
    max-height: 92vh;
    overflow-y: auto;
    box-shadow: 0 32px 80px rgba(0,0,0,0.35), 0 0 0 1px rgba(255,255,255,0.06);
    animation: modalRise 0.28s cubic-bezier(0.34, 1.3, 0.64, 1) both;
    scrollbar-width: none;
  }

  .article-view-modal-content::-webkit-scrollbar { display: none; }

  @keyframes modalRise {
    from { opacity: 0; transform: translateY(24px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0)    scale(1);    }
  }

  .article-view-header {
    position: absolute;
    top: 14px;
    right: 14px;
    z-index: 10;
  }

  .article-view-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: none;
    cursor: pointer;
    background: rgba(255,255,255,0.85);
    color: #374151;
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
    backdrop-filter: blur(4px);
    transition: background 0.15s, color 0.15s, transform 0.15s;
  }

  .article-view-close:hover {
    background: #1a1a2e;
    color: #fff;
    transform: rotate(90deg);
  }

  .view-modal-hero {
    width: 100%;
    display: grid;
    gap: 3px;
    border-radius: 16px 16px 0 0;
    overflow: hidden;
    background: #fff;
    min-height: 0;
    padding: 16px;
    aspect-ratio: 16 / 9;
    max-height: 600px;
    box-sizing: border-box;
  }

  .view-modal-hero.hero-1 { grid-template-columns: 1fr; }
  .view-modal-hero.hero-2 { grid-template-columns: 1fr 1fr; }
  .view-modal-hero.hero-3 {
    grid-template-columns: 2fr 1fr;
    grid-template-rows: calc((100% - 3px) / 2) calc((100% - 3px) / 2);
  }
  .view-modal-hero.hero-4 {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: calc((100% - 3px) / 2) calc((100% - 3px) / 2);
  }

  .view-modal-hero.hero-3 .view-hero-img-wrap:first-child { grid-row: 1 / 3; }

  .view-hero-img-wrap {
    width: 100%;
    height: 100%;
    min-height: 0;
    overflow: hidden;
    cursor: zoom-in;
    position: relative;
    border-radius: 10px;
  }

  .view-hero-img-wrap img {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
    background: #f3f4f6;
  }

  .view-hero-img-wrap:hover img { transform: scale(1.04); }

  .view-modal-preview {
    position: relative;
    background: #000;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .preview-full-img {
    max-width: 100%;
    max-height: 420px;
    object-fit: contain;
    display: block;
  }

  .preview-close-btn {
    position: absolute;
    top: 10px; right: 12px;
    background: rgba(0,0,0,0.55);
    color: white;
    border: none;
    border-radius: 50%;
    width: 32px; height: 32px;
    font-size: 20px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    line-height: 1;
    transition: background 0.2s;
  }

  .preview-close-btn:hover { background: rgba(255,255,255,0.2); }

  .view-modal-body {
    padding: 28px 32px 36px;
  }

  .view-modal-meta-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
  }

  .view-modal-author-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 700;
    color: #fff;
    background: linear-gradient(135deg, #3b82f6, #6366f1);
    padding: 4px 12px;
    border-radius: 20px;
    letter-spacing: 0.02em;
  }

  .view-modal-date {
    font-size: 12px;
    color: #9ca3af;
    letter-spacing: 0.04em;
  }

  .view-modal-title {
    font-size: 24px;
    font-weight: 800;
    color: #111827;
    line-height: 1.35;
    margin: 0 0 16px;
    letter-spacing: -0.02em;
  }

  .view-modal-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 20px;
  }

  .view-modal-tags .tag {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #6366f1;
    background: #eef2ff;
    border: 1px solid #c7d2fe;
    padding: 4px 10px;
    border-radius: 6px;
  }

  .view-modal-divider {
    height: 1px;
    background: linear-gradient(to right, #e5e7eb, transparent);
    margin-bottom: 20px;
  }

  .view-modal-content-text {
    font-size: 15px;
    line-height: 1.85;
    color: #374151;
    white-space: pre-wrap;
    margin: 0;
  }

  #articleImageViewModal {
    display: none;
    position: fixed;
    z-index: 3000;
    left: 0; top: 0;
    width: 100%; height: 100%;
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(4px);
    justify-content: center;
    align-items: center;
  }

  #articleImageViewModal.active { display: flex; }

  .article-image-view-modal-content {
    background: rgba(15, 15, 15, 0.95);
    border-radius: 12px;
    padding: 0;
    width: auto;
    max-width: 90vw;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.8);
    overflow: hidden;
    position: relative;
    margin: auto;
  }

  .modal-full-image {
    max-width: 100%;
    max-height: 70vh;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
    margin: 0 auto;
  }

  .image-modal-body {
    width: 100%;
    padding: 16px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  #editArticleContent { resize: vertical; }
  #article_content    { resize: vertical; }

  @media (max-width: 768px) {
    .article-thumb { max-width: 50%; }
    .articles-actions { flex-direction: column; align-items: stretch; }
    .filter-section-row { flex-direction: row; flex-wrap: wrap; }
    .view-modal-hero { max-height: 240px; }
    .view-modal-body { padding: 20px 20px 28px; }
    .view-modal-title { font-size: 20px; }
    .article-view-modal-content { border-radius: 12px; max-height: 95vh; }
  }
</style>

<script>
  // ── バックエンドから渡された記事投稿日リスト ──
  // コントローラで @article_dates を設定してください（上部コメント参照）
  const articleDates = <%= @article_dates.to_json.html_safe %>;
  const articleDateSet = new Set(articleDates);

  document.addEventListener('DOMContentLoaded', () => {

    // ── 文字数カウント（半角0.5文字換算） ──
    function calcWeight(str) {
      let weight = 0;
      for (const ch of str) {
        weight += /[\x00-\x7F]/.test(ch) ? 0.5 : 1;
      }
      return weight;
    }

    document.querySelectorAll('[data-maxweight]').forEach(input => {
      const max = parseFloat(input.dataset.maxweight);
      input.addEventListener('input', () => {
        const weight = calcWeight(input.value);
        if (weight > max) {
          let trimmed = '', total = 0;
          for (const ch of input.value) {
            const w = /[\x00-\x7F]/.test(ch) ? 0.5 : 1;
            if (total + w > max) break;
            trimmed += ch;
            total += w;
          }
          input.value = trimmed;
        }
      });
    });

    // ── モーダル開閉ヘルパー ──
    function openModal(id) {
      const el = document.getElementById(id);
      if (id === 'articleViewModal') {
        el.style.display = 'flex';
        el.classList.add('modal-open');
        document.body.style.overflow = 'hidden';
      } else {
        el.style.display = 'block';
      }
    }
    function closeModal(id) {
      const el = document.getElementById(id);
      el.style.display = 'none';
      el.classList.remove('modal-open');
      if (id === 'articleViewModal') document.body.style.overflow = '';
    }

    // ── 投稿モーダル ──
    const newArticleBtn = document.getElementById('newArticleBtn');
    if (newArticleBtn) {
      newArticleBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        openModal('articleModal');
      });
    }
    document.getElementById('closeArticleModal').addEventListener('click', () => closeModal('articleModal'));
    document.getElementById('cancelArticle').addEventListener('click', () => closeModal('articleModal'));

    // ── 編集モーダル ──
    document.getElementById('closeEditModal').addEventListener('click', () => closeModal('editArticleModal'));
    document.getElementById('cancelEdit').addEventListener('click', () => closeModal('editArticleModal'));

    // ── 詳細モーダル ──
    document.getElementById('closeArticleViewModal').addEventListener('click', () => closeModal('articleViewModal'));
    document.getElementById('closePreview').addEventListener('click', () => {
      document.getElementById('viewModalPreview').style.display = 'none';
      document.getElementById('viewModalImageArea').style.display = 'flex';
    });

    window.addEventListener('click', (e) => {
      const viewModal = document.getElementById('articleViewModal');
      if (e.target === viewModal) closeModal('articleViewModal');
    });

    // ── 画像ピッカー ──
    function initPicker(pickerId, counterId, maxCount) {
      const picker = document.getElementById(pickerId);
      const counter = document.getElementById(counterId);
      if (!picker || !counter) return;

      picker.querySelectorAll('.picker-item').forEach(item => {
        item.addEventListener('click', () => {
          const checkbox = item.querySelector('.picker-checkbox');
          const selectedCount = picker.querySelectorAll('.picker-item.selected').length;

          if (item.classList.contains('selected')) {
            item.classList.remove('selected');
            checkbox.checked = false;
          } else {
            if (selectedCount >= maxCount) return;
            item.classList.add('selected');
            checkbox.checked = true;
          }

          const newCount = picker.querySelectorAll('.picker-item.selected').length;
          counter.textContent = newCount;
          picker.querySelectorAll('.picker-item:not(.selected)').forEach(i => {
            i.classList.toggle('disabled', newCount >= maxCount);
          });
        });
      });
    }

    initPicker('imagePicker', 'selectedCount', 4);
    initPicker('editImagePicker', 'editSelectedCount', 4);

    // ── 編集ボタン ──
    document.querySelectorAll('.edit-article-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const id = btn.dataset.id;
        const imageIds = btn.dataset.imageIds ? btn.dataset.imageIds.split(',').filter(Boolean) : [];

        document.getElementById('editArticleTitle').value = btn.dataset.title;
        document.getElementById('editArticleContent').value = btn.dataset.content;
        document.getElementById('editArticleTags').value = btn.dataset.tags || '';
        document.getElementById('editArticleForm').action = `/articles/${id}`;

        const picker = document.getElementById('editImagePicker');
        picker.querySelectorAll('.picker-item').forEach(item => {
          item.classList.remove('selected', 'disabled');
          item.querySelector('.picker-checkbox').checked = false;
        });

        imageIds.forEach(imgId => {
          const item = picker.querySelector(`[data-image-id="${imgId.trim()}"]`);
          if (item) {
            item.classList.add('selected');
            item.querySelector('.picker-checkbox').checked = true;
          }
        });

        const count = picker.querySelectorAll('.picker-item.selected').length;
        document.getElementById('editSelectedCount').textContent = count;
        picker.querySelectorAll('.picker-item:not(.selected)').forEach(i => {
          i.classList.toggle('disabled', count >= 4);
        });

        openModal('editArticleModal');
      });
    });

    // ── 削除ボタンの伝播を止める ──
    document.querySelectorAll('.article-actions form').forEach(form => {
      form.addEventListener('click', (e) => e.stopPropagation());
    });

    // ── 記事カードクリックで詳細モーダル ──
    document.querySelectorAll('.article-card').forEach(card => {
      card.addEventListener('click', (e) => {
        if (e.target.closest('.edit-article-btn') || e.target.closest('.btn-danger') || e.target.closest('form')) return;

        const title   = card.dataset.fullTitle   || card.querySelector('h3').textContent;
        const content = card.dataset.fullContent || '';
        const metaRaw = card.querySelector('.article-meta').textContent.trim();
        const metaParts = metaRaw.split('・').map(s => s.trim());
        const author = metaParts[0] || '';
        const date   = metaParts[1] || '';
        const tagsEl = card.querySelector('.article-tags');

        document.getElementById('viewModalTitle').textContent   = title;
        document.getElementById('viewModalContent').textContent = content;
        document.getElementById('viewModalAuthorBadge').textContent = author;
        document.getElementById('viewModalDate').textContent    = date;

        const tagsContainer = document.getElementById('viewModalTags');
        tagsContainer.innerHTML = '';
        if (tagsEl) {
          tagsEl.querySelectorAll('.tag').forEach(tag => {
            const span = document.createElement('span');
            span.className = 'tag';
            span.textContent = tag.textContent;
            tagsContainer.appendChild(span);
          });
        }

        const imageArea = document.getElementById('viewModalImageArea');
        imageArea.innerHTML = '';
        imageArea.className = 'view-modal-hero';
        document.getElementById('viewModalPreview').style.display = 'none';

        const thumbs = card.querySelectorAll('.article-thumb');
        const count  = thumbs.length;

        if (count > 0) {
          imageArea.style.display = '';
          imageArea.classList.add(`hero-${Math.min(count, 4)}`);
          thumbs.forEach((thumb, idx) => {
            if (idx >= 4) return;
            const img = thumb.querySelector('img');
            if (!img) return;

            const fullUrl = thumb.dataset.fullUrl || img.src;
            const wrap = document.createElement('div');
            wrap.className = `view-hero-img-wrap hero-${Math.min(count, 4)}`;

            const image = document.createElement('img');
            image.src = img.src;
            image.alt = '';
            wrap.appendChild(image);

            wrap.addEventListener('click', (ev) => {
              ev.stopPropagation();
              document.getElementById('articleModalImage').src = fullUrl;
              document.getElementById('articleImageViewModal').classList.add('active');
            });

            imageArea.appendChild(wrap);
          });
        } else {
          imageArea.style.display = 'none';
        }

        const modal = document.getElementById('articleViewModal');
        modal.style.display = 'flex';
        modal.classList.add('modal-open');
        document.body.style.overflow = 'hidden';
      });
    });

    // ── 検索 ──
    document.getElementById('searchArticles').addEventListener('input', (e) => {
      const q = e.target.value.toLowerCase();
      document.querySelectorAll('.article-card').forEach(card => {
        card.style.display = card.textContent.toLowerCase().includes(q) ? 'block' : 'none';
      });
    });

    // ────────────────────────────────────────
    // ── 記事ページ用カレンダーフィルター ──
    // ────────────────────────────────────────
    const artCalToggleBtn    = document.getElementById('artCalToggleBtn');
    const artCalendarFilter  = document.getElementById('artCalendarFilter');
    const artSelectedInput   = document.getElementById('artCalSelectedDate');

    let artCalYear, artCalMonth;
    const today = new Date();

    if (artSelectedInput.value) {
      const d = new Date(artSelectedInput.value);
      artCalYear  = d.getFullYear();
      artCalMonth = d.getMonth();
    } else {
      artCalYear  = today.getFullYear();
      artCalMonth = today.getMonth();
    }

    function renderArtCalendar() {
      const title  = document.getElementById('artCalTitle');
      const daysEl = document.getElementById('artCalendarDays');

      title.textContent = `${artCalYear}年${artCalMonth + 1}月`;
      daysEl.innerHTML  = '';

      const firstDay    = new Date(artCalYear, artCalMonth, 1).getDay();
      const daysInMonth = new Date(artCalYear, artCalMonth + 1, 0).getDate();
      const selectedVal = artSelectedInput.value;

      // トグルボタンのテキスト更新
      document.getElementById('artCalToggleText').textContent = selectedVal || '日付で絞り込む';

      // 空白埋め
      for (let i = 0; i < firstDay; i++) {
        const blank = document.createElement('div');
        blank.className = 'cal-day';
        daysEl.appendChild(blank);
      }

      for (let d = 1; d <= daysInMonth; d++) {
        const dateStr = `${artCalYear}-${String(artCalMonth + 1).padStart(2, '0')}-${String(d).padStart(2, '0')}`;
        const div = document.createElement('div');
        div.className = 'cal-day';
        div.textContent = d;

        if (articleDateSet.has(dateStr)) {
          div.classList.add('has-image'); // ギャラリーと同じクラス名を流用（「記事あり」の意味）
          div.addEventListener('click', (e) => {
            e.stopPropagation();
            artSelectedInput.value = dateStr;
            renderArtCalendar();
            // フォームをサブミットして絞り込む
            artSelectedInput.closest('form').submit();
          });
        }

        if (dateStr === selectedVal) div.classList.add('selected');

        const todayStr = `${today.getFullYear()}-${String(today.getMonth() + 1).padStart(2, '0')}-${String(today.getDate()).padStart(2, '0')}`;
        if (dateStr === todayStr) div.classList.add('today');

        daysEl.appendChild(div);
      }
    }

    // 前月・次月
    document.getElementById('artCalPrev').addEventListener('click', () => {
      artCalMonth--;
      if (artCalMonth < 0) { artCalMonth = 11; artCalYear--; }
      renderArtCalendar();
    });

    document.getElementById('artCalNext').addEventListener('click', () => {
      artCalMonth++;
      if (artCalMonth > 11) { artCalMonth = 0; artCalYear++; }
      renderArtCalendar();
    });

    // クリア
    document.getElementById('artCalClear').addEventListener('click', () => {
      artSelectedInput.value = '';
      renderArtCalendar();
      artSelectedInput.closest('form').submit();
    });

    // トグルボタン
    artCalToggleBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = artCalendarFilter.style.display !== 'none';
      artCalendarFilter.style.display = isOpen ? 'none' : 'block';
      artCalToggleBtn.classList.toggle('active', !isOpen);
    });

    // カレンダー外クリックで閉じる
    document.addEventListener('click', (e) => {
      if (!artCalendarFilter.contains(e.target) && e.target !== artCalToggleBtn) {
        artCalendarFilter.style.display = 'none';
        artCalToggleBtn.classList.remove('active');
      }
    });

    // 初期描画
    renderArtCalendar();

  }); // DOMContentLoaded 終わり

  // ── 記事用画像拡大モーダル ──
  document.getElementById('closeArticleImageModal').addEventListener('click', () => {
    document.getElementById('articleImageViewModal').classList.remove('active');
  });

  document.getElementById('closeArticleImageModalBtn').addEventListener('click', () => {
    document.getElementById('articleImageViewModal').classList.remove('active');
  });

  document.getElementById('articleImageViewModal').addEventListener('click', (e) => {
    if (e.target === document.getElementById('articleImageViewModal')) {
      document.getElementById('articleImageViewModal').classList.remove('active');
    }
  });
</script>